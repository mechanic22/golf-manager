@inherits IconComponentBase

@code {
    /// <summary>
    /// SVG path data for the icon
    /// </summary>
    [Parameter, EditorRequired]
    public string Path { get; set; } = string.Empty;
}

<svg xmlns="http://www.w3.org/2000/svg"
     focusable="false"
     aria-hidden="true"
     viewBox="0 0 24 24"
     fill="@FillColor"
     class="@Css"
     @attributes="AdditionalAttributes">
    <path d="@Path"></path>
</svg>

