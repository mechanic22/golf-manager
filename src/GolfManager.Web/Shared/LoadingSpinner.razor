@* Centered loading spinner with optional message. *@

<div class="flex flex-col items-center justify-center @PaddingClass">
    <div class="inline-block animate-spin rounded-full @SizeClass border-b-2 border-primary-600 mb-3"></div>
    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p class="text-gray-600">@Message</p>
    }
</div>

@code {
    [Parameter] public string Message { get; set; } = "Loading...";
    [Parameter] public string Padding { get; set; } = "py-8";

    private string PaddingClass => Padding;
    private string SizeClass => "h-8 w-8";
}
