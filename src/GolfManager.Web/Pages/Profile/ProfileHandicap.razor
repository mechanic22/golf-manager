@page "/profile/handicap"
@layout AppLayout

<PageTitle>Handicap History - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading handicap history...</p>
        </div>
    </div>
}
else
{
    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
            <a href="/profile" class="hover:text-primary-600">Profile</a>
            <span>/</span>
            <span class="text-gray-900">Handicap History</span>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Handicap History</h1>
        <p class="text-gray-600">Track your handicap index over time</p>
    </div>

    <!-- Current Handicap Card -->
    <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold text-gray-900">Current Handicap Index</h2>
            <span class="text-3xl font-bold text-primary-600">@currentHandicap</span>
        </div>
        <p class="text-sm text-gray-600">Last updated: @lastUpdated.ToString("MMMM dd, yyyy")</p>
    </div>

    <!-- Handicap Trend Chart -->
    <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Handicap Trend</h2>
        <div class="h-64 flex items-center justify-center bg-gray-50 rounded-lg">
            <p class="text-gray-500">TODO: Chart showing handicap trend over time</p>
        </div>
    </div>

    <!-- Rounds Used in Calculation -->
    <div class="bg-white rounded-lg border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Rounds Used in Calculation</h2>
        <p class="text-sm text-gray-600 mb-4">Your handicap is calculated using your best 8 of your last 20 rounds</p>
        
        <div class="space-y-3">
            @foreach (var round in handicapRounds)
            {
                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                    <div>
                        <p class="font-medium text-gray-900">@round.CourseName</p>
                        <p class="text-sm text-gray-600">@round.Date.ToString("MMM dd, yyyy")</p>
                    </div>
                    <div class="text-right">
                        <p class="font-semibold text-gray-900">Score: @round.Score</p>
                        <p class="text-sm text-gray-600">Differential: @round.Differential</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Explanation -->
    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-6">
        <h3 class="font-semibold text-blue-900 mb-2">How is my handicap calculated?</h3>
        <p class="text-sm text-blue-800">
            Your Handicap Index is calculated using the best 8 of your last 20 rounds. 
            Each round's score differential is calculated based on the course rating and slope. 
            The average of your best 8 differentials is multiplied by 0.96 to get your Handicap Index.
        </p>
    </div>
}

