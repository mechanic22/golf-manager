@page "/profile/stats"
@layout AppLayout

<PageTitle>My Stats - Pinzo</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    <div class="text-center py-16">
        <p class="text-gray-600">Please log in to view your stats.</p>
    </div>
}
else
{
    <!-- Breadcrumb -->
    <div class="mb-6 text-sm text-gray-600">
        <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
        <span class="mx-2">/</span>
        <a href="/profile" class="hover:text-primary-600">Profile</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Stats</span>
    </div>

    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">My Statistics</h1>
        <p class="text-gray-600">Detailed analysis of your golf performance</p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="text-sm text-gray-500 mb-1">Scoring Average</div>
            <div class="text-3xl font-bold text-primary-600">87.3</div>
            <div class="text-xs text-green-600 mt-1">↓ 2.1 from last month</div>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="text-sm text-gray-500 mb-1">Best Score</div>
            <div class="text-3xl font-bold text-gray-900">78</div>
            <div class="text-xs text-gray-500 mt-1">Pinewood Lake</div>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="text-sm text-gray-500 mb-1">Rounds This Year</div>
            <div class="text-3xl font-bold text-gray-900">24</div>
            <div class="text-xs text-gray-500 mt-1">8 in last 30 days</div>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="text-sm text-gray-500 mb-1">Handicap Index</div>
            <div class="text-3xl font-bold text-primary-600">12.5</div>
            <div class="text-xs text-green-600 mt-1">↓ 0.8 from last revision</div>
        </div>
    </div>

    <!-- Performance by Course -->
    <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Performance by Course</h2>
        <div class="space-y-3">
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                <div>
                    <p class="font-medium text-gray-900">Pinewood Lake Golf Club</p>
                    <p class="text-sm text-gray-500">12 rounds</p>
                </div>
                <div class="text-right">
                    <p class="font-semibold text-primary-600">85.2 avg</p>
                    <p class="text-sm text-gray-500">Best: 78</p>
                </div>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                <div>
                    <p class="font-medium text-gray-900">Oak Ridge Country Club</p>
                    <p class="text-sm text-gray-500">8 rounds</p>
                </div>
                <div class="text-right">
                    <p class="font-semibold text-primary-600">89.5 avg</p>
                    <p class="text-sm text-gray-500">Best: 82</p>
                </div>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                <div>
                    <p class="font-medium text-gray-900">Meadowbrook Golf Course</p>
                    <p class="text-sm text-gray-500">4 rounds</p>
                </div>
                <div class="text-right">
                    <p class="font-semibold text-primary-600">91.0 avg</p>
                    <p class="text-sm text-gray-500">Best: 87</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Scoring Trends -->
    <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Scoring Trends</h2>
        <div class="h-64 flex items-center justify-center bg-gray-50 rounded-lg">
            <p class="text-gray-500">Chart placeholder - Score trend over time</p>
        </div>
    </div>

    <!-- Best/Worst Holes -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4">Best Holes</h2>
            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <span class="text-gray-700">Hole 7 (Par 4)</span>
                    <span class="font-semibold text-green-600">-0.3 avg</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-gray-700">Hole 12 (Par 3)</span>
                    <span class="font-semibold text-green-600">-0.2 avg</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-gray-700">Hole 15 (Par 5)</span>
                    <span class="font-semibold text-green-600">-0.1 avg</span>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4">Worst Holes</h2>
            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <span class="text-gray-700">Hole 3 (Par 4)</span>
                    <span class="font-semibold text-red-600">+0.8 avg</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-gray-700">Hole 16 (Par 3)</span>
                    <span class="font-semibold text-red-600">+0.6 avg</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-gray-700">Hole 9 (Par 5)</span>
                    <span class="font-semibold text-red-600">+0.5 avg</span>
                </div>
            </div>
        </div>
    </div>
}

