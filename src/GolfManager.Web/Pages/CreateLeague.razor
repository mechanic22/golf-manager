@page "/leagues/create"
@layout AppLayout
@using GolfManager.Web.Components.Icons
@inject IAuthService AuthService
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ILogger<CreateLeague> Logger

<PageTitle>Create League - Pinzo</PageTitle>

@if (!canCreate)
{
    <div class="text-center py-16">
        <MaterialIcon Path="@MaterialIcons.LockClosed" Size="MaterialComponents.Icons.IconSize.XL" Class="text-gray-400 mb-4" />
        <h2 class="text-2xl font-semibold text-gray-900 mb-2">Access Denied</h2>
        <p class="text-gray-600 mb-4">You must be a Global Admin or League Admin to create leagues.</p>
        <MaterialButton Style="MaterialButtonStyle.Outlined" 
                      Text="Back to Leagues"
                      OnClick="@(() => Navigation.NavigateTo("/leagues"))" />
    </div>
}
else
{
    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex items-center gap-2 text-sm text-gray-600 mb-2">
            <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
            <span>/</span>
            <a href="/leagues" class="hover:text-primary-600">Leagues</a>
            <span>/</span>
            <span class="text-gray-900">Create League</span>
        </div>
        <h1 class="text-3xl font-bold text-gray-900">Create New League</h1>
    </div>

    <!-- Create Form -->
    <div class="max-w-2xl">
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <form @onsubmit="HandleSubmit">
                <!-- League Name -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">League Name *</label>
                    <input type="text" 
                           @bind="leagueName" 
                           required
                           placeholder="e.g., Sunset Golf League"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>

                <!-- Description -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                    <textarea @bind="description" 
                              rows="4"
                              placeholder="Describe your league..."
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"></textarea>
                </div>

                <!-- League Type -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">League Type *</label>
                    <select @bind="leagueType" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
                        <option value="public">Public - Anyone can request to join</option>
                        <option value="private">Private - Invite only</option>
                    </select>
                </div>

                <!-- Scoring Format -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Scoring Format *</label>
                    <select @bind="scoringFormat" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
                        <option value="stroke">Stroke Play</option>
                        <option value="stableford">Stableford</option>
                        <option value="match">Match Play</option>
                    </select>
                </div>

                <!-- Handicap System -->
                <div class="mb-6">
                    <label class="flex items-center gap-2">
                        <input type="checkbox" @bind="useHandicaps" class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" />
                        <span class="text-sm font-medium text-gray-700">Use handicap system</span>
                    </label>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                        <p class="text-sm text-red-700">@errorMessage</p>
                    </div>
                }

                <!-- Actions -->
                <div class="flex gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Filled"
                                  Text="Create League"
                                  Type="submit"
                                  Disabled="@isSubmitting" />
                    <MaterialButton Style="MaterialButtonStyle.Outlined"
                                  Text="Cancel"
                                  OnClick="@(() => Navigation.NavigateTo("/leagues"))" />
                </div>
            </form>
        </div>

        <!-- Info Box -->
        <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
            <div class="flex items-start gap-3">
                <MaterialIcon Path="@GolfIcons.Info" Class="text-blue-600 flex-shrink-0" />
                <div class="text-sm text-blue-900">
                    <p class="font-semibold mb-1">What happens next?</p>
                    <p>After creating your league, you'll be able to add seasons, invite members, and schedule events.</p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool canCreate = false;
    private bool isSubmitting = false;
    private string? errorMessage;

    private string leagueName = string.Empty;
    private string description = string.Empty;
    private string leagueType = "public";
    private string scoringFormat = "stroke";
    private bool useHandicaps = true;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        // Check if user can create leagues (Global Admin or League Admin)
        canCreate = AuthorizationService.IsGlobalAdmin();
        // TODO: Add check for League Admin role when implemented

        await Task.CompletedTask;
    }

    private async Task HandleSubmit()
    {
        if (isSubmitting) return;

        try
        {
            isSubmitting = true;
            errorMessage = null;

            // TODO: Call API to create league
            Logger.LogInformation("Creating league: {Name}", leagueName);

            await Task.Delay(1000); // Simulate API call

            // Navigate to the new league (mock key)
            Navigation.NavigateTo($"/league/sunset-golf-league");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create league: {ex.Message}";
            Logger.LogError(ex, "Error creating league");
        }
        finally
        {
            isSubmitting = false;
        }
    }
}

