@page "/league/{leagueKey}/season/{seasonKey}/settings"
@layout AppLayout
@using GolfManager.Web.Components.Icons
@inject IAuthService AuthService
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ILogger<SeasonSettings> Logger

<PageTitle>Season Settings - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading season settings...</p>
        </div>
    </div>
}
else if (!isAdmin)
{
    <div class="text-center py-16">
        <MaterialIcon Path="@MaterialIcons.LockClosed" Size="MaterialComponents.Icons.IconSize.XL" Class="text-gray-400 mb-4" />
        <h2 class="text-2xl font-semibold text-gray-900 mb-2">Access Denied</h2>
        <p class="text-gray-600 mb-4">You must be a League Admin to manage season settings.</p>
        <MaterialButton Style="MaterialButtonStyle.Outlined"
                      Text="Back to Season"
                      OnClick="@BackToSeason" />
    </div>
}
else
{
    <!-- Breadcrumb -->
    <div class="mb-6">
        <div class="flex items-center gap-2 text-sm text-gray-600">
            <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
            <span>/</span>
            <a href="/leagues" class="hover:text-primary-600">Leagues</a>
            <span>/</span>
            <a href="@($"/league/{LeagueKey}")" class="hover:text-primary-600">@leagueName</a>
            <span>/</span>
            <a href="@($"/league/{LeagueKey}/season/{SeasonKey}")" class="hover:text-primary-600">@seasonName</a>
            <span>/</span>
            <span class="text-gray-900">Settings</span>
        </div>
    </div>

    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Season Settings</h1>
        <p class="text-gray-600 mt-1">Configure @seasonName settings and preferences</p>
    </div>

    <!-- Tab Navigation -->
    <div class="border-b border-gray-200 mb-8">
        <nav class="-mb-px flex space-x-8">
            <a href="@($"/league/{LeagueKey}/season/{SeasonKey}")" 
               class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                Overview
            </a>
            <a href="@($"/league/{LeagueKey}/season/{SeasonKey}/events")" 
               class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                Events
            </a>
            <a href="@($"/league/{LeagueKey}/season/{SeasonKey}/standings")" 
               class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                Standings
            </a>
            <a href="@($"/league/{LeagueKey}/season/{SeasonKey}/players")" 
               class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                Players
            </a>
            <a href="@($"/league/{LeagueKey}/season/{SeasonKey}/settings")" 
               class="border-primary-600 text-primary-600 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                Settings
            </a>
        </nav>
    </div>

    <!-- Settings Form -->
    <div class="max-w-3xl">
        <!-- Basic Information -->
        <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Basic Information</h2>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Season Name *</label>
                    <input type="text" 
                           @bind="seasonName" 
                           required
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Season Key</label>
                    <input type="text" 
                           value="@SeasonKey" 
                           disabled
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-500" />
                    <p class="text-xs text-gray-500 mt-1">The season key cannot be changed after creation</p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Start Date *</label>
                        <input type="date" 
                               @bind="startDate" 
                               required
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">End Date *</label>
                        <input type="date" 
                               @bind="endDate" 
                               required
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    </div>
                </div>
            </div>

            <div class="mt-6 flex justify-end gap-3">
                <MaterialButton Style="MaterialButtonStyle.Outlined"
                              Text="Cancel"
                              OnClick="@BackToSeason" />
                <MaterialButton Style="MaterialButtonStyle.Filled"
                              Text="Save Changes"
                              OnClick="@SaveSettings" />
            </div>
        </div>

        <!-- Scoring Settings -->
        <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Scoring Settings</h2>

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Scoring Format</label>
                    <select @bind="scoringFormat" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
                        <option value="stroke">Stroke Play</option>
                        <option value="stableford">Stableford</option>
                        <option value="match">Match Play</option>
                    </select>
                </div>

                <div class="flex items-center">
                    <input type="checkbox"
                           @bind="useHandicaps"
                           id="useHandicaps"
                           class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" />
                    <label for="useHandicaps" class="ml-2 block text-sm text-gray-700">
                        Use handicaps for scoring
                    </label>
                </div>

                <div class="flex items-center">
                    <input type="checkbox"
                           @bind="dropWorstScores"
                           id="dropWorstScores"
                           class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" />
                    <label for="dropWorstScores" class="ml-2 block text-sm text-gray-700">
                        Drop worst scores from season total
                    </label>
                </div>

                @if (dropWorstScores)
                {
                    <div class="ml-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Number of scores to drop</label>
                        <input type="number"
                               @bind="scoresToDrop"
                               min="1"
                               max="5"
                               class="w-32 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    </div>
                }
            </div>

            <div class="mt-6 flex justify-end gap-3">
                <MaterialButton Style="MaterialButtonStyle.Outlined"
                              Text="Cancel"
                              OnClick="@BackToSeason" />
                <MaterialButton Style="MaterialButtonStyle.Filled"
                              Text="Save Changes"
                              OnClick="@SaveSettings" />
            </div>
        </div>

        <!-- Registration Settings -->
        <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Registration Settings</h2>

            <div class="space-y-4">
                <div class="flex items-center">
                    <input type="checkbox"
                           @bind="allowRegistration"
                           id="allowRegistration"
                           class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" />
                    <label for="allowRegistration" class="ml-2 block text-sm text-gray-700">
                        Allow new player registration
                    </label>
                </div>

                @if (allowRegistration)
                {
                    <div class="ml-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Registration Deadline</label>
                        <input type="date"
                               @bind="registrationDeadline"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    </div>
                }

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Maximum Players</label>
                    <input type="number"
                           @bind="maxPlayers"
                           min="0"
                           placeholder="No limit"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    <p class="text-xs text-gray-500 mt-1">Leave empty for no limit</p>
                </div>
            </div>

            <div class="mt-6 flex justify-end gap-3">
                <MaterialButton Style="MaterialButtonStyle.Outlined"
                              Text="Cancel"
                              OnClick="@BackToSeason" />
                <MaterialButton Style="MaterialButtonStyle.Filled"
                              Text="Save Changes"
                              OnClick="@SaveSettings" />
            </div>
        </div>

        <!-- Danger Zone -->
        <div class="bg-white rounded-lg border border-red-200 p-6">
            <h2 class="text-lg font-semibold text-red-900 mb-4">Danger Zone</h2>

            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-red-50 rounded-lg">
                    <div>
                        <h3 class="text-sm font-semibold text-red-900">Archive Season</h3>
                        <p class="text-sm text-red-700 mt-1">Mark this season as archived. It will be read-only.</p>
                    </div>
                    <MaterialButton Style="MaterialButtonStyle.Outlined"
                                  Text="Archive"
                                  OnClick="@ArchiveSeason" />
                </div>

                <div class="flex items-center justify-between p-4 bg-red-50 rounded-lg">
                    <div>
                        <h3 class="text-sm font-semibold text-red-900">Delete Season</h3>
                        <p class="text-sm text-red-700 mt-1">Permanently delete this season and all its data. This cannot be undone.</p>
                    </div>
                    <MaterialButton Style="MaterialButtonStyle.Outlined"
                                  Text="Delete"
                                  OnClick="@DeleteSeason" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string LeagueKey { get; set; } = string.Empty;
    [Parameter] public string SeasonKey { get; set; } = string.Empty;

    private bool isLoading = true;
    private bool isAdmin = false;
    private string leagueName = "Summer League 2024";
    private string seasonName = "Spring Season";
    private DateTime startDate = DateTime.Today;
    private DateTime endDate = DateTime.Today.AddMonths(3);
    private string scoringFormat = "stroke";
    private bool useHandicaps = true;
    private bool dropWorstScores = false;
    private int scoresToDrop = 1;
    private bool allowRegistration = true;
    private DateTime? registrationDeadline;
    private int? maxPlayers;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        // TODO: Get actual league ID from API
        isAdmin = AuthorizationService.IsGlobalAdmin() || AuthorizationService.IsLeagueAdmin("temp-league-id");

        if (!isAdmin)
        {
            isLoading = false;
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            // TODO: Load actual season settings from API
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading season settings");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void BackToSeason()
    {
        Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}");
    }

    private async Task SaveSettings()
    {
        try
        {
            // TODO: Save settings to API
            Logger.LogInformation("Saving season settings for {SeasonKey}", SeasonKey);
            await Task.CompletedTask;

            // Show success message and navigate back
            BackToSeason();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving season settings");
        }
    }

    private async Task ArchiveSeason()
    {
        // TODO: Implement archive confirmation and API call
        Logger.LogInformation("Archiving season {SeasonKey}", SeasonKey);
        await Task.CompletedTask;
    }

    private async Task DeleteSeason()
    {
        // TODO: Implement delete confirmation and API call
        Logger.LogInformation("Deleting season {SeasonKey}", SeasonKey);
        await Task.CompletedTask;
    }
}

