@page "/admin/users"
@using GolfManager.Shared.DTOs.User
@layout AppLayout
@inject IAuthService AuthService
@inject IAuthorizationService AuthorizationService
@inject IUserService UserService
@inject NavigationManager Navigation
@inject ILogger<AdminUsers> Logger

<PageTitle>Manage Users - Pinzo Admin</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading users...</p>
        </div>
    </div>
}
else if (!isGlobalAdmin)
{
    <div class="text-center py-16">
        <MaterialIcon Path="@MaterialIcons.LockClosed" Size="MaterialComponents.Icons.IconSize.XL" Class="text-gray-400 mb-4" />
        <h2 class="text-2xl font-semibold text-gray-900 mb-2">Access Denied</h2>
        <p class="text-gray-600 mb-4">You must be a Global Admin to manage users.</p>
        <MaterialButton Style="MaterialButtonStyle.Outlined" 
                      Text="Back to Admin Dashboard"
                      OnClick="@(() => Navigation.NavigateTo("/admin"))" />
    </div>
}
else
{
    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex items-center gap-2 text-sm text-gray-600 mb-2">
            <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
            <span>/</span>
            <a href="/admin" class="hover:text-primary-600">Admin</a>
            <span>/</span>
            <span class="text-gray-900">Manage Users</span>
        </div>
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Manage Users</h1>
                <p class="text-gray-600 mt-1">View and manage all platform users</p>
            </div>
            <MaterialButton Style="MaterialButtonStyle.Filled"
                          Text="Invite User"
                          OnClick="@(() => showInviteModal = true)" />
        </div>
    </div>

    <!-- Search and Filters -->
    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="md:col-span-2">
                <input type="text"
                       @bind="searchQuery"
                       @bind:event="oninput"
                       placeholder="Search by name or email..."
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
            </div>
            <div>
                <select @bind="roleFilter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
                    <option value="all">All Roles</option>
                    <option value="admin">Global Admin</option>
                    <option value="league_admin">League Admin (@allUsers.Count(u => u.LeagueAdminCount > 0))</option>
                    <option value="player">Player</option>
                </select>
            </div>
            <div>
                <select @bind="statusFilter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
                    <option value="all">All Status</option>
                    <option value="active">Active (@allUsers.Count(u => u.IsActive))</option>
                    <option value="inactive">Inactive (@allUsers.Count(u => !u.IsActive))</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var user in filteredUsers)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                                <div class="w-10 h-10 bg-primary-600 rounded-full flex items-center justify-center text-white font-semibold flex-shrink-0">
                                    @GetInitials(user.FirstName, user.LastName)
                                </div>
                                <div class="ml-4">
                                    <div class="text-sm font-medium text-gray-900">@user.FirstName @user.LastName</div>
                                    <div class="text-sm text-gray-500">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="px-2 py-1 text-xs font-medium rounded-full @GetRoleBadgeClass(user)">
                                @GetRoleText(user)
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @user.CreatedAt.ToString("MMM dd, yyyy")
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (user.IsActive)
                            {
                                <MaterialChip Text="Active" Color="MaterialChipColor.Success" Size="MaterialChipSize.Small" />
                            }
                            else
                            {
                                <MaterialChip Text="Inactive" Color="MaterialChipColor.Error" Size="MaterialChipSize.Small" />
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <div class="flex justify-end gap-2">
                                <button @onclick="() => OpenEditModal(user)"
                                        class="text-primary-600 hover:text-primary-900 font-medium">
                                    Edit
                                </button>

                                <button @onclick="() => SendPasswordReset(user)"
                                        class="text-primary-600 hover:text-primary-900 font-medium">
                                    Reset Password
                                </button>

                                @if (user.IsActive)
                                {
                                    <button @onclick="() => ToggleUserStatus(user)"
                                            class="text-orange-600 hover:text-orange-900 font-medium">
                                        Deactivate
                                    </button>
                                }
                                else
                                {
                                    <button @onclick="() => ToggleUserStatus(user)"
                                            class="text-green-600 hover:text-green-900 font-medium">
                                        Reactivate
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!filteredUsers.Any())
    {
        <div class="text-center py-16">
            <MaterialIcon Path="@MaterialIcons.Person" Size="MaterialComponents.Icons.IconSize.XL" Class="text-gray-400 mb-4" />
            <h3 class="text-lg font-semibold text-gray-900 mb-2">No users found</h3>
            <p class="text-gray-600">Try adjusting your search or filters</p>
        </div>
    }

    <!-- Pagination -->
    <div class="mt-6 flex items-center justify-between">
        <p class="text-sm text-gray-600">
            Showing @filteredUsers.Count of @allUsers.Count users
        </p>
    </div>
}

<!-- Edit User Modal -->
@if (showEditModal && editingUser != null)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" @onclick="CloseEditModal">
        <div class="bg-white rounded-lg shadow-xl max-w-lg w-full mx-4" @onclick:stopPropagation="true">
            <div class="px-6 py-4 border-b border-gray-200">
                <h2 class="text-xl font-semibold text-gray-900">Edit User</h2>
            </div>

            <div class="px-6 py-4 space-y-4">
                <!-- First Name -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">First Name</label>
                    <input type="text" @bind="editFirstName"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>

                <!-- Last Name -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Last Name</label>
                    <input type="text" @bind="editLastName"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>

                <!-- Email -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                    <input type="email" @bind="editEmail"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>

                <!-- Is Global Admin -->
                <div class="flex items-center gap-2">
                    <input type="checkbox" @bind="editIsGlobalAdmin" id="editIsGlobalAdmin"
                           class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" />
                    <label for="editIsGlobalAdmin" class="text-sm font-medium text-gray-700">Global Admin</label>
                </div>

                <!-- Is Active -->
                <div class="flex items-center gap-2">
                    <input type="checkbox" @bind="editIsActive" id="editIsActive"
                           class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" />
                    <label for="editIsActive" class="text-sm font-medium text-gray-700">Active</label>
                </div>

                @if (!string.IsNullOrEmpty(editError))
                {
                    <div class="p-3 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm">
                        @editError
                    </div>
                }
            </div>

            <div class="px-6 py-4 border-t border-gray-200 flex justify-end gap-2">
                <MaterialButton Style="MaterialButtonStyle.Text"
                              Text="Cancel"
                              OnClick="CloseEditModal"
                              Disabled="@isSaving" />
                <MaterialButton Style="MaterialButtonStyle.Filled"
                              Text="@(isSaving ? "Saving..." : "Save Changes")"
                              OnClick="SaveUser"
                              Disabled="@isSaving" />
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isGlobalAdmin = false;
    private bool showInviteModal = false;
    private bool showEditModal = false;
    private bool isSaving = false;
    private string searchQuery = string.Empty;
    private string roleFilter = "all";
    private string statusFilter = "all";
    private List<UserResponse> allUsers = new();

    // Edit modal state
    private UserResponse? editingUser;
    private string editFirstName = string.Empty;
    private string editLastName = string.Empty;
    private string editEmail = string.Empty;
    private bool editIsGlobalAdmin = false;
    private bool editIsActive = true;
    private string editError = string.Empty;

    private List<UserResponse> filteredUsers => allUsers
        .Where(u => string.IsNullOrEmpty(searchQuery) ||
                    u.FirstName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    u.LastName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    u.Email.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(u => roleFilter == "all" ||
                    (roleFilter == "admin" && u.IsGlobalAdmin) ||
                    (roleFilter == "league_admin" && u.LeagueAdminCount > 0))
        .Where(u => statusFilter == "all" ||
                    (statusFilter == "active" && u.IsActive) ||
                    (statusFilter == "inactive" && !u.IsActive))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        isGlobalAdmin = AuthorizationService.IsGlobalAdmin();

        if (!isGlobalAdmin)
        {
            isLoading = false;
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var response = await UserService.GetAllUsersAsync(includeInactive: true);
            allUsers = (response != null && response.Success && response.Data != null)
                ? response.Data
                : new List<UserResponse>();

            Logger.LogInformation("Loaded {Count} users from API", allUsers.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading users");
            allUsers = new List<UserResponse>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenEditModal(UserResponse user)
    {
        editingUser = user;
        editFirstName = user.FirstName;
        editLastName = user.LastName;
        editEmail = user.Email;
        editIsGlobalAdmin = user.IsGlobalAdmin;
        editIsActive = user.IsActive;
        editError = string.Empty;
        showEditModal = true;
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        editingUser = null;
        editError = string.Empty;
    }

    private async Task SaveUser()
    {
        if (editingUser == null) return;

        isSaving = true;
        editError = string.Empty;

        try
        {
            var request = new UpdateUserRequest
            {
                FirstName = editFirstName,
                LastName = editLastName,
                Email = editEmail,
                IsGlobalAdmin = editIsGlobalAdmin,
                IsActive = editIsActive
            };

            var response = await UserService.UpdateUserAsync(editingUser.Id, request);

            if (response != null && response.Success)
            {
                Logger.LogInformation("User {UserId} updated successfully", editingUser.Id);
                CloseEditModal();
                await LoadData(); // Reload users
            }
            else
            {
                editError = response?.Message ?? "Failed to update user";
                Logger.LogWarning("Failed to update user: {Error}", editError);
            }
        }
        catch (Exception ex)
        {
            editError = "An error occurred while saving";
            Logger.LogError(ex, "Error saving user");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleUserStatus(UserResponse user)
    {
        try
        {
            var request = new UpdateUserRequest
            {
                IsActive = !user.IsActive
            };

            var response = await UserService.UpdateUserAsync(user.Id, request);

            if (response != null && response.Success)
            {
                Logger.LogInformation("User {UserId} status toggled to {Status}", user.Id, !user.IsActive);
                await LoadData(); // Reload users
            }
            else
            {
                Logger.LogWarning("Failed to toggle user status: {Error}", response?.Message);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error toggling user status");
        }
    }

    private async Task SendPasswordReset(UserResponse user)
    {
        try
        {
            var response = await UserService.SendPasswordResetAsync(user.Id);

            if (response != null && response.Success)
            {
                Logger.LogInformation("Password reset sent for user {UserId}", user.Id);
                // TODO: Show success toast/notification
            }
            else
            {
                Logger.LogWarning("Failed to send password reset: {Error}", response?.Message);
                // TODO: Show error toast/notification
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error sending password reset");
        }
    }

    private string GetInitials(string firstName, string lastName)
    {
        var first = !string.IsNullOrEmpty(firstName) ? firstName[0].ToString() : "";
        var last = !string.IsNullOrEmpty(lastName) ? lastName[0].ToString() : "";
        return $"{first}{last}".ToUpper();
    }

    private string GetRoleBadgeClass(UserResponse user)
    {
        if (user.IsGlobalAdmin)
            return "bg-red-100 text-red-800";
        return "bg-gray-100 text-gray-800";
    }

    private string GetRoleText(UserResponse user)
    {
        if (user.IsGlobalAdmin)
            return "Global Admin";
        if (user.LeagueAdminCount > 0)
            return $"League Admin ({user.LeagueAdminCount})";
        return "Player";
    }
}

