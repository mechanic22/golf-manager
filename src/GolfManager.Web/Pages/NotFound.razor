@page "/not-found"
@layout AppLayout
@inject NavigationManager Navigation

<PageTitle>Page Not Found - Pinzo</PageTitle>

<div class="max-w-2xl mx-auto py-16 px-4 text-center">
    <MaterialCard Variant="MaterialCardVariant.Elevated">
        <div class="p-12">
            <div class="text-8xl font-bold text-gray-200 mb-4">404</div>
            <h1 class="text-2xl font-semibold text-gray-900 mb-3">Page Not Found</h1>
            <p class="text-gray-600 mb-8">The page you're looking for doesn't exist or may have been moved.</p>
            <div class="flex flex-col sm:flex-row justify-center gap-3">
                <MaterialButton Style="MaterialButtonStyle.Filled"
                                Text="Go to Dashboard"
                                OnClick="@(() => Navigation.NavigateTo("/dashboard"))" />
                <MaterialButton Style="MaterialButtonStyle.Outlined"
                                Text="Browse Leagues"
                                OnClick="@(() => Navigation.NavigateTo("/leagues"))" />
            </div>
        </div>
    </MaterialCard>
</div>
