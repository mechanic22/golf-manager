@page "/leagues"
@layout AppLayout
@using GolfManager.Shared.DTOs.League
@using GolfManager.Web.Services
@inject IAuthService AuthService
@inject IAuthorizationService AuthorizationService
@inject ILeagueService LeagueService
@inject NavigationManager Navigation
@inject ILogger<Leagues> Logger

<PageTitle>Leagues - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading leagues...</p>
        </div>
    </div>
}
else
{
    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between mb-2">
            <h1 class="text-3xl font-bold text-gray-900">Leagues</h1>
            @if (AuthorizationService.IsGlobalAdmin() || canCreateLeague)
            {
                <MaterialButton Style="MaterialButtonStyle.Filled"
                              Text="Create League"
                              LeadingIcon="@CreateIcon()"
                              OnClick="@(() => Navigation.NavigateTo("/dashboard"))" />
            }
        </div>
        <p class="text-gray-600">Browse and manage your golf leagues</p>
    </div>

    <!-- My Leagues Section -->
    <div class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 mb-4">My Leagues</h2>
        
        @if (myLeagues == null || !myLeagues.Any())
        {
            <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
                <div class="text-gray-400 mb-4">
                    <MaterialIcon Path="@MaterialIcons.Person" Size="MaterialComponents.Icons.IconSize.XL" />
                </div>
                <p class="text-gray-600 mb-4">You're not a member of any leagues yet.</p>
                <MaterialButton Style="MaterialButtonStyle.Outlined"
                              Text="Discover Leagues"
                              OnClick="@(() => scrollToDiscover = true)" />
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var league in myLeagues)
                {
                    <div class="bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow cursor-pointer"
                         @onclick="@(() => Navigation.NavigateTo($"/league/{league.Key}"))">
                        <div class="p-6">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex-1">
                                    <h3 class="text-xl font-semibold text-gray-900 mb-1">@league.Name</h3>
                                    <p class="text-sm text-gray-500 font-mono">@league.Key</p>
                                </div>
                                @if (AuthorizationService.CanManageLeague(league.Id))
                                {
                                    <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs font-medium rounded">Admin</span>
                                }
                            </div>
                            
                            @if (!string.IsNullOrEmpty(league.Description))
                            {
                                <p class="text-gray-600 text-sm mb-4 line-clamp-2">@league.Description</p>
                            }

                            @if (!string.IsNullOrEmpty(league.CustomDomain) && (AuthorizationService.IsGlobalAdmin() || league.IsCurrentUserAdmin))
                            {
                                <div class="mb-3 flex items-center gap-2">
                                    @if (league.CustomDomainVerifiedAt.HasValue)
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-1 bg-green-100 text-green-700 text-xs font-medium rounded"
                                              title="Custom domain verified">
                                            <span>✓</span>
                                            <span class="font-mono text-green-800">@league.CustomDomain</span>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-1 bg-yellow-100 text-yellow-700 text-xs font-medium rounded"
                                              title="Custom domain pending verification">
                                            <span>⏳</span>
                                            <span class="font-mono text-yellow-800">@league.CustomDomain</span>
                                        </span>
                                    }
                                    <div class="group relative inline-block">
                                        <div class="text-gray-400 cursor-help text-xs font-bold">ⓘ</div>
                                        <div class="invisible group-hover:visible absolute left-0 mt-1 w-48 p-2 bg-gray-900 text-white text-xs rounded-md z-10 whitespace-normal">
                                            Add a TXT record: <code class="bg-gray-800 px-1 rounded">_dkgolf.@league.CustomDomain</code> with the verification token to complete verification.
                                        </div>
                                    </div>
                                </div>
                            }
                            
                            <div class="flex items-center gap-4 text-sm text-gray-500">
                                <div class="flex items-center gap-1">
                                    <MaterialIcon Path="@MaterialIcons.Person" Size="MaterialComponents.Icons.IconSize.SM" />
                                    <span>@league.MemberCount members</span>
                                </div>
                                <div class="flex items-center gap-1">
                                    <MaterialIcon Path="@MaterialIcons.Dashboard" Size="MaterialComponents.Icons.IconSize.SM" />
                                    <span>@GetActiveSeasonCount(league) seasons</span>
                                </div>
                            </div>
                        </div>

                        <div class="border-t border-gray-200 px-6 py-3 bg-gray-50 rounded-b-lg">
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-gray-600">View Details</span>
                                <MaterialIcon Path="@MaterialIcons.ArrowForward" Size="MaterialComponents.Icons.IconSize.SM" />
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Discover Leagues Section -->
    <div id="discover-section">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-semibold text-gray-900">Discover Leagues</h2>
            <div class="flex items-center gap-2">
                <input type="text"
                       @bind="searchQuery"
                       @bind:event="oninput"
                       placeholder="Search leagues..."
                       class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 w-64" />
                <MaterialButton Style="MaterialButtonStyle.Outlined"
                              Icon="@SearchIcon()"
                              OnClick="SearchLeagues" />
            </div>
        </div>

        @if (publicLeagues == null || !publicLeagues.Any())
        {
            <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
                <div class="text-gray-400 mb-4">
                    <MaterialIcon Path="@MaterialIcons.Search" Size="MaterialComponents.Icons.IconSize.XL" />
                </div>
                <p class="text-gray-600">No public leagues found.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var league in publicLeagues)
                {
                    <div class="bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
                        <div class="p-6">
                            <h3 class="text-xl font-semibold text-gray-900 mb-1">@league.Name</h3>
                            <p class="text-sm text-gray-500 font-mono mb-3">@league.Key</p>
                            
                            @if (!string.IsNullOrEmpty(league.Description))
                            {
                                <p class="text-gray-600 text-sm mb-4 line-clamp-3">@league.Description</p>
                            }

                            @if (!string.IsNullOrEmpty(league.CustomDomain) && (AuthorizationService.IsGlobalAdmin() || league.IsCurrentUserAdmin))
                            {
                                <div class="mb-3 flex items-center gap-2">
                                    @if (league.CustomDomainVerifiedAt.HasValue)
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-1 bg-green-100 text-green-700 text-xs font-medium rounded"
                                              title="Custom domain verified">
                                            <span>✓</span>
                                            <span class="font-mono text-green-800">@league.CustomDomain</span>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-1 bg-yellow-100 text-yellow-700 text-xs font-medium rounded"
                                              title="Custom domain pending verification">
                                            <span>⏳</span>
                                            <span class="font-mono text-yellow-800">@league.CustomDomain</span>
                                        </span>
                                    }
                                    <div class="group relative inline-block">
                                        <div class="text-gray-400 cursor-help text-xs font-bold">ⓘ</div>
                                        <div class="invisible group-hover:visible absolute left-0 mt-1 w-48 p-2 bg-gray-900 text-white text-xs rounded-md z-10 whitespace-normal">
                                            Add a TXT record: <code class="bg-gray-800 px-1 rounded">_dkgolf.@league.CustomDomain</code> with the verification token to complete verification.
                                        </div>
                                    </div>
                                </div>
                            }
                            
                            <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
                                <div class="flex items-center gap-1">
                                    <MaterialIcon Path="@MaterialIcons.Person" Size="MaterialComponents.Icons.IconSize.SM" />
                                    <span>@league.MemberCount members</span>
                                </div>
                            </div>
                            
                            <MaterialButton Style="MaterialButtonStyle.Outlined"
                                          Text="Request to Join"
                                          OnClick="@(() => RequestToJoin(league))"
                                          Class="w-full" />
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private List<LeagueResponse>? myLeagues;
    private List<LeagueResponse>? publicLeagues;
    private bool isLoading = true;
    private bool canCreateLeague = false;
    private bool scrollToDiscover = false;
    private string searchQuery = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await AuthorizationService.InitializeAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            // Load all leagues from API
            var response = await LeagueService.GetUserLeaguesAsync();
            if (response != null && response.Success && response.Data != null)
            {
                // All returned leagues are user's leagues (API filters by user)
                myLeagues = response.Data;
                publicLeagues = new List<LeagueResponse>(); // TODO: Implement public leagues endpoint
            }

            // Check if user can create leagues
            canCreateLeague = AuthorizationService.IsGlobalAdmin();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading leagues");
        }
        finally
        {
            isLoading = false;
        }
    }

    private int GetActiveSeasonCount(LeagueResponse league)
    {
        // TODO: Get actual season count from API
        return 0;
    }

    private async Task SearchLeagues()
    {
        // TODO: Implement search when API endpoint exists
        Logger.LogInformation("Searching for: {SearchQuery}", searchQuery);
    }

    private async Task RequestToJoin(LeagueResponse league)
    {
        // TODO: Implement join request when API endpoint exists
        Logger.LogInformation("Requesting to join league: {LeagueKey}", league.Key);
    }

    // Icon helpers
    private RenderFragment CreateIcon() => @<MaterialIcon Path="@MaterialIcons.Add" Size="MaterialComponents.Icons.IconSize.SM" />;
    private RenderFragment SearchIcon() => @<MaterialIcon Path="@MaterialIcons.Search" Size="MaterialComponents.Icons.IconSize.SM" />;
}

