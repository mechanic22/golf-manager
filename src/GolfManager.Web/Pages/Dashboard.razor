@page "/dashboard"
@layout AppLayout
@using GolfManager.Web.Services
@using GolfManager.Web.Components.Dashboard
@using GolfManager.Shared.DTOs.User

<PageTitle>Dashboard - Pinzo</PageTitle>

<!-- Header -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">
        @GetWelcomeHeadline()
    </h1>
    <p class="text-gray-600">@GetWelcomeSubhead()</p>
</div>

@if (HasFeaturedAnnouncement())
{
    <div class="mb-8 rounded-xl border border-amber-200 bg-amber-50 px-5 py-4">
        <div class="flex items-start gap-3">
            <MaterialIcon Icon="MaterialIcons.Campaign" Class="text-amber-700 mt-1" />
            <div>
                <h2 class="text-lg font-semibold text-amber-900">@GetAnnouncementTitle()</h2>
                @if (!string.IsNullOrWhiteSpace(featuredLeague?.AnnouncementBody))
                {
                    <p class="mt-1 text-sm text-amber-900/90 whitespace-pre-line">@featuredLeague!.AnnouncementBody</p>
                }
            </div>
        </div>
    </div>
}

<!-- Content -->
@if (isLoading)
{
    <div class="flex flex-col items-center justify-center py-16">
        <MaterialProgressIndicator Variant="MaterialProgressVariant.Circular" />
        <p class="text-gray-600 mt-4">Loading...</p>
    </div>
}
else
{
    <!-- Upcoming Events -->
    <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="text-2xl font-bold text-gray-900">Upcoming Events</h2>
                <p class="text-gray-600 text-sm">Your next golf outings</p>
            </div>
            <a href="/events" class="text-primary-600 hover:text-primary-700 text-sm font-medium">View All →</a>
        </div>

        @if (isLoadingEvents)
        {
            <div class="flex justify-center py-8">
                <MaterialProgressIndicator Variant="MaterialProgressVariant.Circular" />
            </div>
        }
        else if (myEvents == null || !myEvents.Any())
        {
            <MaterialCard Variant="MaterialCardVariant.Outlined">
                <div class="md-card__content text-center py-12">
                    <MaterialIcon Icon="MaterialIcons.EventBusy" Class="text-gray-400 text-4xl mb-3" />
                    <p class="text-gray-600">@GetUpcomingEventsEmptyMessage()</p>
                </div>
            </MaterialCard>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var evt in myEvents)
                {
                    <MaterialCard Variant="MaterialCardVariant.Outlined" Class="hover:shadow-md transition-shadow">
                        <div class="md-card__content">
                            <div class="flex items-start justify-between mb-3">
                                <h3 class="text-lg font-semibold text-gray-900">@evt.Name</h3>
                                <MaterialChip Label="@evt.Status.ToString()"
                                             Color="@GetStatusColor(evt.Status)"
                                             Size="MaterialChipSize.Small" />
                            </div>

                            <div class="space-y-2 text-sm text-gray-600 mb-4">
                                <div class="flex items-center gap-2">
                                    <MaterialIcon Icon="MaterialIcons.CalendarToday" Class="text-base" />
                                    <span>@evt.EventDate.ToString("MMM d, yyyy")</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <MaterialIcon Icon="MaterialIcons.GolfCourse" Class="text-base" />
                                    <span>@evt.Format</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <MaterialIcon Icon="MaterialIcons.Groups" Class="text-base" />
                                    <span>@evt.RegisteredTeamsCount / @(evt.MaxTeams?.ToString() ?? "∞") teams</span>
                                </div>
                            </div>

                            <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/event/{evt.Key}"))">
                                View Event
                            </MaterialButton>
                        </div>
                    </MaterialCard>
                }
            </div>
        }
    </div>

    <div class="mb-4">
        <h2 class="text-2xl font-bold text-gray-900">Your Leagues</h2>
        <p class="text-gray-600 text-sm">Leagues you belong to</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var league in leagues ?? [])
        {
            <MaterialCard Variant="MaterialCardVariant.Filled" Class="hover:shadow-md transition-shadow">
                <div class="md-card__content">
                    <div class="flex items-start gap-4 mb-4">
                        @if (!string.IsNullOrEmpty(league.LogoUrl))
                        {
                            <img src="@league.LogoUrl" alt="@league.Name" class="w-12 h-12 rounded-lg object-cover" />
                        }
                        else
                        {
                            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
                                <MaterialIcon Icon="MaterialIcons.GolfCourse" Class="text-primary-700" />
                            </div>
                        }
                        <div class="flex-1 min-w-0">
                            <h3 class="text-lg font-semibold text-gray-900 mb-1 truncate">@league.Name</h3>
                            <p class="text-xs text-gray-500 font-mono">@league.Key</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(league.Description))
                    {
                        <p class="text-gray-600 text-sm mb-4 line-clamp-2">@league.Description</p>
                    }

                    <div class="grid grid-cols-3 gap-4 py-4 border-t border-b border-gray-200 mb-4">
                        <div class="text-center">
                            <div class="text-2xl font-bold text-gray-900">@league.MemberCount</div>
                            <div class="text-xs text-gray-500 uppercase tracking-wide">Members</div>
                        </div>
                        <div class="text-center">
                            <div class="text-2xl font-bold text-gray-900">@league.PlayerCount</div>
                            <div class="text-xs text-gray-500 uppercase tracking-wide">Players</div>
                        </div>
                        <div class="text-center">
                            <div class="text-2xl font-bold text-gray-900">@league.SeasonCount</div>
                            <div class="text-xs text-gray-500 uppercase tracking-wide">Seasons</div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between gap-3">
                        <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="() => NavigateToLeague(league.Key)">
                            View League
                        </MaterialButton>
                        @if (league.IsCurrentUserAdmin)
                        {
                            <MaterialChip Text="Admin" Color="MaterialChipColor.Primary" Size="MaterialChipSize.Small" />
                        }
                    </div>
                </div>
            </MaterialCard>
        }
    </div>

    <!-- Handicap Widget -->
    @if (currentUser?.IsGolfer == true && !string.IsNullOrEmpty(currentUser.GolferId))
    {
        <div class="mt-12 mb-6">
            <HandicapWidget CurrentUser="@currentUser" />
        </div>
    }

}

<CreateLeagueDialog IsOpen="showCreateModal"
                     IsOpenChanged="@((value) => showCreateModal = value)"
                     OnLeagueCreated="@HandleLeagueCreated" />

<CreateEventDialog IsOpen="showCreateEventModal"
                   IsOpenChanged="@((value) => showCreateEventModal = value)"
                   OnEventCreated="@HandleEventCreated" />
