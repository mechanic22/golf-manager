@page "/register"

<PageTitle>Register - Pinzo</PageTitle>

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background-color: #f9fafb; padding: 2rem;">
    <div class="card" style="max-width: 28rem; width: 100%; padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <img src="/img/pinzo-green.png" alt="Pinzo Golf" style="height: 2.5rem; margin-bottom: 1rem;" />
            <h1 style="font-size: 1.875rem; font-weight: 700; color: #111827; margin-bottom: 0.5rem;">Create Your Account</h1>
            <p style="color: #6b7280; font-size: 0.875rem;">Join Pinzo and start managing your golf league today</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
            </div>
        }

        <EditForm Model="@registerRequest" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">Email Address</label>
                <InputText id="email" @bind-Value="registerRequest.Email" class="form-control" placeholder="you@example.com" />
                <ValidationMessage For="@(() => registerRequest.Email)" />
            </div>

            <div class="form-group">
                <label for="firstName">First Name</label>
                <InputText id="firstName" @bind-Value="registerRequest.FirstName" class="form-control" placeholder="John" />
                <ValidationMessage For="@(() => registerRequest.FirstName)" />
            </div>

            <div class="form-group">
                <label for="lastName">Last Name</label>
                <InputText id="lastName" @bind-Value="registerRequest.LastName" class="form-control" placeholder="Doe" />
                <ValidationMessage For="@(() => registerRequest.LastName)" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" type="password" @bind-Value="registerRequest.Password" class="form-control" placeholder="••••••••" />
                <ValidationMessage For="@(() => registerRequest.Password)" />
                <small style="display: block; margin-top: 0.25rem; font-size: 0.8125rem; color: #6b7280;">Minimum 8 characters</small>
            </div>

            <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Creating Account...</span>
                }
                else
                {
                    <span>Create Account</span>
                }
            </button>
        </EditForm>

        <div style="margin-top: 1.5rem; text-align: center; padding-top: 1.5rem; border-top: 1px solid #e5e7eb;">
            <p style="color: #6b7280; font-size: 0.875rem;">
                Already have an account? <a href="/login" style="color: #2563eb; font-weight: 500;">Sign in</a>
            </p>
        </div>
    </div>
</div>

