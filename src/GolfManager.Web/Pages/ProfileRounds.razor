@page "/profile/rounds"
@layout AppLayout
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<ProfileRounds> Logger

<PageTitle>My Rounds - Pinzo</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    <div class="text-center py-16">
        <p class="text-gray-600">Please log in to view your rounds.</p>
    </div>
}
else
{
    <!-- Breadcrumb -->
    <div class="mb-6 text-sm text-gray-600">
        <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
        <span class="mx-2">/</span>
        <a href="/profile" class="hover:text-primary-600">Profile</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Rounds</span>
    </div>

    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between mb-2">
            <h1 class="text-3xl font-bold text-gray-900">My Rounds</h1>
            <MaterialButton Style="MaterialButtonStyle.Outlined" 
                          Text="Export to CSV"
                          LeadingIcon="@DownloadIcon()" />
        </div>
        <p class="text-gray-600">Complete history of all your rounds</p>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Date Range</label>
                <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
                    <option>All Time</option>
                    <option>Last 30 Days</option>
                    <option>Last 90 Days</option>
                    <option>This Year</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">League</label>
                <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
                    <option>All Leagues</option>
                    <option>Summer League 2024</option>
                    <option>Fall League 2023</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Course</label>
                <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
                    <option>All Courses</option>
                    <option>Pinewood Lake</option>
                    <option>Oak Ridge</option>
                </select>
            </div>
            <div class="flex items-end">
                <MaterialButton Style="MaterialButtonStyle.Filled" 
                              Text="Apply Filters"
                              Class="w-full" />
            </div>
        </div>
    </div>

    <!-- Rounds List -->
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Course</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">League/Event</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Score</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Differential</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var round in mockRounds)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@round.Date.ToString("MMM dd, yyyy")</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@round.Course</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@round.League</td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="@GetScoreClass(round.Score)">@round.Score</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@round.Differential.ToString("F1")</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <button class="text-primary-600 hover:text-primary-800">View Details</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="mt-6 flex items-center justify-between">
        <p class="text-sm text-gray-600">Showing 1-10 of 24 rounds</p>
        <div class="flex gap-2">
            <MaterialButton Style="MaterialButtonStyle.Outlined" 
                          Text="Previous"
                          Disabled="true" />
            <MaterialButton Style="MaterialButtonStyle.Outlined" 
                          Text="Next" />
        </div>
    </div>
}

@code {
    private List<MockRound> mockRounds = new()
    {
        new MockRound { Date = DateTime.Now.AddDays(-2), Course = "Pinewood Lake", League = "Summer League 2024", Score = 85, Differential = 12.3m },
        new MockRound { Date = DateTime.Now.AddDays(-9), Course = "Oak Ridge", League = "Summer League 2024", Score = 89, Differential = 13.1m },
        new MockRound { Date = DateTime.Now.AddDays(-16), Course = "Pinewood Lake", League = "Summer League 2024", Score = 82, Differential = 11.5m },
        new MockRound { Date = DateTime.Now.AddDays(-23), Course = "Meadowbrook", League = "One-Time Event", Score = 91, Differential = 14.2m },
        new MockRound { Date = DateTime.Now.AddDays(-30), Course = "Pinewood Lake", League = "Summer League 2024", Score = 87, Differential = 12.8m },
        new MockRound { Date = DateTime.Now.AddDays(-37), Course = "Oak Ridge", League = "Summer League 2024", Score = 88, Differential = 13.0m },
        new MockRound { Date = DateTime.Now.AddDays(-44), Course = "Pinewood Lake", League = "Summer League 2024", Score = 84, Differential = 12.1m },
        new MockRound { Date = DateTime.Now.AddDays(-51), Course = "Meadowbrook", League = "One-Time Event", Score = 93, Differential = 14.8m },
        new MockRound { Date = DateTime.Now.AddDays(-58), Course = "Pinewood Lake", League = "Summer League 2024", Score = 86, Differential = 12.6m },
        new MockRound { Date = DateTime.Now.AddDays(-65), Course = "Oak Ridge", League = "Summer League 2024", Score = 90, Differential = 13.5m },
    };

    private string GetScoreClass(int score)
    {
        if (score < 80) return "text-sm font-semibold text-green-600";
        if (score < 90) return "text-sm font-semibold text-primary-600";
        return "text-sm font-semibold text-gray-900";
    }

    private RenderFragment DownloadIcon() => @<MaterialIcon Path="@MaterialIcons.Download" Size="MaterialComponents.Icons.IconSize.SM" />;

    private class MockRound
    {
        public DateTime Date { get; set; }
        public string Course { get; set; } = string.Empty;
        public string League { get; set; } = string.Empty;
        public int Score { get; set; }
        public decimal Differential { get; set; }
    }
}

