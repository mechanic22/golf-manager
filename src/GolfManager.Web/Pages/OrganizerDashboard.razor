@page "/event/{EventKey}/manage"
@layout AppLayout
@inject IOneTimeEventService EventService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ILogger<OrganizerDashboard> Logger

<PageTitle>Manage @(eventData?.Name ?? "Event") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex flex-col items-center justify-center py-16">
        <MaterialProgressIndicator Variant="MaterialProgressVariant.Circular" />
        <p class="text-gray-600 mt-4">Loading event...</p>
    </div>
}
else if (eventData == null || !isOrganizer)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Lock" Class="text-gray-400 text-6xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Access Denied</h2>
                <p class="text-gray-600 mb-8">You don't have permission to manage this event.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo("/dashboard"))">
                    Go to Dashboard
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <!-- Header -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8 py-6 mb-8">
        <div class="flex items-start justify-between flex-wrap gap-4">
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                    <h1 class="text-3xl font-bold text-gray-900">@eventData.Name</h1>
                    <MaterialChip Label="@eventData.Status.ToString()"
                                 Color="@GetStatusColor(eventData.Status)"
                                 Size="MaterialChipSize.Small" />
                </div>
                <div class="flex flex-wrap gap-4 text-sm text-gray-600">
                    <div class="flex items-center gap-1">
                        <MaterialIcon Icon="MaterialIcons.CalendarToday" Class="text-base" />
                        <span>@eventData.EventDate.ToString("MMMM d, yyyy")</span>
                    </div>
                    <div class="flex items-center gap-1">
                        <MaterialIcon Icon="MaterialIcons.Groups" Class="text-base" />
                        <span>@teams.Count teams registered</span>
                    </div>
                </div>
            </div>
            <div class="flex gap-3">
                <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => Navigation.NavigateTo($"/event/{EventKey}"))">
                    <MaterialIcon Icon="MaterialIcons.Visibility" Class="mr-1" />
                    View Public Page
                </MaterialButton>
                @if (eventData.Status == EventStatus.Draft || eventData.Status == EventStatus.Published)
                {
                    <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="ShowEditEventModal">
                        <MaterialIcon Icon="MaterialIcons.Edit" Class="mr-1" />
                        Edit Event
                    </MaterialButton>
                }
                @if (eventData.Status == EventStatus.Draft)
                {
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="HandlePublishEvent">
                        <MaterialIcon Icon="MaterialIcons.Publish" Class="mr-1" />
                        Publish Event
                    </MaterialButton>
                }
                @if (eventData.Status == EventStatus.Published)
                {
                    <MaterialButton Style="MaterialButtonStyle.Outlined" Color="MaterialButtonColor.Error" OnClick="HandleCancelEvent">
                        <MaterialIcon Icon="MaterialIcons.Cancel" Class="mr-1" />
                        Cancel Event
                    </MaterialButton>
                }
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center">
                <div class="text-3xl font-bold text-gray-900">@teams.Count</div>
                <div class="text-sm text-gray-600 mt-1">Total Teams</div>
            </div>
        </MaterialCard>
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center">
                <div class="text-3xl font-bold text-gray-900">@teams.Count(t => t.IsCheckedIn)</div>
                <div class="text-sm text-gray-600 mt-1">Checked In</div>
            </div>
        </MaterialCard>
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center">
                <div class="text-3xl font-bold text-gray-900">@teams.Sum(t => t.Players.Count)</div>
                <div class="text-sm text-gray-600 mt-1">Total Players</div>
            </div>
        </MaterialCard>
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center">
                <div class="text-3xl font-bold text-gray-900">@(eventData.MaxTeams?.ToString() ?? "∞")</div>
                <div class="text-sm text-gray-600 mt-1">Max Teams</div>
            </div>
        </MaterialCard>
    </div>

    <!-- Teams Management -->
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-semibold text-gray-900">Registered Teams</h2>
                <MaterialButton Style="MaterialButtonStyle.Text" OnClick="LoadEvent">
                    <MaterialIcon Icon="MaterialIcons.Refresh" Class="mr-1" />
                    Refresh
                </MaterialButton>
            </div>

            @if (!teams.Any())
            {
                <div class="text-center py-12">
                    <MaterialIcon Icon="MaterialIcons.Groups" Class="text-gray-400 text-5xl mb-3" />
                    <p class="text-gray-600">No teams registered yet</p>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var team in teams.OrderBy(t => t.TeamNumber))
                    {
                        <div class="border border-gray-200 rounded-lg p-4">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex-1">
                                    <div class="flex items-center gap-3 mb-2">
                                        <h3 class="text-lg font-semibold text-gray-900">Team #@team.TeamNumber - @team.TeamName</h3>
                                        @if (team.IsCheckedIn)
                                        {
                                            <MaterialChip Label="Checked In" Color="MaterialChipColor.Success" Size="MaterialChipSize.Small" />
                                        }
                                    </div>
                                    <div class="text-sm text-gray-600">
                                        <div>Captain: @team.CaptainName</div>
                                        <div>Email: @team.CaptainEmail</div>
                                        @if (!string.IsNullOrEmpty(team.CaptainPhone))
                                        {
                                            <div>Phone: @team.CaptainPhone</div>
                                        }
                                        <div class="mt-1">Registered: @team.RegisteredAt.ToString("MMM d, yyyy h:mm tt")</div>
                                    </div>
                                </div>
                                <div class="flex gap-2">
                                    @if (!team.IsCheckedIn)
                                    {
                                        <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => HandleCheckInTeam(team.Id))">
                                            Check In
                                        </MaterialButton>
                                    }
                                    <MaterialButton Style="MaterialButtonStyle.Text" Color="MaterialButtonColor.Error" OnClick="@(() => HandleRemoveTeam(team.Id, team.TeamName))">
                                        Remove
                                    </MaterialButton>
                                </div>
                            </div>

                            <!-- Players List -->
                            <div class="mt-3 pt-3 border-t border-gray-200">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="text-sm font-medium text-gray-700">Players (@team.Players.Count / @eventData.TeamSize)</div>
                                    @if (team.Players.Count < eventData.TeamSize)
                                    {
                                        <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => ShowAddPlayerModal(team))">
                                            <MaterialIcon Icon="MaterialIcons.PersonAdd" Class="mr-1" />
                                            Add Player
                                        </MaterialButton>
                                    }
                                </div>
                                <div class="space-y-2">
                                    @foreach (var player in team.Players.OrderBy(p => !p.IsCaptain))
                                    {
                                        <div class="flex items-center justify-between text-sm bg-gray-50 rounded p-2">
                                            <div class="flex items-center gap-2">
                                                @if (player.IsCaptain)
                                                {
                                                    <MaterialIcon Icon="MaterialIcons.Star" Class="text-base text-yellow-500" />
                                                }
                                                else
                                                {
                                                    <MaterialIcon Icon="MaterialIcons.Person" Class="text-base text-gray-400" />
                                                }
                                                <div>
                                                    <div class="font-medium text-gray-900">@player.PlayerName</div>
                                                    @if (!string.IsNullOrEmpty(player.Email))
                                                    {
                                                        <div class="text-xs text-gray-500">@player.Email</div>
                                                    }
                                                </div>
                                            </div>
                                            @if (!player.IsCaptain)
                                            {
                                                <MaterialButton Style="MaterialButtonStyle.Text" Color="MaterialButtonColor.Error" OnClick="@(() => HandleRemovePlayer(player.Id, player.PlayerName))">
                                                    <MaterialIcon Icon="MaterialIcons.Delete" />
                                                </MaterialButton>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </MaterialCard>
}

<MaterialDialog @bind-IsOpen="showAddPlayerModal" Title="Add Player" MaxWidth="MaterialDialogMaxWidth.Small">
    <ChildContent>
        @if (!string.IsNullOrEmpty(addPlayerErrorMessage))
        {
            <div class="alert alert-danger mb-4">
                @addPlayerErrorMessage
            </div>
        }

        <EditForm Model="@addPlayerRequest" OnValidSubmit="HandleAddPlayer">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <MaterialInput @bind-Value="addPlayerRequest.PlayerName"
                                  Label="Player Name"
                                  Placeholder="John Doe"
                                  Variant="MaterialInputVariant.Outlined"
                                  Required="true" />
                    <ValidationMessage For="@(() => addPlayerRequest.PlayerName)" />
                </div>

                <div>
                    <MaterialInput @bind-Value="addPlayerRequest.Email"
                                  Label="Email (Optional)"
                                  Placeholder="john@example.com"
                                  Type="email"
                                  Variant="MaterialInputVariant.Outlined" />
                    <ValidationMessage For="@(() => addPlayerRequest.Email)" />
                </div>

                <div>
                    <MaterialInput @bind-Value="addPlayerRequest.Handicap"
                                  Label="Handicap (Optional)"
                                  Placeholder="10.5"
                                  Type="number"
                                  Variant="MaterialInputVariant.Outlined" />
                    <ValidationMessage For="@(() => addPlayerRequest.Handicap)" />
                </div>

                <div class="mt-4 flex justify-end gap-3">
                    <MaterialButton Type="button" Style="MaterialButtonStyle.Text" OnClick="HideAddPlayerModal" Disabled="isAddingPlayer">
                        Cancel
                    </MaterialButton>
                    <MaterialButton Type="submit" Style="MaterialButtonStyle.Filled" Disabled="isAddingPlayer">
                        @if (isAddingPlayer)
                        {
                            <span>Adding...</span>
                        }
                        else
                        {
                            <span>Add Player</span>
                        }
                    </MaterialButton>
                </div>
            </div>
        </EditForm>
    </ChildContent>
</MaterialDialog>

<MaterialDialog @bind-IsOpen="showEditEventModal" Title="Edit Event" MaxWidth="MaterialDialogMaxWidth.Medium">
    <ChildContent>
        @if (!string.IsNullOrEmpty(editEventErrorMessage))
        {
            <div class="alert alert-danger mb-4">
                @editEventErrorMessage
            </div>
        }

        <EditForm Model="@updateEventRequest" OnValidSubmit="HandleUpdateEvent">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <MaterialInput @bind-Value="updateEventRequest.Name"
                                  Label="Event Name"
                                  Placeholder="Summer Golf Tournament"
                                  Variant="MaterialInputVariant.Outlined" />
                    <ValidationMessage For="@(() => updateEventRequest.Name)" />
                </div>

                <div>
                    <MaterialInput @bind-Value="updateEventRequest.Description"
                                  Label="Description"
                                  Placeholder="Event description..."
                                  Variant="MaterialInputVariant.Outlined"
                                  Multiline="true"
                                  Rows="3" />
                    <ValidationMessage For="@(() => updateEventRequest.Description)" />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <MaterialInput @bind-Value="updateEventRequest.EventDate"
                                      Label="Event Date"
                                      Type="date"
                                      Variant="MaterialInputVariant.Outlined" />
                        <ValidationMessage For="@(() => updateEventRequest.EventDate)" />
                    </div>

                    <div>
                        <MaterialInput @bind-Value="updateEventRequest.TeamSize"
                                      Label="Team Size"
                                      Type="number"
                                      Variant="MaterialInputVariant.Outlined" />
                        <ValidationMessage For="@(() => updateEventRequest.TeamSize)" />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <MaterialInput @bind-Value="updateEventRequest.MaxTeams"
                                      Label="Max Teams (Optional)"
                                      Type="number"
                                      Variant="MaterialInputVariant.Outlined" />
                        <ValidationMessage For="@(() => updateEventRequest.MaxTeams)" />
                    </div>

                    <div>
                        <MaterialInput @bind-Value="updateEventRequest.TotalRounds"
                                      Label="Total Rounds"
                                      Type="number"
                                      Variant="MaterialInputVariant.Outlined" />
                        <ValidationMessage For="@(() => updateEventRequest.TotalRounds)" />
                    </div>
                </div>

                <div>
                    <MaterialInput @bind-Value="updateEventRequest.OrganizationName"
                                  Label="Organization Name (Optional)"
                                  Placeholder="Golf Club Name"
                                  Variant="MaterialInputVariant.Outlined" />
                    <ValidationMessage For="@(() => updateEventRequest.OrganizationName)" />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <MaterialInput @bind-Value="updateEventRequest.OrganizerEmail"
                                      Label="Contact Email"
                                      Type="email"
                                      Variant="MaterialInputVariant.Outlined" />
                        <ValidationMessage For="@(() => updateEventRequest.OrganizerEmail)" />
                    </div>

                    <div>
                        <MaterialInput @bind-Value="updateEventRequest.OrganizerPhone"
                                      Label="Contact Phone"
                                      Type="tel"
                                      Variant="MaterialInputVariant.Outlined" />
                        <ValidationMessage For="@(() => updateEventRequest.OrganizerPhone)" />
                    </div>
                </div>

                <div>
                    <MaterialInput @bind-Value="updateEventRequest.RegistrationDeadline"
                                  Label="Registration Deadline (Optional)"
                                  Type="date"
                                  Variant="MaterialInputVariant.Outlined" />
                    <ValidationMessage For="@(() => updateEventRequest.RegistrationDeadline)" />
                </div>

                <div class="mt-4 flex justify-end gap-3">
                    <MaterialButton Type="button" Style="MaterialButtonStyle.Text" OnClick="HideEditEventModal" Disabled="isUpdatingEvent">
                        Cancel
                    </MaterialButton>
                    <MaterialButton Type="submit" Style="MaterialButtonStyle.Filled" Disabled="isUpdatingEvent">
                        @if (isUpdatingEvent)
                        {
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>Save Changes</span>
                        }
                    </MaterialButton>
                </div>
            </div>
        </EditForm>
    </ChildContent>
</MaterialDialog>

@code {
    [Parameter]
    public string EventKey { get; set; } = string.Empty;

    private OneTimeEventResponse? eventData;
    private List<OneTimeEventTeamResponse> teams = new();
    private bool isLoading = true;
    private bool isOrganizer = false;

    private bool showAddPlayerModal = false;
    private bool isAddingPlayer = false;
    private AddPlayerRequest addPlayerRequest = new();
    private string? addPlayerErrorMessage;
    private string? selectedTeamId;

    private bool showEditEventModal = false;
    private bool isUpdatingEvent = false;
    private UpdateOneTimeEventRequest updateEventRequest = new();
    private string? editEventErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadEvent();
    }

    private async Task LoadEvent()
    {
        isLoading = true;
        try
        {
            var response = await EventService.GetEventByKeyAsync(EventKey);
            if (response?.Success == true && response.Data != null)
            {
                eventData = response.Data;
                isOrganizer = AuthService.IsAuthenticated && AuthService.UserId == eventData.OrganizerId;

                if (isOrganizer)
                {
                    // Load teams
                    var teamsResponse = await EventService.GetEventTeamsAsync(eventData.Id);
                    if (teamsResponse?.Success == true && teamsResponse.Data != null)
                    {
                        teams = teamsResponse.Data;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading event");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowEditEventModal()
    {
        if (eventData == null) return;

        // Populate the update request with current values
        updateEventRequest = new UpdateOneTimeEventRequest
        {
            Name = eventData.Name,
            Description = eventData.Description,
            EventDate = eventData.EventDate,
            OrganizationName = eventData.OrganizationName,
            OrganizerEmail = eventData.OrganizerEmail,
            OrganizerPhone = eventData.OrganizerPhone,
            Format = eventData.Format,
            TeamSize = eventData.TeamSize,
            UseHandicaps = eventData.UseHandicaps,
            MaxTeams = eventData.MaxTeams,
            TotalRounds = eventData.TotalRounds,
            AccessType = eventData.AccessType,
            RegistrationDeadline = eventData.RegistrationDeadline
        };
        editEventErrorMessage = null;
        showEditEventModal = true;
    }

    private void HideEditEventModal()
    {
        showEditEventModal = false;
    }

    private async Task HandleUpdateEvent()
    {
        if (eventData == null) return;

        isUpdatingEvent = true;
        editEventErrorMessage = null;

        try
        {
            var response = await EventService.UpdateEventAsync(eventData.Id, updateEventRequest);

            if (response?.Success == true)
            {
                showEditEventModal = false;
                await LoadEvent(); // Reload to show updated data
            }
            else
            {
                editEventErrorMessage = response?.Message ?? "Failed to update event. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating event");
            editEventErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isUpdatingEvent = false;
        }
    }

    private async Task HandlePublishEvent()
    {
        if (eventData == null) return;

        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to publish this event? Once published, teams can register."))
            return;

        try
        {
            var response = await EventService.PublishEventAsync(eventData.Id);
            if (response?.Success == true)
            {
                await LoadEvent(); // Reload to update status
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error publishing event");
        }
    }

    private async Task HandleCancelEvent()
    {
        if (eventData == null) return;

        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to cancel this event? This action cannot be undone and all registered teams will be notified."))
            return;

        try
        {
            var response = await EventService.CancelEventAsync(eventData.Id);
            if (response?.Success == true)
            {
                await LoadEvent(); // Reload to update status
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error canceling event");
        }
    }

    private async Task HandleCheckInTeam(string teamId)
    {
        try
        {
            var response = await EventService.CheckInTeamAsync(teamId);
            if (response?.Success == true)
            {
                await LoadEvent(); // Reload to update check-in status
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error checking in team");
        }
    }

    private async Task HandleRemoveTeam(string teamId, string teamName)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to remove {teamName}?"))
            return;

        try
        {
            var response = await EventService.RemoveTeamAsync(teamId);
            if (response?.Success == true)
            {
                await LoadEvent(); // Reload to update teams list
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing team");
        }
    }

    private void ShowAddPlayerModal(OneTimeEventTeamResponse team)
    {
        selectedTeamId = team.Id;
        addPlayerRequest = new AddPlayerRequest();
        addPlayerErrorMessage = null;
        showAddPlayerModal = true;
    }

    private void HideAddPlayerModal()
    {
        showAddPlayerModal = false;
        selectedTeamId = null;
    }

    private async Task HandleAddPlayer()
    {
        if (string.IsNullOrEmpty(selectedTeamId)) return;

        isAddingPlayer = true;
        addPlayerErrorMessage = null;

        try
        {
            var response = await EventService.AddPlayerAsync(selectedTeamId, addPlayerRequest);

            if (response?.Success == true)
            {
                showAddPlayerModal = false;
                await LoadEvent(); // Reload to update teams
            }
            else
            {
                addPlayerErrorMessage = response?.Message ?? "Failed to add player. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding player");
            addPlayerErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isAddingPlayer = false;
        }
    }

    private async Task HandleRemovePlayer(string playerId, string playerName)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to remove {playerName}?"))
            return;

        try
        {
            var response = await EventService.RemovePlayerAsync(playerId);
            if (response?.Success == true)
            {
                await LoadEvent(); // Reload to update teams
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing player");
        }
    }

    private MaterialChipColor GetStatusColor(EventStatus status)
    {
        return status switch
        {
            EventStatus.Draft => MaterialChipColor.Default,
            EventStatus.Published => MaterialChipColor.Primary,
            EventStatus.InProgress => MaterialChipColor.Info,
            EventStatus.Completed => MaterialChipColor.Success,
            EventStatus.Cancelled => MaterialChipColor.Error,
            _ => MaterialChipColor.Default
        };
    }
}
