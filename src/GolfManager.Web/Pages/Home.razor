@page "/"
@inject NavigationManager Navigation
@inject IAuthService AuthService

<PageTitle>GolfManager - Manage Your Golf League</PageTitle>

<div class="landing-page">
    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="hero-title">⛳ GolfManager</h1>
            <p class="hero-subtitle">The modern way to manage your golf league</p>
            <p class="hero-description">
                Track scores, manage seasons, calculate handicaps, and build your golf community.
            </p>
            <div class="hero-actions">
                @if (!AuthService.IsAuthenticated)
                {
                    <button class="btn btn-primary btn-lg" @onclick="NavigateToRegister">
                        Get Started Free
                    </button>
                    <button class="btn btn-secondary btn-lg" @onclick="NavigateToLogin">
                        Sign In
                    </button>
                }
                else
                {
                    <button class="btn btn-primary btn-lg" @onclick="NavigateToDashboard">
                        Go to Dashboard
                    </button>
                }
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features">
        <h2 class="section-title">Everything You Need</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🏆</div>
                <h3>League Management</h3>
                <p>Create and manage multiple leagues with ease. Invite players and track membership.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h3>Score Tracking</h3>
                <p>Record hole-by-hole scores, track statistics, and view detailed round history.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📅</div>
                <h3>Season & Events</h3>
                <p>Organize seasons and schedule events. Keep your league organized year-round.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🎯</div>
                <h3>Handicap System</h3>
                <p>Automatic handicap calculations to keep competition fair and fun.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📱</div>
                <h3>Mobile Friendly</h3>
                <p>Access your league from any device. Perfect for on-course scoring.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔒</div>
                <h3>Secure & Private</h3>
                <p>Your data is secure with multi-tenant isolation and JWT authentication.</p>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
        <h2>Ready to Get Started?</h2>
        <p>Join thousands of golfers managing their leagues with GolfManager</p>
        @if (!AuthService.IsAuthenticated)
        {
            <button class="btn btn-primary btn-lg" @onclick="NavigateToRegister">
                Create Your Free Account
            </button>
        }
    </section>
</div>

@code {
    private void NavigateToRegister()
    {
        Navigation.NavigateTo("/register");
    }

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void NavigateToDashboard()
    {
        Navigation.NavigateTo("/dashboard");
    }
}
