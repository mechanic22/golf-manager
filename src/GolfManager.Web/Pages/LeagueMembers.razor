@page "/league/{LeagueKey}/members"
@layout AppLayout
@using GolfManager.Shared.DTOs.League
@using GolfManager.Web.Services
@using MaterialComponents.Models
@inject IAuthService AuthService
@inject IAuthorizationService AuthorizationService
@inject ILeagueService LeagueService
@inject SeedDataService SeedData
@inject NavigationManager Navigation
@inject ILogger<LeagueMembers> Logger

<PageTitle>Members - @(league?.Name ?? "League") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading members...</p>
        </div>
    </div>
}
else if (league == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">League Not Found</h2>
                <p class="text-gray-600 mb-8">The league you're looking for doesn't exist or you don't have access to it.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo("/dashboard"))">
                    Back to Dashboard
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <!-- Header -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8 py-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">@league.Name</h1>
                <p class="text-gray-600 text-sm font-mono">@league.Key</p>
            </div>
            @if (AuthorizationService.CanManageLeague(league.Id))
            {
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="ShowAddMemberModal">
                    <MaterialIcon Icon="MaterialIcons.PersonAdd" Class="mr-1" />
                    Add Member
                </MaterialButton>
            }
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8">
        <MaterialTabs @bind-ActiveTab="activeTab"
                      Tabs="@GetNavigationTabs()"
                      ShowContent="false"
                      OnTabChange="HandleTabChange" />
    </div>

    <div class="mt-8"></div>

    <!-- Members List -->
    @if (isLoadingMembers)
    {
        <div class="flex items-center justify-center py-8">
            <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
        </div>
    }
    else if (members == null || !members.Any())
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <MaterialIcon Icon="MaterialIcons.People" Class="text-gray-400 text-5xl mb-4" />
                <p class="text-gray-600 mb-4">No members yet</p>
                @if (AuthorizationService.CanManageLeague(league.Id))
                {
                    <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="ShowAddMemberModal">
                        Add First Member
                    </MaterialButton>
                }
            </div>
        </MaterialCard>
    }
    else
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content p-0">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50 border-b border-gray-200">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Member</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
                                @if (AuthorizationService.CanManageLeague(league.Id))
                                {
                                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var member in members)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 h-10 w-10 bg-primary-100 rounded-full flex items-center justify-center">
                                                <span class="text-primary-700 font-semibold">@GetInitials(member.FirstName, member.LastName)</span>
                                            </div>
                                            <div class="ml-4">
                                                <div class="text-sm font-medium text-gray-900">@member.FullName</div>
                                                @if (!string.IsNullOrEmpty(member.PlayerDisplayName))
                                                {
                                                    <div class="text-xs text-gray-500">Player: @member.PlayerDisplayName</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@member.Email</td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        @if (member.IsLeagueAdmin)
                                        {
                                            <MaterialChip Text="Admin" Color="MaterialChipColor.Primary" Size="MaterialChipSize.Small" />
                                        }
                                        else
                                        {
                                            <MaterialChip Text="Member" Color="MaterialChipColor.Secondary" Size="MaterialChipSize.Small" />
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@member.JoinedAt.ToString("MMM d, yyyy")</td>
                                    @if (AuthorizationService.CanManageLeague(league.Id))
                                    {
                                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                            <div class="flex justify-end gap-2">
                                                @if (!member.IsLeagueAdmin)
                                                {
                                                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="() => PromoteToAdmin(member)">
                                                        <MaterialIcon Icon="MaterialIcons.ArrowUpward" Class="mr-1" />
                                                        Promote
                                                    </MaterialButton>
                                                }
                                                else
                                                {
                                                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="() => DemoteFromAdmin(member)">
                                                        <MaterialIcon Icon="MaterialIcons.ArrowDownward" Class="mr-1" />
                                                        Demote
                                                    </MaterialButton>
                                                }
                                                <MaterialButton Style="MaterialButtonStyle.Text" OnClick="() => ShowRemoveMemberConfirm(member)">
                                                    <MaterialIcon Icon="MaterialIcons.Delete" Class="mr-1 text-red-600" />
                                                    <span class="text-red-600">Remove</span>
                                                </MaterialButton>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </MaterialCard>
    }
}

<!-- Add Member Modal -->
<MaterialDialog @bind-IsOpen="showAddMemberModal" Title="Add League Member" MaxWidth="MaterialDialogMaxWidth.Small">
    <ChildContent>
        @if (!string.IsNullOrEmpty(addMemberError))
        {
            <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded mb-4">
                @addMemberError
            </div>
        }

        <div class="space-y-6">
            <MaterialInput @bind-Value="addMemberRequest.Email"
                          Label="Email Address"
                          Type="email"
                          Variant="MaterialInputVariant.Outlined"
                          SupportingText="Enter the email address of the user to add"
                          Required="true" />

            <div class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded text-sm">
                <strong>Note:</strong> If the user doesn't exist, they will be created automatically. Please provide their first and last name below.
            </div>

            <MaterialInput @bind-Value="addMemberRequest.FirstName"
                          Label="First Name"
                          Variant="MaterialInputVariant.Outlined"
                          SupportingText="Required if creating a new user" />

            <MaterialInput @bind-Value="addMemberRequest.LastName"
                          Label="Last Name"
                          Variant="MaterialInputVariant.Outlined"
                          SupportingText="Required if creating a new user" />

            <MaterialCheckbox @bind-Value="addMemberRequest.IsLeagueAdmin"
                            Label="Make this user a league admin" />

            <MaterialInput @bind-Value="addMemberRequest.InvitationMessage"
                          Label="Invitation Message (Optional)"
                          Variant="MaterialInputVariant.Outlined"
                          Multiline="true"
                          Rows="3"
                          SupportingText="Optional welcome message for the new member" />
        </div>
    </ChildContent>
    <Actions>
        <MaterialButton Style="MaterialButtonStyle.Text" OnClick="() => showAddMemberModal = false" Disabled="isAddingMember">
            Cancel
        </MaterialButton>
        <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="HandleAddMember" Disabled="isAddingMember">
            @if (isAddingMember)
            {
                <span>Adding...</span>
            }
            else
            {
                <span>Add Member</span>
            }
        </MaterialButton>
    </Actions>
</MaterialDialog>

<!-- Remove Member Confirmation -->
<MaterialDialog @bind-IsOpen="showRemoveConfirm" Title="Remove Member" MaxWidth="MaterialDialogMaxWidth.Small">
    <ChildContent>
        @if (memberToRemove != null)
        {
            <p class="text-gray-700">
                Are you sure you want to remove <strong>@memberToRemove.FullName</strong> from this league?
            </p>
        }
    </ChildContent>
    <Actions>
        <MaterialButton Style="MaterialButtonStyle.Text" OnClick="() => showRemoveConfirm = false" Disabled="isRemovingMember">
            Cancel
        </MaterialButton>
        <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="HandleRemoveMember" Disabled="isRemovingMember">
            @if (isRemovingMember)
            {
                <span>Removing...</span>
            }
            else
            {
                <span>Remove</span>
            }
        </MaterialButton>
    </Actions>
</MaterialDialog>

@code {
    [Parameter]
    public string LeagueKey { get; set; } = string.Empty;

    private LeagueResponse? league;
    private List<LeagueMemberResponse>? members;
    private bool isLoading = true;
    private bool isLoadingMembers = true;

    // Add member modal
    private bool showAddMemberModal = false;
    private bool isAddingMember = false;
    private AddLeagueMemberRequest addMemberRequest = new();
    private string? addMemberError;

    // Remove member
    private bool showRemoveConfirm = false;
    private bool isRemovingMember = false;
    private LeagueMemberResponse? memberToRemove;

    // Tab navigation
    private string activeTab = "members";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        // Initialize authorization service
        await AuthorizationService.InitializeAsync();

        await LoadLeague();
        await LoadMembers();
    }

    private async Task LoadLeague()
    {
        try
        {
            isLoading = true;

            // Use seed data - find league by key
            var seedLeague = SeedData.Leagues.FirstOrDefault(l => l.Key == LeagueKey);
            if (seedLeague != null)
            {
                league = new LeagueResponse
                {
                    Id = seedLeague.Id,
                    Key = seedLeague.Key,
                    Name = seedLeague.Name,
                    Description = seedLeague.Description,
                    MemberCount = seedLeague.MemberCount,
                    PlayerCount = seedLeague.MemberCount,
                    SeasonCount = SeedData.Seasons.Count(s => s.LeagueId == seedLeague.Id),
                    IsCurrentUserAdmin = seedLeague.AdminUserId == AuthService.UserId || AuthService.IsGlobalAdmin,
                    CreatedAt = seedLeague.CreatedDate
                };
            }

            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading league");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadMembers()
    {
        if (league == null) return;

        try
        {
            isLoadingMembers = true;

            // Use seed data - get all users who have played in this league
            var playerIds = SeedData.Rounds
                .Where(r => SeedData.Events.Any(e => e.Id == r.EventId && e.LeagueId == league.Id))
                .Select(r => r.PlayerId)
                .Distinct()
                .ToList();

            members = SeedData.Users
                .Where(u => playerIds.Contains(u.Id))
                .Select(u => new LeagueMemberResponse
                {
                    UserId = u.Id,
                    Email = u.Email,
                    FirstName = u.FirstName,
                    LastName = u.LastName,
                    IsLeagueAdmin = league.IsCurrentUserAdmin && u.Id == SeedData.Leagues.First(l => l.Id == league.Id).AdminUserId,
                    JoinedAt = u.JoinedDate
                })
                .ToList();

            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading members");
        }
        finally
        {
            isLoadingMembers = false;
        }
    }

    private void ShowAddMemberModal()
    {
        addMemberRequest = new AddLeagueMemberRequest();
        addMemberError = null;
        showAddMemberModal = true;
    }

    private async Task HandleAddMember()
    {
        if (league == null) return;

        addMemberError = null;
        isAddingMember = true;

        try
        {
            var response = await LeagueService.AddLeagueMemberAsync(league.Id, addMemberRequest);

            if (response?.Success == true)
            {
                showAddMemberModal = false;
                await LoadMembers();
                await LoadLeague(); // Refresh member count
            }
            else
            {
                addMemberError = response?.Message ?? "Failed to add member";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding member");
            addMemberError = "An error occurred while adding the member";
        }
        finally
        {
            isAddingMember = false;
        }
    }

    private async Task PromoteToAdmin(LeagueMemberResponse member)
    {
        if (league == null) return;

        try
        {
            var request = new UpdateLeagueMemberRequest { IsLeagueAdmin = true };
            var response = await LeagueService.UpdateLeagueMemberAsync(league.Id, member.UserId, request);

            if (response?.Success == true)
            {
                await LoadMembers();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error promoting member");
        }
    }

    private async Task DemoteFromAdmin(LeagueMemberResponse member)
    {
        if (league == null) return;

        try
        {
            var request = new UpdateLeagueMemberRequest { IsLeagueAdmin = false };
            var response = await LeagueService.UpdateLeagueMemberAsync(league.Id, member.UserId, request);

            if (response?.Success == true)
            {
                await LoadMembers();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error demoting member");
        }
    }

    private void ShowRemoveMemberConfirm(LeagueMemberResponse member)
    {
        memberToRemove = member;
        showRemoveConfirm = true;
    }

    private async Task HandleRemoveMember()
    {
        if (league == null || memberToRemove == null) return;

        isRemovingMember = true;

        try
        {
            var response = await LeagueService.RemoveLeagueMemberAsync(league.Id, memberToRemove.UserId);

            if (response?.Success == true)
            {
                showRemoveConfirm = false;
                memberToRemove = null;
                await LoadMembers();
                await LoadLeague(); // Refresh member count
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing member");
        }
        finally
        {
            isRemovingMember = false;
        }
    }

    private string GetInitials(string firstName, string lastName)
    {
        var first = !string.IsNullOrEmpty(firstName) ? firstName[0].ToString() : "";
        var last = !string.IsNullOrEmpty(lastName) ? lastName[0].ToString() : "";
        return (first + last).ToUpper();
    }

    private List<MaterialTab> GetNavigationTabs()
    {
        var tabs = new List<MaterialTab>
        {
            new MaterialTab
            {
                Value = "dashboard",
                Label = "Dashboard",
                Icon = @<MaterialIcon Icon="MaterialIcons.Dashboard" Size="IconSize.SM" />
            },
            new MaterialTab
            {
                Value = "seasons",
                Label = "Seasons",
                Icon = @<MaterialIcon Icon="MaterialIcons.CalendarToday" Size="IconSize.SM" />
            },
            new MaterialTab
            {
                Value = "members",
                Label = "Members",
                Icon = @<MaterialIcon Icon="MaterialIcons.People" Size="IconSize.SM" />
            }
        };

        // Only show Settings tab to admins (Global Admin OR League Admin)
        if (league != null && AuthorizationService.CanManageLeague(league.Id))
        {
            tabs.Add(new MaterialTab
            {
                Value = "settings",
                Label = "Settings",
                Icon = @<MaterialIcon Icon="MaterialIcons.Settings" Size="IconSize.SM" />
            });
        }

        return tabs;
    }

    private void HandleTabChange(string tabValue)
    {
        var route = tabValue switch
        {
            "dashboard" => $"/league/{LeagueKey}",
            "seasons" => $"/league/{LeagueKey}/seasons",
            "members" => $"/league/{LeagueKey}/members",
            "settings" => $"/league/{LeagueKey}/settings",
            _ => $"/league/{LeagueKey}"
        };

        Navigation.NavigateTo(route);
    }
}

