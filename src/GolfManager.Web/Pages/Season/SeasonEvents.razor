@page "/league/{LeagueKey}/season/{SeasonKey}/events"
@layout AppLayout
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Shared.DTOs.Event
@using GolfManager.Web.Services
@using MaterialComponents.Models

<PageTitle>Events - @(season?.Name ?? "Season") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading...</p>
        </div>
    </div>
}
else if (season == null || league == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Season Not Found</h2>
                <p class="text-gray-600 mb-8">The season you're looking for doesn't exist or you don't have access to it.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/seasons"))">
                    Back to Seasons
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8 py-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
                    <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <a href="@($"/league/{LeagueKey}")" class="hover:text-primary-600">@league.Name</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <a href="@($"/league/{LeagueKey}/season/{SeasonKey}")" class="hover:text-primary-600">@season.Name</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <span class="text-gray-900">Events</span>
                </div>
                <div class="flex items-center gap-3 mb-2">
                    <h1 class="text-3xl font-bold text-gray-900">@season.Name</h1>
                    @if (season.IsLocked)
                    {
                        <MaterialChip Text="Locked" Color="MaterialChipColor.Secondary" Size="MaterialChipSize.Medium" />
                    }
                </div>
                <div class="flex items-center gap-4 text-sm text-gray-600">
                    <span class="font-mono">@season.Key</span>
                </div>
            </div>
            @if (CanManageSeason)
            {
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="OpenCreateEventManager">
                    <MaterialIcon Icon="MaterialIcons.Add" Class="mr-1" />
                    Add Event
                </MaterialButton>
            }
        </div>
    </div>

    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8">
        <MaterialTabs @bind-ActiveTab="activeTab"
                      Tabs="@GetNavigationTabs()"
                      ShowContent="false"
                      OnTabChange="HandleTabChange" />
    </div>

    <div class="mt-8"></div>

    @if (events.Count == 0)
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Event" Class="text-gray-400 text-5xl mb-4" />
                <h3 class="text-lg font-semibold text-gray-900 mb-2">No Events Yet</h3>
                <p class="text-gray-600">Events will appear here once they are created.</p>
            </div>
        </MaterialCard>
    }
    else
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content">
                <div class="divide-y divide-gray-200">
                    @foreach (var evt in events)
                    {
                        var scoreboard = GetScoreboard(evt.Id);
                        <div class="py-5 px-2">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-3">
                                        <div class="text-center min-w-[60px]">
                                            <div class="text-2xl font-bold text-primary-600">@evt.EventDate.Day</div>
                                            <div class="text-xs text-gray-600 uppercase">@evt.EventDate.ToString("MMM")</div>
                                        </div>
                                        <div>
                                            <h3 class="text-base font-semibold text-gray-900">@(evt.Name ?? $"Event {events.IndexOf(evt) + 1}")</h3>
                                            <div class="flex items-center gap-4 mt-1 text-sm text-gray-600">
                                                <span class="flex items-center gap-1">
                                                    <MaterialIcon Icon="MaterialIcons.Event" Class="text-xs" />
                                                    @evt.EventDate.ToString("dddd, MMMM d, yyyy")
                                                </span>
                                                <span class="flex items-center gap-1">
                                                    <MaterialIcon Icon="MaterialIcons.Flag" Class="text-xs" />
                                                    @evt.HolesPlayed
                                                </span>
                                                <span class="flex items-center gap-1">
                                                    <MaterialIcon Icon="MaterialIcons.Score" Class="text-xs" />
                                                    @evt.ScoringFormat
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(evt.GameOfDayTitle) || !string.IsNullOrWhiteSpace(evt.GameOfDayWinnerDisplayName))
                                    {
                                        <div class="mt-4 ml-[72px]">
                                            <div class="inline-flex items-center gap-2 rounded-md bg-gray-100 px-3 py-1 text-sm text-gray-700">
                                                <MaterialIcon Icon="MaterialIcons.EmojiEvents" Class="text-amber-600 text-base" />
                                                <span>
                                                    @if (!string.IsNullOrWhiteSpace(evt.GameOfDayTitle))
                                                    {
                                                        <strong>@evt.GameOfDayTitle</strong>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(evt.GameOfDayTitle) && !string.IsNullOrWhiteSpace(evt.GameOfDayWinnerDisplayName))
                                                    {
                                                        <span>: </span>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(evt.GameOfDayWinnerDisplayName))
                                                    {
                                                        <span>Weekly Winner @evt.GameOfDayWinnerDisplayName</span>
                                                    }
                                                </span>
                                            </div>
                                        </div>
                                    }

                                    @if (scoreboard != null && (scoreboard.Matches.Count > 0 || scoreboard.Players.Count > 0))
                                    {
                                        <div class="mt-4 ml-[72px] space-y-4">
                                            @if (scoreboard.Matches.Count > 0)
                                            {
                                                <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                                                    <div class="mb-3 flex items-center justify-between gap-3">
                                                        <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Team Results</h4>
                                                        <span class="text-xs text-gray-500">@scoreboard.Matches.Count matchup(s)</span>
                                                    </div>
                                                    <div class="space-y-2">
                                                        @foreach (var match in scoreboard.Matches)
                                                        {
                                                            <div class="rounded-lg border border-white bg-white px-3 py-3 shadow-sm">
                                                                <div class="flex items-center justify-between gap-4">
                                                                    <div>
                                                                        <div class="font-medium text-gray-900">@match.HomeTeamName vs @match.AwayTeamName</div>
                                                                        <div class="text-xs text-gray-500">
                                                                            Flight @((match.StartingFlight ?? 0) == 0 ? "-" : match.StartingFlight) • Start hole @((match.StartingHole ?? 0) == 0 ? "-" : match.StartingHole)
                                                                        </div>
                                                                    </div>
                                                                    <div class="text-right">
                                                                        <div class="text-lg font-semibold text-gray-900">@(match.HomePoints?.ToString("F1") ?? "-") - @(match.AwayPoints?.ToString("F1") ?? "-")</div>
                                                                        <div class="text-xs text-gray-500">match points</div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            @if (scoreboard.Players.Count > 0)
                                            {
                                                <div class="rounded-xl border border-gray-200 bg-white p-4">
                                                    <div class="mb-3 flex items-center justify-between gap-3">
                                                        <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Individual Results</h4>
                                                        <span class="text-xs text-gray-500">Top @Math.Min(scoreboard.Players.Count, 8)</span>
                                                    </div>
                                                    <div class="overflow-x-auto">
                                                        <table class="min-w-full text-sm">
                                                            <thead>
                                                                <tr class="text-left text-xs uppercase tracking-wide text-gray-500">
                                                                    <th class="pb-2 pr-4">Pos</th>
                                                                    <th class="pb-2 pr-4">Player</th>
                                                                    <th class="pb-2 pr-4">Team</th>
                                                                    <th class="pb-2 pr-4">Raw</th>
                                                                    <th class="pb-2 pr-4">Net</th>
                                                                    <th class="pb-2">Pts</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var player in scoreboard.Players.Take(8))
                                                                {
                                                                    <tr class="border-t border-gray-100 text-gray-900">
                                                                        <td class="py-2 pr-4 font-semibold">@(player.EventPosition?.ToString() ?? "-")</td>
                                                                        <td class="py-2 pr-4">@player.DisplayName</td>
                                                                        <td class="py-2 pr-4 text-gray-600">@(string.IsNullOrWhiteSpace(player.TeamName) ? "-" : player.TeamName)</td>
                                                                        <td class="py-2 pr-4">@(player.RawScore?.ToString() ?? "-")</td>
                                                                        <td class="py-2 pr-4">@(player.NetScore?.ToString("F1") ?? "-")</td>
                                                                        <td class="py-2 font-semibold">@(player.EventPoints?.ToString("F1") ?? "-")</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="flex flex-col items-end gap-3 shrink-0">
                                    <div class="flex items-center gap-2">
                                        <span class="px-2 py-1 text-xs rounded-full @(evt.EventType == Core.Enums.SeasonEventType.Regular ? "bg-blue-100 text-blue-800" : "bg-purple-100 text-purple-800")">
                                            @evt.EventType
                                        </span>
                                        @if (evt.IsLocked)
                                        {
                                            <MaterialIcon Icon="MaterialIcons.Lock" Class="text-gray-400 text-sm" />
                                        }
                                    </div>
                                    <div class="flex flex-wrap justify-end gap-2">
                                        @if (CanManageSeason)
                                        {
                                            <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => OpenScoreEntry(evt))">
                                                Scores
                                            </MaterialButton>
                                        }
                                        <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => OpenPrintScorecards(evt))">
                                            Scorecards
                                        </MaterialButton>
                                        @if (CanManageSeason)
                                        {
                                            <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => OpenEditEventManager(evt))">
                                                Manage
                                            </MaterialButton>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </MaterialCard>
    }
}

@if (showEventManagerModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4" @onclick="CloseEventManagerModal">
        <div class="max-h-[90vh] w-full max-w-6xl overflow-y-auto rounded-2xl bg-white shadow-2xl" @onclick:stopPropagation="true">
            <div class="sticky top-0 z-10 flex items-center justify-between border-b border-gray-200 bg-white px-6 py-4">
                <div>
                    <h2 class="text-xl font-semibold text-gray-900">@(isCreatingEvent ? "Add Event" : $"Manage {(selectedEvent?.Name ?? "Event")}")</h2>
                    <p class="text-sm text-gray-600">Keep event setup in one place instead of editing directly in the list.</p>
                </div>
                <MaterialButton Style="MaterialButtonStyle.Text" OnClick="CloseEventManagerModal">Close</MaterialButton>
            </div>

            <div class="px-6 py-5 space-y-6">
                @if (!string.IsNullOrWhiteSpace(eventManagerErrorMessage))
                {
                    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@eventManagerErrorMessage</div>
                }

                @if (isCreatingEvent)
                {
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                        <div>
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Event Name</label>
                            <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="createEventRequest.Name" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Event Date</label>
                            <input type="date" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="createEventRequest.EventDate" />
                        </div>
                        <div>
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Event Type</label>
                            <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="createEventRequest.EventType">
                                <option value="@Core.Enums.SeasonEventType.Regular">Regular</option>
                                <option value="@Core.Enums.SeasonEventType.Special">Special</option>
                                <option value="@Core.Enums.SeasonEventType.Playoff">Playoff</option>
                                <option value="@Core.Enums.SeasonEventType.Championship">Championship</option>
                            </select>
                        </div>
                        <div>
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Format</label>
                            <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="createEventRequest.ScoringFormat">
                                <option value="@Core.Enums.ScoringFormat.MatchPlay">Match Play</option>
                                <option value="@Core.Enums.ScoringFormat.StrokePlay">Stroke Play</option>
                                <option value="@Core.Enums.ScoringFormat.Stableford">Stableford</option>
                            </select>
                        </div>
                        <div>
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Holes</label>
                            <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="createEventRequest.HolesPlayed">
                                <option value="@Core.Enums.HolesPlayed.Nine">Nine</option>
                                <option value="@Core.Enums.HolesPlayed.Eighteen">Eighteen</option>
                            </select>
                        </div>
                        <div class="md:col-span-2">
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Notes</label>
                            <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="createEventRequest.Description" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Weekly Winner Category</label>
                            <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" placeholder="Closest to pin, skins, etc." @bind="createEventRequest.GameOfDayTitle" @bind:event="oninput" />
                        </div>
                        <div>
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Weekly Winner (Season Player)</label>
                            <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="createEventRequest.GameOfDayWinnerSeasonGolferId">
                                <option value="">Select winner</option>
                                @foreach (var player in seasonPlayers)
                                {
                                    <option value="@player.SeasonGolferId">@player.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="md:col-span-2">
                            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Winner Name Override</label>
                            <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" placeholder="Optional custom winner" @bind="createEventRequest.GameOfDayWinnerDisplayName" @bind:event="oninput" />
                        </div>
                    </div>
                }
                else if (selectedEvent != null)
                {
                    <div class="space-y-6">
                        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                            <div>
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Event Name</label>
                                <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="GetEventEditRequest(selectedEvent.Id).Name" @bind:event="oninput" />
                            </div>
                            <div>
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Event Date</label>
                                <input type="date" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="GetEventEditRequest(selectedEvent.Id).EventDate" />
                            </div>
                            <div>
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Event Type</label>
                                <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="GetEventEditRequest(selectedEvent.Id).EventType">
                                    <option value="@Core.Enums.SeasonEventType.Regular">Regular</option>
                                    <option value="@Core.Enums.SeasonEventType.Special">Special</option>
                                    <option value="@Core.Enums.SeasonEventType.Playoff">Playoff</option>
                                    <option value="@Core.Enums.SeasonEventType.Championship">Championship</option>
                                </select>
                            </div>
                            <div>
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Format</label>
                                <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="GetEventEditRequest(selectedEvent.Id).ScoringFormat">
                                    <option value="@Core.Enums.ScoringFormat.MatchPlay">Match Play</option>
                                    <option value="@Core.Enums.ScoringFormat.StrokePlay">Stroke Play</option>
                                    <option value="@Core.Enums.ScoringFormat.Stableford">Stableford</option>
                                </select>
                            </div>
                            <div>
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Holes</label>
                                <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="GetEventEditRequest(selectedEvent.Id).HolesPlayed">
                                    <option value="@Core.Enums.HolesPlayed.Nine">Nine</option>
                                    <option value="@Core.Enums.HolesPlayed.Eighteen">Eighteen</option>
                                </select>
                            </div>
                            <div class="md:col-span-2">
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Notes</label>
                                <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="GetEventEditRequest(selectedEvent.Id).Description" @bind:event="oninput" />
                            </div>
                            <div>
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Weekly Winner Category</label>
                                <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" placeholder="Closest to pin, skins, etc." @bind="gameOfDayTitles[selectedEvent.Id]" @bind:event="oninput" />
                            </div>
                            <div>
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Weekly Winner (Season Player)</label>
                                <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="gameOfDayWinnerSeasonGolferIds[selectedEvent.Id]">
                                    <option value="">Select winner</option>
                                    @foreach (var player in seasonPlayers)
                                    {
                                        <option value="@player.SeasonGolferId">@player.DisplayName</option>
                                    }
                                </select>
                            </div>
                            <div class="md:col-span-2">
                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Winner Name Override</label>
                                <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" placeholder="Optional custom winner" @bind="gameOfDayWinnerNames[selectedEvent.Id]" @bind:event="oninput" />
                            </div>
                        </div>

                        <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                            <div class="mb-3 flex items-center justify-between gap-3">
                                <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-800">Matchups</h4>
                                <div class="flex flex-wrap gap-2">
                                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => OpenScoreEntry(selectedEvent))">Scores</MaterialButton>
                                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => OpenPrintScorecards(selectedEvent))">Scorecards</MaterialButton>
                                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => RecalculateEventHandicaps(selectedEvent))" Disabled="@IsRecalculatingHandicaps(selectedEvent.Id)">
                                        @(IsRecalculatingHandicaps(selectedEvent.Id) ? "Recalculating..." : "Recalculate Handicaps")
                                    </MaterialButton>
                                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => RecalculateOverallStandings(selectedEvent))" Disabled="@IsRecalculatingOverall(selectedEvent.Id)">
                                        @(IsRecalculatingOverall(selectedEvent.Id) ? "Calculating..." : "Calculate Overall")
                                    </MaterialButton>
                                    <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => ScheduleNextWeek(selectedEvent))" Disabled="@IsSchedulingNextWeek(selectedEvent.Id)">
                                        @(IsSchedulingNextWeek(selectedEvent.Id) ? "Scheduling..." : "Schedule Next Week")
                                    </MaterialButton>
                                    <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => AutoSetupMatchups(selectedEvent))" Disabled="@IsAutoSetupInProgress(selectedEvent.Id)">
                                        @(IsAutoSetupInProgress(selectedEvent.Id) ? "Generating..." : "Auto Setup")
                                    </MaterialButton>
                                </div>
                            </div>

                            @if (GetMatchups(selectedEvent.Id).Count == 0)
                            {
                                <p class="text-sm text-gray-500">No matchups yet. Use Auto Setup to build pairings, then fine-tune them here.</p>
                            }
                            else
                            {
                                <div class="space-y-2">
                                    @foreach (var matchup in GetMatchups(selectedEvent.Id))
                                    {
                                        <div class="grid grid-cols-1 items-end gap-2 rounded-lg border border-gray-200 bg-white p-3 md:grid-cols-14">
                                            <div class="md:col-span-2">
                                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Home Team</label>
                                                <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="matchup.HomeTeamId">
                                                    <option value="">Select team</option>
                                                    @foreach (var team in seasonTeams)
                                                    {
                                                        <option value="@team.Id">@team.Name</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="md:col-span-3">
                                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Home Sub</label>
                                                <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="matchup.HomeSubSeasonGolferId">
                                                    <option value="">No sub</option>
                                                    @foreach (var player in GetTeamOrSubCandidates(matchup.HomeTeamId))
                                                    {
                                                        <option value="@player.SeasonGolferId">@player.DisplayName</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="md:col-span-2">
                                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Away Team</label>
                                                <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="matchup.AwayTeamId">
                                                    <option value="">Select team</option>
                                                    @foreach (var team in seasonTeams)
                                                    {
                                                        <option value="@team.Id">@team.Name</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="md:col-span-3">
                                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Away Sub</label>
                                                <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="matchup.AwaySubSeasonGolferId">
                                                    <option value="">No sub</option>
                                                    @foreach (var player in GetTeamOrSubCandidates(matchup.AwayTeamId))
                                                    {
                                                        <option value="@player.SeasonGolferId">@player.DisplayName</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="md:col-span-1">
                                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Flight</label>
                                                <input type="number" min="1" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="matchup.StartingFlight" />
                                            </div>
                                            <div class="md:col-span-1">
                                                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-600">Start Hole</label>
                                                <input type="number" min="1" max="18" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" @bind="matchup.StartingHole" />
                                            </div>
                                            <div class="md:col-span-2 flex justify-end">
                                                <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => SaveMatchup(selectedEvent, matchup))" Disabled="@IsSavingMatchup(matchup.Id)">
                                                    @(IsSavingMatchup(matchup.Id) ? "Saving..." : "Save")
                                                </MaterialButton>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="sticky bottom-0 flex items-center justify-between gap-3 border-t border-gray-200 bg-white px-6 py-4">
                <div>
                    @if (!isCreatingEvent && selectedEvent != null)
                    {
                        <MaterialButton Style="MaterialButtonStyle.Text" OnClick="DeleteSelectedEvent" Disabled="@isEventManagerDeleting">
                            @(isEventManagerDeleting ? "Deleting..." : "Delete Event")
                        </MaterialButton>
                    }
                </div>
                <div class="flex items-center gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="CloseEventManagerModal">Cancel</MaterialButton>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="SaveEventManager" Disabled="@IsSelectedEventSaving">
                        @(IsSelectedEventSaving ? "Saving..." : (isCreatingEvent ? "Create Event" : "Save Event"))
                    </MaterialButton>
                </div>
            </div>
        </div>
    </div>
}
