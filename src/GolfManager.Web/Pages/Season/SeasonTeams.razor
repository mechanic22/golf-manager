@page "/league/{LeagueKey}/season/{SeasonKey}/teams"
@layout AppLayout
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Shared.DTOs.Player
@using GolfManager.Web.Services
@using MaterialComponents.Models

<PageTitle>Teams - @(season?.Name ?? "Season") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading...</p>
        </div>
    </div>
}
else if (season == null || league == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Season Not Found</h2>
                <p class="text-gray-600 mb-8">The season you're looking for doesn't exist or you don't have access to it.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/seasons"))">
                    Back to Seasons
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <!-- Header -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8 py-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
                    <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <a href="@($"/league/{LeagueKey}")" class="hover:text-primary-600">@league.Name</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <a href="@($"/league/{LeagueKey}/season/{SeasonKey}")" class="hover:text-primary-600">@season.Name</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <span class="text-gray-900">Teams</span>
                </div>
                <div class="flex items-center gap-3 mb-2">
                    <h1 class="text-3xl font-bold text-gray-900">@season.Name</h1>
                    @if (season.IsLocked)
                    {
                        <MaterialChip Text="Locked" Color="MaterialChipColor.Secondary" Size="MaterialChipSize.Medium" />
                    }
                </div>
                <div class="flex items-center gap-4 text-sm text-gray-600">
                    <span class="font-mono">@season.Key</span>
                </div>
            </div>
            @if (CanManageSeason)
            {
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="OpenAddTeamModal">
                    <MaterialIcon Icon="MaterialIcons.GroupAdd" Class="mr-1" />
                    Add Team
                </MaterialButton>
            }
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8">
        <MaterialTabs @bind-ActiveTab="activeTab"
                      Tabs="@GetNavigationTabs()"
                      ShowContent="false"
                      OnTabChange="HandleTabChange" />
    </div>

    <div class="mt-8"></div>

    @if (isLoadingTeams)
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-3"></div>
                <p class="text-gray-600">Loading teams...</p>
            </div>
        </MaterialCard>
    }
    else if (teams.Count == 0)
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <MaterialIcon Icon="MaterialIcons.Groups" Class="text-gray-400 text-5xl mb-4" />
                <p class="text-gray-600 mb-4">No teams in this season yet</p>
                @if (CanManageSeason)
                {
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="OpenAddTeamModal">
                        <MaterialIcon Icon="MaterialIcons.GroupAdd" Class="mr-1" />
                        Add First Team
                    </MaterialButton>
                }
            </div>
        </MaterialCard>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm">@successMessage</div>
        }

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @foreach (var standing in RankedTeams)
            {
                var team = standing.Team;
                <MaterialCard Variant="MaterialCardVariant.Outlined">
                    <div class="md-card__content">
                        <!-- Team Header -->
                        <div class="flex items-center justify-between mb-4">
                            <div class="flex items-center gap-3">
                                <div class="h-10 w-10 bg-primary-100 rounded-full flex items-center justify-center">
                                    <MaterialIcon Icon="MaterialIcons.Groups" Class="text-primary-700" />
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-900">@team.Name</h3>
                                    <p class="text-xs text-gray-500">@team.Members.Count player(s) • @standing.MatchCount match(es)</p>
                                </div>
                            </div>
                            @if (CanManageSeason)
                            {
                                <div class="flex gap-1">
                                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => OpenEditTeamModal(team))">
                                        <MaterialIcon Icon="MaterialIcons.Edit" Class="text-sm" />
                                    </MaterialButton>
                                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => OpenDeleteTeamConfirm(team))">
                                        <MaterialIcon Icon="MaterialIcons.Delete" Class="text-sm text-red-500" />
                                    </MaterialButton>
                                </div>
                            }
                        </div>

                        <!-- Win/Loss record -->
                        <div class="grid grid-cols-4 gap-3 mb-4 text-sm">
                            <div class="rounded-lg bg-green-50 px-3 py-2">
                                <div class="text-xs uppercase tracking-wide text-green-700">Wins</div>
                                <div class="font-semibold text-green-900">@standing.Wins</div>
                            </div>
                            <div class="rounded-lg bg-red-50 px-3 py-2">
                                <div class="text-xs uppercase tracking-wide text-red-700">Losses</div>
                                <div class="font-semibold text-red-900">@standing.Losses</div>
                            </div>
                            <div class="rounded-lg bg-gray-50 px-3 py-2">
                                <div class="text-xs uppercase tracking-wide text-gray-600">Ties</div>
                                <div class="font-semibold text-gray-900">@standing.Ties</div>
                            </div>
                            <div class="rounded-lg bg-primary-50 px-3 py-2">
                                <div class="text-xs uppercase tracking-wide text-primary-700">Points</div>
                                <div class="font-semibold text-primary-900">@standing.PointsFor.ToString("F1")</div>
                            </div>
                        </div>

                        <div class="mb-4 flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2 text-sm">
                            <span class="text-gray-600">Point Differential</span>
                            <span class="font-semibold text-gray-900">@standing.PointDifferential.ToString("F1")</span>
                        </div>

                        <!-- Members -->
                        @if (team.Members.Count == 0)
                        {
                            <p class="text-sm text-gray-400 italic">No players assigned</p>
                        }
                        else
                        {
                            <ul class="divide-y divide-gray-100">
                                @foreach (var member in team.Members)
                                {
                                    <li class="py-2 flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            <div class="h-7 w-7 bg-gray-100 rounded-full flex items-center justify-center text-xs font-semibold text-gray-700">
                                                @GetInitials(member.DisplayName)
                                            </div>
                                            <span class="text-sm text-gray-900">@member.DisplayName</span>
                                            @if (member.LeagueHandicap.HasValue)
                                            {
                                                <span class="text-xs text-gray-400">(HCP @member.LeagueHandicap.Value.ToString("F1"))</span>
                                            }
                                        </div>
                                        @if (CanManageSeason)
                                        {
                                            <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => UnassignPlayer(member, team))">
                                                <MaterialIcon Icon="MaterialIcons.PersonRemove" Class="text-xs text-gray-400" />
                                            </MaterialButton>
                                        }
                                    </li>
                                }
                            </ul>
                        }

                        <!-- Assign unassigned player to this team -->
                        @if (CanManageSeason && unassignedPlayers.Count() > 0)
                        {
                            <div class="mt-4 flex gap-2 items-center">
                                <select class="flex-1 text-sm border border-gray-300 rounded px-2 py-1"
                                        @bind="assignTargetPlayerId[team.Id]">
                                    <option value="">Add player to team...</option>
                                    @foreach (var p in unassignedPlayers)
                                    {
                                        <option value="@p.SeasonGolferId">@p.DisplayName</option>
                                    }
                                </select>
                                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => AssignSelectedPlayer(team))">
                                    Add
                                </MaterialButton>
                            </div>
                        }
                    </div>
                </MaterialCard>
            }
        </div>
    }
}

<!-- Add Team Modal -->
@if (showAddTeamModal)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" @onclick="CloseAddTeamModal">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4" @onclick:stopPropagation="true">
            <div class="p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Add Team</h2>
                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="mb-3 p-3 bg-red-50 border border-red-200 rounded text-red-700 text-sm">@modalError</div>
                }
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Team Name</label>
                    <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
                           @bind="newTeamName" @bind:event="oninput" placeholder="e.g., Team 1" />
                </div>
                <div class="flex justify-end gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="CloseAddTeamModal" Disabled="isSaving">Cancel</MaterialButton>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="SaveNewTeam" Disabled="@(isSaving || string.IsNullOrWhiteSpace(newTeamName))">
                        @if (isSaving) { <span>Saving...</span> } else { <span>Add Team</span> }
                    </MaterialButton>
                </div>
            </div>
        </div>
    </div>
}

<!-- Edit Team Modal -->
@if (showEditTeamModal && editingTeam != null)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" @onclick="CloseEditTeamModal">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4" @onclick:stopPropagation="true">
            <div class="p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Edit Team</h2>
                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="mb-3 p-3 bg-red-50 border border-red-200 rounded text-red-700 text-sm">@modalError</div>
                }
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Team Name</label>
                    <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
                           @bind="editTeamName" @bind:event="oninput" />
                </div>
                <div class="flex justify-end gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="CloseEditTeamModal" Disabled="isSaving">Cancel</MaterialButton>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="SaveEditTeam" Disabled="@(isSaving || string.IsNullOrWhiteSpace(editTeamName))">
                        @if (isSaving) { <span>Saving...</span> } else { <span>Save</span> }
                    </MaterialButton>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Team Confirm -->
@if (showDeleteTeamConfirm && teamToDelete != null)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" @onclick="CloseDeleteTeamConfirm">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4" @onclick:stopPropagation="true">
            <div class="p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-3">Delete Team</h2>
                <p class="text-gray-600 mb-6">
                    Are you sure you want to delete <strong>@teamToDelete.Name</strong>?
                    Players will be unassigned from the team but will remain in the season.
                </p>
                <div class="flex justify-end gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="CloseDeleteTeamConfirm" Disabled="isSaving">Cancel</MaterialButton>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="ConfirmDeleteTeam" Disabled="isSaving">
                        @if (isSaving) { <span>Deleting...</span> } else { <span>Delete Team</span> }
                    </MaterialButton>
                </div>
            </div>
        </div>
    </div>
}
