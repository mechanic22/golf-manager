@page "/league/{LeagueKey}/season/{SeasonKey}/players"
@layout AppLayout
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Shared.DTOs.Player
@using GolfManager.Shared.DTOs.User
@using GolfManager.Web.Services
@using MaterialComponents.Models

<PageTitle>Players - @(season?.Name ?? "Season") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading...</p>
        </div>
    </div>
}
else if (season == null || league == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Season Not Found</h2>
                <p class="text-gray-600 mb-8">The season you're looking for doesn't exist or you don't have access to it.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/seasons"))">
                    Back to Seasons
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <!-- Header -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8 py-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
                    <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <a href="@($"/league/{LeagueKey}")" class="hover:text-primary-600">@league.Name</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <a href="@($"/league/{LeagueKey}/season/{SeasonKey}")" class="hover:text-primary-600">@season.Name</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <span class="text-gray-900">Players</span>
                </div>
                <div class="flex items-center gap-3 mb-2">
                    <h1 class="text-3xl font-bold text-gray-900">@season.Name</h1>
                    @if (season.IsLocked)
                    {
                        <MaterialChip Text="Locked" Color="MaterialChipColor.Secondary" Size="MaterialChipSize.Medium" />
                    }
                </div>
                <div class="flex items-center gap-4 text-sm text-gray-600">
                    <span class="font-mono">@season.Key</span>
                </div>
            </div>
            @if (CanManageSeason)
            {
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => showAddGolferModal = true)">
                    <MaterialIcon Icon="MaterialIcons.PersonAdd" Class="mr-1" />
                    Add Player
                </MaterialButton>
            }
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8">
        <MaterialTabs @bind-ActiveTab="activeTab" 
                      Tabs="@GetNavigationTabs()" 
                      ShowContent="false"
                      OnTabChange="HandleTabChange" />
    </div>

    <div class="mt-8"></div>

    <!-- Players Section -->
    @if (isLoadingGolfers)
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-3"></div>
                <p class="text-gray-600">Loading players...</p>
            </div>
        </MaterialCard>
    }
    else if (golfers == null || golfers.Count == 0)
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <MaterialIcon Icon="MaterialIcons.GolfCourse" Class="text-gray-400 text-5xl mb-4" />
                <p class="text-gray-600 mb-4">No players in this season yet</p>
                @if (CanManageSeason)
                {
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => showAddGolferModal = true)">
                        <MaterialIcon Icon="MaterialIcons.PersonAdd" Class="mr-1" />
                        Add First Player
                    </MaterialButton>
                }
            </div>
        </MaterialCard>
    }
    else
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Player</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Team</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Handicap</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var golfer in golfers)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap cursor-pointer" @onclick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/player/{golfer.Id}"))">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 h-10 w-10 bg-primary-100 rounded-full flex items-center justify-center">
                                                <span class="text-primary-700 font-semibold">@GetInitials(golfer.DisplayName)</span>
                                            </div>
                                            <div class="ml-4">
                                                <div class="text-sm font-medium text-gray-900">@golfer.DisplayName</div>
                                                @if (!string.IsNullOrEmpty(golfer.Nickname))
                                                {
                                                    <div class="text-sm text-gray-500">"@golfer.Nickname"</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        @if (!string.IsNullOrEmpty(golfer.TeamId))
                                        {
                                            var teamName = GetTeamName(golfer.TeamId);
                                            <MaterialChip Text="@teamName" Color="MaterialChipColor.Primary" Size="MaterialChipSize.Small" />
                                        }
                                        else
                                        {
                                            <span class="text-gray-400 text-sm">—</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm text-gray-900">
                                            @if (golfer.LeagueHandicap.HasValue)
                                            {
                                                <span>@golfer.LeagueHandicap.Value.ToString("F1")</span>
                                            }
                                            else
                                            {
                                                <span class="text-gray-400">-</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex flex-col gap-1">
                                            <MaterialChip Text="Active" Color="MaterialChipColor.Success" Size="MaterialChipSize.Small" />
                                            @if (golfer.IsPaidForSeason == true)
                                            {
                                                <MaterialChip Text="Paid" Color="MaterialChipColor.Primary" Size="MaterialChipSize.Small" />
                                                @if (golfer.PaidAt.HasValue)
                                                {
                                                    <span class="text-xs text-gray-500">@golfer.PaidAt.Value.ToLocalTime().ToString("MMM d")</span>
                                                }
                                            }
                                            else
                                            {
                                                <MaterialChip Text="Unpaid" Color="MaterialChipColor.Warning" Size="MaterialChipSize.Small" />
                                            }
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium" @onclick:stopPropagation="true">
                                        <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/player/{golfer.Id}"))">
                                            View
                                        </MaterialButton>
                                        @if (CanManageSeason)
                                        {
                                            <MaterialButton Style="MaterialButtonStyle.Text"
                                                            OnClick="@(() => TogglePaymentStatus(golfer))"
                                                            Disabled="@IsPaymentUpdating(golfer)">
                                                @if (IsPaymentUpdating(golfer))
                                                {
                                                    <span>Saving...</span>
                                                }
                                                else
                                                {
                                                    <span>@(golfer.IsPaidForSeason == true ? "Mark Unpaid" : "Mark Paid")</span>
                                                }
                                            </MaterialButton>
                                            <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => OpenRemovePlayerConfirm(golfer))">
                                                <MaterialIcon Icon="MaterialIcons.PersonRemove" Class="text-sm text-red-500" />
                                            </MaterialButton>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </MaterialCard>
    }
}

<!-- Add Player Modal -->
@if (showAddGolferModal)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" @onclick="CloseAddPlayerModal">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4" @onclick:stopPropagation="true">
            <div class="p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Add Player to Season</h2>
                @if (!string.IsNullOrEmpty(addPlayerError))
                {
                    <div class="mb-3 p-3 bg-red-50 border border-red-200 rounded text-red-700 text-sm">@addPlayerError</div>
                }
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label>
                    <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
                           @bind="newPlayerDisplayName" @bind:event="oninput" placeholder="e.g., John Smith" />
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
                           @bind="newPlayerEmail" @bind:event="oninput" placeholder="player@example.com" />
                    <p class="text-xs text-gray-500 mt-1">Required to create a new user account</p>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Handicap (optional)</label>
                    <input type="number" step="0.1" min="0" max="54"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
                           @bind="newPlayerHandicap" />
                </div>
                <div class="flex justify-end gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="CloseAddPlayerModal" Disabled="isAddingPlayer">Cancel</MaterialButton>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="AddPlayer"
                                    Disabled="@(isAddingPlayer || string.IsNullOrWhiteSpace(newPlayerDisplayName))">
                        @if (isAddingPlayer) { <span>Adding...</span> } else { <span>Add Player</span> }
                    </MaterialButton>
                </div>
            </div>
        </div>
    </div>
}

<!-- Remove Player Confirm -->
@if (showRemovePlayerConfirm && playerToRemove != null)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" @onclick="CloseRemovePlayerConfirm">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4" @onclick:stopPropagation="true">
            <div class="p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-3">Remove Player</h2>
                <p class="text-gray-600 mb-6">
                    Remove <strong>@playerToRemove.DisplayName</strong> from this season?
                    Their scores and rounds will be preserved.
                </p>
                <div class="flex justify-end gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Text" OnClick="CloseRemovePlayerConfirm" Disabled="isRemovingPlayer">Cancel</MaterialButton>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="ConfirmRemovePlayer" Disabled="isRemovingPlayer">
                        @if (isRemovingPlayer) { <span>Removing...</span> } else { <span>Remove</span> }
                    </MaterialButton>
                </div>
            </div>
        </div>
    </div>
}

