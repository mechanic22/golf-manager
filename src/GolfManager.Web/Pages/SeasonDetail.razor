@page "/league/{LeagueKey}/season/{SeasonKey}"
@page "/league/{LeagueKey}/season/{SeasonKey}/overview"
@layout AppLayout
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Shared.DTOs.Player
@using GolfManager.Shared.DTOs.User
@using GolfManager.Shared.DTOs.Common
@using GolfManager.Shared.DTOs.Simulation
@using GolfManager.Core.Enums
@using GolfManager.Web.Services
@using System.Text.Json
@using MaterialComponents.Models
@inject IAuthService AuthService
@inject IAuthorizationService AuthorizationService
@inject ILeagueService LeagueService
@inject ISeasonService SeasonService
@inject ISeasonSettingsService SeasonSettingsService
@inject IPlayerService PlayerService
@inject IUserService UserService
@inject SeedDataService SeedData
@inject NavigationManager Navigation
@inject ILogger<SeasonDetail> Logger
@inject HttpClient Http

<PageTitle>@(season?.Name ?? "Season") - @(league?.Name ?? "League") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading season...</p>
        </div>
    </div>
}
else if (season == null || league == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Season Not Found</h2>
                <p class="text-gray-600 mb-8">The season you're looking for doesn't exist or you don't have access to it.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}"))">
                    Back to League
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <!-- Header -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8 py-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <h1 class="text-3xl font-bold text-gray-900">@season.Name</h1>
                    @if (season.IsLocked)
                    {
                        <MaterialChip Text="Locked" Color="MaterialChipColor.Secondary" Size="MaterialChipSize.Medium" />
                    }
                </div>
                <div class="flex items-center gap-4 text-sm text-gray-600">
                    <span class="font-mono">@season.Key</span>
                    <span>•</span>
                    <div class="flex items-center gap-1">
                        <MaterialIcon Icon="MaterialIcons.CalendarToday" Size="IconSize.SM" />
                        <span>@season.StartDate.ToString("MMM d, yyyy")</span>
                        @if (season.EndDate.HasValue)
                        {
                            <span>- @season.EndDate.Value.ToString("MMM d, yyyy")</span>
                        }
                    </div>
                </div>
            </div>
            <div class="flex gap-3">
                <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/seasons"))">
                    <MaterialIcon Icon="MaterialIcons.ArrowBack" Class="mr-1" />
                    Back to Seasons
                </MaterialButton>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8">
        <MaterialTabs @bind-ActiveTab="activeTab"
                      Tabs="@GetNavigationTabs()"
                      ShowContent="false"
                      OnTabChange="HandleTabChange" />
    </div>

    <div class="mt-8"></div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-6">
                <MaterialIcon Icon="MaterialIcons.Event" Class="text-primary-600 text-4xl mb-2" />
                <div class="text-3xl font-bold text-gray-900">@season.EventCount</div>
                <div class="text-sm text-gray-600">Events</div>
            </div>
        </MaterialCard>
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-6">
                <MaterialIcon Icon="MaterialIcons.People" Class="text-primary-600 text-4xl mb-2" />
                <div class="text-3xl font-bold text-gray-900">@season.GolferCount</div>
                <div class="text-sm text-gray-600">Golfers</div>
            </div>
        </MaterialCard>
    </div>

    <!-- Events Section (Placeholder) -->
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">Events</h2>
            <p class="text-gray-600 text-sm">Manage season events and competitions</p>
        </div>
        @if (league != null && season != null && AuthorizationService.CanManageSeason(league.Id, season.Id))
        {
            <MaterialButton Style="MaterialButtonStyle.Filled">
                <MaterialIcon Icon="MaterialIcons.Add" Class="mr-1" />
                Create Event
            </MaterialButton>
        }
    </div>

    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-12">
            <MaterialIcon Icon="MaterialIcons.Event" Class="text-gray-400 text-5xl mb-4" />
            <p class="text-gray-600">Event management coming soon</p>
        </div>
    </MaterialCard>

    <!-- Golfers Section -->
    <div class="mt-12 mb-6 flex items-center justify-between">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">League Players</h2>
            <p class="text-gray-600 text-sm">All players in this league (season-specific participation coming soon)</p>
        </div>
        @if (league != null && season != null && AuthorizationService.CanManageSeason(league.Id, season.Id))
        {
            <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => showAddGolferModal = true)">
                <MaterialIcon Icon="MaterialIcons.PersonAdd" Class="mr-1" />
                Add Player
            </MaterialButton>
        }
    </div>

    @if (isLoadingGolfers)
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-4"></div>
                <p class="text-gray-600">Loading golfers...</p>
            </div>
        </MaterialCard>
    }
    else if (golfers == null || golfers.Count == 0)
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <MaterialIcon Icon="MaterialIcons.GolfCourse" Class="text-gray-400 text-5xl mb-4" />
                <p class="text-gray-600 mb-4">No golfers in this season yet</p>
                @if (league != null && season != null && AuthorizationService.CanManageSeason(league.Id, season.Id))
                {
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => showAddGolferModal = true)">
                        <MaterialIcon Icon="MaterialIcons.PersonAdd" Class="mr-1" />
                        Add First Player
                    </MaterialButton>
                }
            </div>
        </MaterialCard>
    }
    else
    {
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content p-0">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50 border-b border-gray-200">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Player</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Handicap</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rounds</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Avg Score</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Best Score</th>
                                @if (league != null && season != null && AuthorizationService.CanManageSeason(league.Id, season.Id))
                                {
                                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var golfer in golfers)
                            {
                                <tr class="hover:bg-gray-50 transition-colors cursor-pointer" @onclick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/player/{golfer.Id}"))">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 h-10 w-10 bg-primary-100 rounded-full flex items-center justify-center">
                                                <span class="text-primary-700 font-semibold">@GetInitials(golfer.DisplayName)</span>
                                            </div>
                                            <div class="ml-4">
                                                <div class="text-sm font-medium text-gray-900">@golfer.DisplayName</div>
                                                @if (!string.IsNullOrEmpty(golfer.Nickname))
                                                {
                                                    <div class="text-sm text-gray-500">"@golfer.Nickname"</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="text-sm text-gray-900">@(golfer.LeagueHandicap?.ToString("F1") ?? "-")</span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="text-sm text-gray-900">@golfer.TotalRounds</span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="text-sm text-gray-900">@(golfer.AverageScore?.ToString("F1") ?? "-")</span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="text-sm text-gray-900">@(golfer.BestScore?.ToString() ?? "-")</span>
                                    </td>
                                    @if (league != null && season != null && AuthorizationService.CanManageSeason(league.Id, season.Id))
                                    {
                                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                            <MaterialButton Style="MaterialButtonStyle.Text">
                                                <MaterialIcon Icon="MaterialIcons.MoreVert" />
                                            </MaterialButton>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </MaterialCard>
    }

<!-- Add Player Modal -->
@if (showAddGolferModal)
{
    <MaterialDialog @bind-IsOpen="showAddGolferModal" Title="Add Player to League">
        <ChildContent>
            <div class="space-y-6">
                <p class="text-gray-600 text-sm">
                    Add a new player to the league. You can add an existing user or create a new one.
                </p>

                <!-- User Search -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Search by Email (Optional)
                    </label>
                    <div class="flex gap-2">
                        <MaterialInput @bind-Value="newPlayerEmail"
                                     Type="email"
                                     Placeholder="user@example.com"
                                     Class="flex-1" />
                        <MaterialButton Style="MaterialButtonStyle.Outlined"
                                      OnClick="SearchUser"
                                      Disabled="@(string.IsNullOrWhiteSpace(newPlayerEmail) || isSearchingUser)">
                            @if (isSearchingUser)
                            {
                                <span>Searching...</span>
                            }
                            else
                            {
                                <MaterialIcon Icon="MaterialIcons.Search" Class="mr-1" />
                                <span>Search</span>
                            }
                        </MaterialButton>
                    </div>
                    @if (!string.IsNullOrEmpty(userSearchMessage))
                    {
                        <p class="text-sm mt-2 @(userSearchSuccess ? "text-green-600" : "text-gray-600")">
                            @userSearchMessage
                        </p>
                    }
                </div>

                <!-- Player Details -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            First Name @(foundUserId == null ? "(Required)" : "(Optional)")
                        </label>
                        <MaterialInput @bind-Value="newPlayerFirstName"
                                     Placeholder="John" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            Last Name @(foundUserId == null ? "(Required)" : "(Optional)")
                        </label>
                        <MaterialInput @bind-Value="newPlayerLastName"
                                     Placeholder="Doe" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Display Name (Required)
                    </label>
                    <MaterialInput @bind-Value="newPlayerDisplayName"
                                 Placeholder="John Doe"
                                 Required="true" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Nickname (Optional)
                    </label>
                    <MaterialInput @bind-Value="newPlayerNickname"
                                 Placeholder="Johnny" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        League Handicap (Optional)
                    </label>
                    <MaterialInput @bind-Value="newPlayerHandicap"
                                 Type="number"
                                 Placeholder="15.5"
                                 Min="0"
                                 Max="54"
                                 Step="0.1" />
                </div>

                @if (!string.IsNullOrEmpty(addPlayerError))
                {
                    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                        <p class="text-sm text-red-800">@addPlayerError</p>
                    </div>
                }
            </div>
        </ChildContent>
        <Actions>
            <MaterialButton Style="MaterialButtonStyle.Text"
                          OnClick="@(() => { showAddGolferModal = false; ResetAddPlayerForm(); })">
                Cancel
            </MaterialButton>
            <MaterialButton Style="MaterialButtonStyle.Filled"
                          OnClick="HandleAddPlayer"
                          Disabled="@(isAddingPlayer || string.IsNullOrWhiteSpace(newPlayerDisplayName))">
                @if (isAddingPlayer)
                {
                    <span>Adding...</span>
                }
                else
                {
                    <span>Add Player</span>
                }
            </MaterialButton>
        </Actions>
    </MaterialDialog>
}

    <!-- Settings Section -->
    @if (league != null && season != null && AuthorizationService.CanManageSeason(league.Id, season.Id))
    {
        <div class="mt-12 mb-6 flex items-center justify-between">
            <div>
                <h2 class="text-xl font-semibold text-gray-900">Season Settings</h2>
                <p class="text-gray-600 text-sm">Configure scoring formats, handicap settings, and defaults</p>
            </div>
        </div>

        @if (isLoadingSettings)
        {
            <MaterialCard Variant="MaterialCardVariant.Outlined">
                <div class="md-card__content text-center py-12">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-3"></div>
                    <p class="text-gray-600">Loading settings...</p>
                </div>
            </MaterialCard>
        }
        else if (settings == null)
        {
            <MaterialCard Variant="MaterialCardVariant.Outlined">
                <div class="md-card__content text-center py-12">
                    <MaterialIcon Icon="MaterialIcons.Settings" Class="text-gray-400 text-5xl mb-4" />
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">No Settings Configured</h3>
                    <p class="text-gray-600 mb-6">Create default settings to get started</p>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="CreateDefaultSettings" Disabled="@isCreatingSettings">
                        @if (isCreatingSettings)
                        {
                            <span>Creating...</span>
                        }
                        else
                        {
                            <MaterialIcon Icon="MaterialIcons.Add" Class="mr-1" />
                            <span>Create Default Settings</span>
                        }
                    </MaterialButton>
                </div>
            </MaterialCard>
        }
        else
        {
            <MaterialCard Variant="MaterialCardVariant.Outlined">
                <div class="md-card__content p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Handicap Settings -->
                        <div>
                            <h3 class="text-sm font-semibold text-gray-900 mb-4">Handicap Settings</h3>
                            <div class="space-y-3">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Handicap Type</label>
                                    <p class="text-gray-900">@settings.HandicapType</p>
                                </div>
                                @if (settings.MaxHandicap.HasValue)
                                {
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Max Handicap</label>
                                        <p class="text-gray-900">@settings.MaxHandicap</p>
                                    </div>
                                }
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Max Score for Handicap</label>
                                    <p class="text-gray-900">@settings.MaxScoreForHandicap</p>
                                </div>
                            </div>
                        </div>

                        <!-- Scoring Settings -->
                        <div>
                            <h3 class="text-sm font-semibold text-gray-900 mb-4">Scoring Settings</h3>
                            <div class="space-y-3">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Individual Scoring</label>
                                    <p class="text-gray-900">@settings.IndividualScoringType</p>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Team Scoring</label>
                                    <p class="text-gray-900">@settings.TeamScoringType</p>
                                </div>
                            </div>
                        </div>

                        <!-- Missing Player/Team Settings -->
                        <div>
                            <h3 class="text-sm font-semibold text-gray-900 mb-4">Missing Player/Team</h3>
                            <div class="space-y-3">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Missing Player</label>
                                    <p class="text-gray-900">@settings.MissingPlayerType</p>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Missing Team</label>
                                    <p class="text-gray-900">@settings.MissingTeamType</p>
                                </div>
                            </div>
                        </div>

                        <!-- Defaults -->
                        <div>
                            <h3 class="text-sm font-semibold text-gray-900 mb-4">Defaults</h3>
                            <div class="space-y-3">
                                @if (!string.IsNullOrEmpty(settings.DefaultCourseName))
                                {
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Default Course</label>
                                        <p class="text-gray-900">@settings.DefaultCourseName</p>
                                    </div>
                                }
                                @if (settings.DefaultStartTime.HasValue)
                                {
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Default Start Time</label>
                                        <p class="text-gray-900">@settings.DefaultStartTime.Value.ToString("h:mm tt")</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mt-6 pt-6 border-t border-gray-200 flex justify-end">
                        <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="OpenEditSettingsModal">
                            <MaterialIcon Icon="MaterialIcons.Edit" Class="mr-1" />
                            Edit Settings
                        </MaterialButton>
                    </div>
                </div>
            </MaterialCard>
        }
    }

    <!-- Admin Simulation Section -->
    @if (league != null && season != null && AuthorizationService.CanManageSeason(league.Id, season.Id))
    {
        <div class="mt-12 mb-6 flex items-center justify-between">
            <div>
                <h2 class="text-xl font-semibold text-gray-900">Season Simulation</h2>
                <p class="text-gray-600 text-sm">Test and simulate season data for development</p>
            </div>
        </div>

        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content p-6">
                @if (!string.IsNullOrEmpty(simulationMessage))
                {
                    <div class="mb-4 p-4 @(simulationSuccess ? "bg-green-50 border-green-200" : "bg-red-50 border-red-200") border rounded-lg">
                        <p class="text-sm @(simulationSuccess ? "text-green-800" : "text-red-800")">@simulationMessage</p>
                    </div>
                }

                <div class="space-y-4">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-900 mb-3">Seed Season Data</h3>
                        <p class="text-sm text-gray-600 mb-4">Generate 60 players with realistic handicaps, create 3-man teams, and schedule 16 weekly events</p>
                        <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="SeedSeason" Disabled="@isSimulating">
                            @if (isSimulating)
                            {
                                <span>Seeding...</span>
                            }
                            else
                            {
                                <MaterialIcon Icon="MaterialIcons.GroupAdd" Class="mr-1" />
                                <span>Seed Season (60 Players)</span>
                            }
                        </MaterialButton>
                    </div>

                    <div class="border-t border-gray-200 pt-4">
                        <h3 class="text-sm font-semibold text-gray-900 mb-3">Simulate Scores</h3>
                        <p class="text-sm text-gray-600 mb-4">Generate realistic hole-by-hole scores for events</p>
                        <div class="flex gap-3">
                            <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="SimulateNextEvent" Disabled="@isSimulating">
                                @if (isSimulating)
                                {
                                    <span>Simulating...</span>
                                }
                                else
                                {
                                    <MaterialIcon Icon="MaterialIcons.PlayArrow" Class="mr-1" />
                                    <span>Simulate Next Event</span>
                                }
                            </MaterialButton>
                            <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="SimulateAllEvents" Disabled="@isSimulating">
                                @if (isSimulating)
                                {
                                    <span>Simulating...</span>
                                }
                                else
                                {
                                    <MaterialIcon Icon="MaterialIcons.FastForward" Class="mr-1" />
                                    <span>Simulate All Events</span>
                                }
                            </MaterialButton>
                        </div>
                    </div>

                    <div class="border-t border-gray-200 pt-4">
                        <h3 class="text-sm font-semibold text-gray-900 mb-3">Clear Data</h3>
                        <p class="text-sm text-gray-600 mb-4">Remove all simulated players, teams, events, and scores</p>
                        <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="ClearSeasonData" Disabled="@isSimulating">
                            @if (isSimulating)
                            {
                                <span>Clearing...</span>
                            }
                            else
                            {
                                <MaterialIcon Icon="MaterialIcons.Delete" Class="mr-1" />
                                <span>Clear Season Data</span>
                            }
                        </MaterialButton>
                    </div>
                </div>
            </div>
        </MaterialCard>
    }

    <!-- Edit Settings Modal -->
    @if (showEditSettingsModal && settings != null)
    {
        <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50" @onclick="@(() => showEditSettingsModal = false)">
            <div class="bg-white rounded-lg shadow-xl max-w-4xl w-full max-h-[90vh] overflow-y-auto" @onclick:stopPropagation="true">
                <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
                    <h2 class="text-xl font-semibold text-gray-900">Edit Season Settings</h2>
                    <button @onclick="@(() => showEditSettingsModal = false)" class="text-gray-400 hover:text-gray-600">
                        <MaterialIcon Icon="MaterialIcons.Close" />
                    </button>
                </div>

                <div class="p-6">
                    @if (!string.IsNullOrEmpty(editSettingsError))
                    {
                        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
                            <p class="text-sm text-red-800">@editSettingsError</p>
                        </div>
                    }

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Handicap Settings -->
                        <div class="md:col-span-2">
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Handicap Settings</h3>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Handicap Type</label>
                            <select @bind="editHandicapType" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                @foreach (var type in Enum.GetValues<HandicapType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Max Handicap</label>
                            <input type="number" @bind="editMaxHandicap" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" placeholder="e.g., 18" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Max Score for Handicap</label>
                            <select @bind="editMaxScoreForHandicap" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                @foreach (var type in Enum.GetValues<MaxScoreForHandicap>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>

                        <!-- Scoring Settings -->
                        <div class="md:col-span-2 mt-4">
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Scoring Settings</h3>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Individual Scoring Type</label>
                            <select @bind="editIndividualScoringType" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                @foreach (var type in Enum.GetValues<IndividualScoringType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Team Scoring Type</label>
                            <select @bind="editTeamScoringType" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                @foreach (var type in Enum.GetValues<TeamScoringType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>

                        <!-- Missing Player/Team Settings -->
                        <div class="md:col-span-2 mt-4">
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Missing Player/Team Handling</h3>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Missing Player Type</label>
                            <select @bind="editMissingPlayerType" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                @foreach (var type in Enum.GetValues<MissingPlayerType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Missing Team Type</label>
                            <select @bind="editMissingTeamType" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                                @foreach (var type in Enum.GetValues<MissingTeamType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>

                        <!-- Default Settings -->
                        <div class="md:col-span-2 mt-4">
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Default Settings</h3>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Default Start Time</label>
                            <input type="time" value="@editDefaultStartTime" @onchange="@((e) => editDefaultStartTime = e.Value?.ToString())" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
                        </div>
                    </div>
                </div>

                <div class="sticky bottom-0 bg-gray-50 border-t border-gray-200 px-6 py-4 flex justify-end gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => showEditSettingsModal = false)" Disabled="@isSavingSettings">
                        Cancel
                    </MaterialButton>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="SaveSettings" Disabled="@isSavingSettings">
                        @if (isSavingSettings)
                        {
                            <span>Saving...</span>
                        }
                        else
                        {
                            <MaterialIcon Icon="MaterialIcons.Save" Class="mr-1" />
                            <span>Save Settings</span>
                        }
                    </MaterialButton>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public string LeagueKey { get; set; } = string.Empty;

    [Parameter]
    public string SeasonKey { get; set; } = string.Empty;

    private LeagueResponse? league;
    private SeasonResponse? season;
    private List<PlayerResponse> golfers = new();
    private bool isLoading = true;
    private bool isLoadingGolfers = false;

    // Season Settings State
    private SeasonSettingsResponse? settings;
    private bool isLoadingSettings = false;
    private bool isCreatingSettings = false;
    private bool showEditSettingsModal = false;
    private bool isSavingSettings = false;
    private string editSettingsError = string.Empty;

    // Edit Settings Form State
    private HandicapType editHandicapType;
    private int? editMaxHandicap;
    private MaxScoreForHandicap editMaxScoreForHandicap;
    private IndividualScoringType editIndividualScoringType;
    private TeamScoringType editTeamScoringType;
    private MissingPlayerType editMissingPlayerType;
    private MissingTeamType editMissingTeamType;
    private string? editDefaultStartTime;

    // Simulation State
    private bool isSimulating = false;
    private string simulationMessage = string.Empty;
    private bool simulationSuccess = false;

    // Add Player Modal State
    private bool showAddGolferModal = false;
    private string newPlayerEmail = string.Empty;
    private string newPlayerFirstName = string.Empty;
    private string newPlayerLastName = string.Empty;
    private string newPlayerDisplayName = string.Empty;
    private string newPlayerNickname = string.Empty;
    private string? newPlayerHandicap;
    private string? foundUserId;

    // Tab navigation
    private string activeTab = "overview";
    private bool isSearchingUser = false;
    private bool isAddingPlayer = false;
    private string userSearchMessage = string.Empty;
    private bool userSearchSuccess = false;
    private string addPlayerError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        // Initialize authorization service
        await AuthorizationService.InitializeAsync();

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            // Use seed data - find league by key
            var seedLeague = SeedData.Leagues.FirstOrDefault(l => l.Key == LeagueKey);
            if (seedLeague != null)
            {
                league = new LeagueResponse
                {
                    Id = seedLeague.Id,
                    Key = seedLeague.Key,
                    Name = seedLeague.Name,
                    Description = seedLeague.Description,
                    MemberCount = seedLeague.MemberCount,
                    PlayerCount = seedLeague.MemberCount,
                    SeasonCount = SeedData.Seasons.Count(s => s.LeagueId == seedLeague.Id),
                    IsCurrentUserAdmin = seedLeague.AdminUserId == AuthService.UserId || AuthService.IsGlobalAdmin,
                    CreatedAt = seedLeague.CreatedDate
                };

                // Find season by key
                var seedSeason = SeedData.Seasons.FirstOrDefault(s => s.LeagueId == seedLeague.Id && s.Key == SeasonKey);
                if (seedSeason != null)
                {
                    var eventCount = SeedData.Events.Count(e => e.SeasonId == seedSeason.Id);

                    season = new SeasonResponse
                    {
                        Id = seedSeason.Id,
                        LeagueId = seedSeason.LeagueId,
                        Key = seedSeason.Key,
                        Name = seedSeason.Name,
                        StartDate = DateOnly.FromDateTime(seedSeason.StartDate),
                        EndDate = DateOnly.FromDateTime(seedSeason.EndDate),
                        IsLocked = !seedSeason.IsActive,
                        EventCount = eventCount,
                        CreatedAt = seedSeason.StartDate
                    };

                    // Load golfers
                    await LoadGolfers();
                }
            }

            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading season data");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadGolfers()
    {
        if (league == null) return;

        isLoadingGolfers = true;
        try
        {
            // Use seed data - get players who have played in this league's events
            var playerIds = SeedData.Rounds
                .Where(r => SeedData.Events.Any(e => e.Id == r.EventId && e.LeagueId == league.Id))
                .Select(r => r.PlayerId)
                .Distinct()
                .ToList();

            golfers = SeedData.Users
                .Where(u => playerIds.Contains(u.Id))
                .Select(u => new PlayerResponse
                {
                    Id = u.Id,
                    UserId = u.Id,
                    LeagueId = league.Id,
                    DisplayName = $"{u.FirstName} {u.LastName}",
                    Email = u.Email,
                    LeagueHandicap = (double)u.Handicap,
                    TotalRounds = SeedData.Rounds.Count(r => r.PlayerId == u.Id),
                    JoinedAt = u.JoinedDate
                }).ToList();

            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading golfers");
        }
        finally
        {
            isLoadingGolfers = false;
        }
    }

    private string GetInitials(string displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
            return "?";

        var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
            return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();

        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private async Task SearchUser()
    {
        if (string.IsNullOrWhiteSpace(newPlayerEmail))
            return;

        isSearchingUser = true;
        userSearchMessage = string.Empty;
        userSearchSuccess = false;
        foundUserId = null;

        try
        {
            var response = await UserService.SearchByEmailAsync(newPlayerEmail);
            if (response?.Success == true && response.Data != null)
            {
                if (response.Data.Exists)
                {
                    foundUserId = response.Data.Id;
                    userSearchMessage = $"User found: {response.Data.Email}";
                    userSearchSuccess = true;

                    // Auto-fill display name if available
                    if (!string.IsNullOrEmpty(response.Data.FirstName) && !string.IsNullOrEmpty(response.Data.LastName))
                    {
                        if (string.IsNullOrWhiteSpace(newPlayerDisplayName))
                        {
                            newPlayerDisplayName = $"{response.Data.FirstName} {response.Data.LastName}";
                        }
                    }
                }
                else
                {
                    userSearchMessage = "User not found. A new account will be created.";
                    userSearchSuccess = false;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching for user");
            userSearchMessage = "Error searching for user";
        }
        finally
        {
            isSearchingUser = false;
        }
    }

    private async Task HandleAddPlayer()
    {
        if (league == null || string.IsNullOrWhiteSpace(newPlayerDisplayName))
            return;

        isAddingPlayer = true;
        addPlayerError = string.Empty;

        try
        {
            var request = new CreatePlayerRequest
            {
                UserId = foundUserId,
                Email = string.IsNullOrWhiteSpace(newPlayerEmail) ? null : newPlayerEmail,
                FirstName = string.IsNullOrWhiteSpace(newPlayerFirstName) ? null : newPlayerFirstName,
                LastName = string.IsNullOrWhiteSpace(newPlayerLastName) ? null : newPlayerLastName,
                DisplayName = newPlayerDisplayName,
                Nickname = string.IsNullOrWhiteSpace(newPlayerNickname) ? null : newPlayerNickname,
                LeagueHandicap = string.IsNullOrWhiteSpace(newPlayerHandicap) ? null : double.Parse(newPlayerHandicap)
            };

            var response = await PlayerService.AddPlayerToLeagueAsync(league.Id, request);

            if (response?.Success == true)
            {
                showAddGolferModal = false;
                ResetAddPlayerForm();
                await LoadGolfers(); // Reload the golfer list
            }
            else
            {
                addPlayerError = response?.Message ?? "Failed to add player";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding player");
            addPlayerError = ex.Message;
        }
        finally
        {
            isAddingPlayer = false;
        }
    }

    private void ResetAddPlayerForm()
    {
        newPlayerEmail = string.Empty;
        newPlayerFirstName = string.Empty;
        newPlayerLastName = string.Empty;
        newPlayerDisplayName = string.Empty;
        newPlayerNickname = string.Empty;
        newPlayerHandicap = null;
        foundUserId = null;
        userSearchMessage = string.Empty;
        userSearchSuccess = false;
        addPlayerError = string.Empty;
    }

    // Season Settings Methods
    private async Task LoadSettings()
    {
        if (league == null || season == null) return;

        isLoadingSettings = true;
        try
        {
            settings = await SeasonSettingsService.GetSeasonSettingsAsync(league.Id, season.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading season settings");
        }
        finally
        {
            isLoadingSettings = false;
        }
    }

    private async Task CreateDefaultSettings()
    {
        if (league == null || season == null) return;

        isCreatingSettings = true;
        try
        {
            var response = await SeasonSettingsService.CreateDefaultSettingsAsync(league.Id, season.Id);
            if (response?.Success == true && response.Data != null)
            {
                settings = response.Data;
            }
            else
            {
                Logger.LogError("Failed to create default settings: {Message}", response?.Message);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating default settings");
        }
        finally
        {
            isCreatingSettings = false;
        }
    }

    private void OpenEditSettingsModal()
    {
        if (settings == null) return;

        // Populate form with current settings
        editHandicapType = settings.HandicapType;
        editMaxHandicap = settings.MaxHandicap;
        editMaxScoreForHandicap = settings.MaxScoreForHandicap;
        editIndividualScoringType = settings.IndividualScoringType;
        editTeamScoringType = settings.TeamScoringType;
        editMissingPlayerType = settings.MissingPlayerType;
        editMissingTeamType = settings.MissingTeamType;
        editDefaultStartTime = settings.DefaultStartTime?.ToString("HH:mm");
        editSettingsError = string.Empty;

        showEditSettingsModal = true;
    }

    private async Task SaveSettings()
    {
        if (league == null || season == null || settings == null) return;

        isSavingSettings = true;
        editSettingsError = string.Empty;

        try
        {
            var request = new UpdateSeasonSettingsRequest
            {
                HandicapType = editHandicapType,
                MaxHandicap = editMaxHandicap,
                MaxScoreForHandicap = editMaxScoreForHandicap,
                IndividualScoringType = editIndividualScoringType,
                TeamScoringType = editTeamScoringType,
                MissingPlayerType = editMissingPlayerType,
                MissingTeamType = editMissingTeamType,
                DefaultStartTime = !string.IsNullOrEmpty(editDefaultStartTime)
                    ? TimeOnly.Parse(editDefaultStartTime)
                    : null
            };

            var response = await SeasonSettingsService.UpdateSeasonSettingsAsync(league.Id, season.Id, request);
            if (response?.Success == true && response.Data != null)
            {
                settings = response.Data;
                showEditSettingsModal = false;
            }
            else
            {
                editSettingsError = response?.Message ?? "Failed to save settings";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving settings");
            editSettingsError = ex.Message;
        }
        finally
        {
            isSavingSettings = false;
        }
    }

    // Simulation Methods
    private async Task SeedSeason()
    {
        if (league == null || season == null) return;

        isSimulating = true;
        simulationMessage = string.Empty;
        simulationSuccess = false;

        try
        {
            var response = await Http.PostAsJsonAsync(
                $"/api/v1/leagues/{league.Id}/seasons/{season.Id}/simulation/seed",
                new { PlayerCount = 60, PlayersPerTeam = 3, WeekCount = 16 });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<SimulationResult>>();
                if (result?.Success == true)
                {
                    simulationMessage = result.Data?.Message ?? "Season seeded successfully!";
                    simulationSuccess = true;

                    // Reload season data
                    await LoadData();
                }
                else
                {
                    simulationMessage = result?.Message ?? "Failed to seed season";
                    simulationSuccess = false;
                }
            }
            else
            {
                simulationMessage = $"Error: {response.StatusCode}";
                simulationSuccess = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error seeding season");
            simulationMessage = ex.Message;
            simulationSuccess = false;
        }
        finally
        {
            isSimulating = false;
        }
    }

    private async Task SimulateNextEvent()
    {
        if (league == null || season == null) return;

        isSimulating = true;
        simulationMessage = string.Empty;
        simulationSuccess = false;

        try
        {
            var response = await Http.PostAsync(
                $"/api/v1/leagues/{league.Id}/seasons/{season.Id}/simulation/simulate-next",
                null);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<SimulationResult>>();
                if (result?.Success == true)
                {
                    simulationMessage = result.Data?.Message ?? "Event simulated successfully!";
                    simulationSuccess = true;
                }
                else
                {
                    simulationMessage = result?.Message ?? "Failed to simulate event";
                    simulationSuccess = false;
                }
            }
            else
            {
                simulationMessage = $"Error: {response.StatusCode}";
                simulationSuccess = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error simulating next event");
            simulationMessage = ex.Message;
            simulationSuccess = false;
        }
        finally
        {
            isSimulating = false;
        }
    }

    private async Task SimulateAllEvents()
    {
        if (league == null || season == null) return;

        isSimulating = true;
        simulationMessage = string.Empty;
        simulationSuccess = false;

        try
        {
            var response = await Http.PostAsync(
                $"/api/v1/leagues/{league.Id}/seasons/{season.Id}/simulation/simulate-all",
                null);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<SimulationResult>>();
                if (result?.Success == true)
                {
                    simulationMessage = result.Data?.Message ?? "All events simulated successfully!";
                    simulationSuccess = true;
                }
                else
                {
                    simulationMessage = result?.Message ?? "Failed to simulate events";
                    simulationSuccess = false;
                }
            }
            else
            {
                simulationMessage = $"Error: {response.StatusCode}";
                simulationSuccess = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error simulating all events");
            simulationMessage = ex.Message;
            simulationSuccess = false;
        }
        finally
        {
            isSimulating = false;
        }
    }

    private async Task ClearSeasonData()
    {
        if (league == null || season == null) return;

        isSimulating = true;
        simulationMessage = string.Empty;
        simulationSuccess = false;

        try
        {
            var response = await Http.DeleteAsync(
                $"/api/v1/leagues/{league.Id}/seasons/{season.Id}/simulation/clear");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<SimulationResult>>();
                if (result?.Success == true)
                {
                    simulationMessage = result.Data?.Message ?? "Season data cleared successfully!";
                    simulationSuccess = true;

                    // Reload season data
                    await LoadData();
                }
                else
                {
                    simulationMessage = result?.Message ?? "Failed to clear season data";
                    simulationSuccess = false;
                }
            }
            else
            {
                simulationMessage = $"Error: {response.StatusCode}";
                simulationSuccess = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error clearing season data");
            simulationMessage = ex.Message;
            simulationSuccess = false;
        }
        finally
        {
            isSimulating = false;
        }
    }

    private List<MaterialTab> GetNavigationTabs()
    {
        var tabs = new List<MaterialTab>
        {
            new MaterialTab
            {
                Value = "overview",
                Label = "Overview",
                Icon = @<MaterialIcon Icon="MaterialIcons.Dashboard" Size="IconSize.SM" />
            },
            new MaterialTab
            {
                Value = "events",
                Label = "Events",
                Icon = @<MaterialIcon Icon="MaterialIcons.Event" Size="IconSize.SM" />
            },
            new MaterialTab
            {
                Value = "standings",
                Label = "Standings",
                Icon = @<MaterialIcon Icon="MaterialIcons.Leaderboard" Size="IconSize.SM" />
            },
            new MaterialTab
            {
                Value = "players",
                Label = "Players",
                Icon = @<MaterialIcon Icon="MaterialIcons.People" Size="IconSize.SM" />
            }
        };

        // Only show Settings tab to admins (Global Admin OR League Admin OR Season Admin)
        if (league != null && season != null && AuthorizationService.CanManageSeason(league.Id, season.Id))
        {
            tabs.Add(new MaterialTab
            {
                Value = "settings",
                Label = "Settings",
                Icon = @<MaterialIcon Icon="MaterialIcons.Settings" Size="IconSize.SM" />
            });
        }

        return tabs;
    }

    private void HandleTabChange(string tabValue)
    {
        var route = tabValue switch
        {
            "overview" => $"/league/{LeagueKey}/season/{SeasonKey}",
            "events" => $"/league/{LeagueKey}/season/{SeasonKey}/events",
            "standings" => $"/league/{LeagueKey}/season/{SeasonKey}/standings",
            "players" => $"/league/{LeagueKey}/season/{SeasonKey}/players",
            "settings" => $"/league/{LeagueKey}/season/{SeasonKey}/settings",
            _ => $"/league/{LeagueKey}/season/{SeasonKey}"
        };

        Navigation.NavigateTo(route);
    }
}
