@page "/players"
@layout AppLayout
@using GolfManager.Web.Services
@inject IAuthService AuthService
@inject SeedDataService SeedData
@inject NavigationManager Navigation
@inject ILogger<Players> Logger

<PageTitle>Browse Players - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading players...</p>
        </div>
    </div>
}
else
{
    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Browse Players</h1>
        <p class="text-gray-600">Find and connect with other golfers</p>
    </div>

    <!-- Search and Filters -->
    <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Search -->
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-2">Search Players</label>
                <input type="text" 
                       @bind="searchQuery" 
                       @bind:event="oninput"
                       placeholder="Search by name or email..."
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
            </div>
            
            <!-- Handicap Filter -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Handicap Range</label>
                <select @bind="handicapFilter" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
                    <option value="all">All Handicaps</option>
                    <option value="scratch">Scratch (0-5)</option>
                    <option value="low">Low (6-12)</option>
                    <option value="mid">Mid (13-20)</option>
                    <option value="high">High (21+)</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Players Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var player in filteredPlayers)
        {
            <div class="bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-md transition-all cursor-pointer"
                 @onclick="@(() => Navigation.NavigateTo($"/player/{player.Id}"))">
                <div class="p-6">
                    <!-- Avatar -->
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-16 h-16 bg-primary-600 rounded-full flex items-center justify-center text-white text-xl font-semibold flex-shrink-0">
                            @GetInitials(player.FirstName, player.LastName)
                        </div>
                        <div class="flex-1 min-w-0">
                            <h3 class="font-semibold text-gray-900 truncate">@player.FirstName @player.LastName</h3>
                            <p class="text-sm text-gray-600 truncate">@player.Email</p>
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="grid grid-cols-2 gap-4 pt-4 border-t border-gray-200">
                        <div>
                            <p class="text-sm text-gray-600">Handicap</p>
                            <p class="text-lg font-semibold text-gray-900">@player.Handicap</p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-600">Rounds</p>
                            <p class="text-lg font-semibold text-gray-900">@player.TotalRounds</p>
                        </div>
                    </div>

                    <!-- Leagues -->
                    @if (player.Leagues.Any())
                    {
                        <div class="mt-4 pt-4 border-t border-gray-200">
                            <p class="text-sm text-gray-600 mb-2">Member of:</p>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var league in player.Leagues.Take(3))
                                {
                                    <span class="px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded">@league</span>
                                }
                                @if (player.Leagues.Count > 3)
                                {
                                    <span class="px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded">+@(player.Leagues.Count - 3) more</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @if (!filteredPlayers.Any())
    {
        <div class="text-center py-16">
            <MaterialIcon Path="@MaterialIcons.Person" Size="MaterialComponents.Icons.IconSize.XL" Class="text-gray-400 mb-4" />
            <h3 class="text-lg font-semibold text-gray-900 mb-2">No players found</h3>
            <p class="text-gray-600">Try adjusting your search or filters</p>
        </div>
    }
}

@code {
    private bool isLoading = true;
    private string searchQuery = string.Empty;
    private string handicapFilter = "all";
    private List<MockPlayer> allPlayers = new();

    private List<MockPlayer> filteredPlayers => allPlayers
        .Where(p => string.IsNullOrEmpty(searchQuery) || 
                    p.FirstName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.LastName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.Email.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(p => handicapFilter == "all" || FilterByHandicap(p.Handicap, handicapFilter))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            // Use seed data - convert to MockPlayer format for display
            // Filter out admin users (first 2 users are admins)
            allPlayers = SeedData.Users
                .Where(u => !u.IsGlobalAdmin)
                .Select(u => new MockPlayer
                {
                    Id = u.Id,
                    FirstName = u.FirstName,
                    LastName = u.LastName,
                    Email = u.Email,
                    Handicap = u.Handicap,
                    TotalRounds = SeedData.Rounds.Count(r => r.PlayerId == u.Id),
                    Leagues = SeedData.Leagues
                        .Where(l => SeedData.Seasons.Any(s => s.LeagueId == l.Id &&
                                   SeedData.Events.Any(e => e.SeasonId == s.Id &&
                                   SeedData.Rounds.Any(r => r.EventId == e.Id && r.PlayerId == u.Id))))
                        .Select(l => l.Name)
                        .Distinct()
                        .ToList()
                }).ToList();

            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading players");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetInitials(string firstName, string lastName)
    {
        var first = !string.IsNullOrEmpty(firstName) ? firstName[0].ToString() : "";
        var last = !string.IsNullOrEmpty(lastName) ? lastName[0].ToString() : "";
        return $"{first}{last}".ToUpper();
    }

    private bool FilterByHandicap(decimal handicap, string filter)
    {
        return filter switch
        {
            "scratch" => handicap >= 0 && handicap <= 5,
            "low" => handicap >= 6 && handicap <= 12,
            "mid" => handicap >= 13 && handicap <= 20,
            "high" => handicap >= 21,
            _ => true
        };
    }



    private class MockPlayer
    {
        public string Id { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public decimal Handicap { get; set; }
        public int TotalRounds { get; set; }
        public List<string> Leagues { get; set; } = new();
    }
}

