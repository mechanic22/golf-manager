
<div class="bg-white rounded-lg border border-gray-200 p-6 hover:shadow-md transition-shadow">
    <!-- Icon & Label -->
    <div class="flex items-start justify-between mb-4">
        <div class="flex items-center gap-3">
            @if (!string.IsNullOrEmpty(Icon))
            {
                <div class="p-2 bg-gradient-to-br @IconBgGradient rounded-lg">
                    <Icon Path="@Icon" Size="GolfManager.Web.Shared.Icons.IconSize.MD" Class="@IconColor" />
                </div>
            }
            <div>
                <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">@Label</p>
                <p class="text-sm text-gray-600">@Description</p>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Badge))
        {
            <span class="px-2 py-1 text-xs font-medium bg-blue-100 text-blue-700 rounded-full">@Badge</span>
        }
    </div>

    <!-- Value -->
    <div class="flex items-baseline gap-2">
        <span class="text-3xl font-bold text-gray-900">@Value</span>
        @if (!string.IsNullOrEmpty(Unit))
        {
            <span class="text-sm text-gray-600">@Unit</span>
        }
    </div>

    <!-- Trend (optional) -->
    @if (!string.IsNullOrEmpty(Trend))
    {
        <div class="mt-3 text-xs">
            @if (Trend.StartsWith("+"))
            {
                <span class="text-green-600 font-medium">@Trend vs last season</span>
            }
            else if (Trend.StartsWith("-"))
            {
                <span class="text-red-600 font-medium">@Trend vs last season</span>
            }
        </div>
    }

    <!-- Footer (optional) -->
    @if (!string.IsNullOrEmpty(Footer))
    {
        <div class="mt-4 pt-4 border-t border-gray-100">
            <p class="text-xs text-gray-500">@Footer</p>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string? Unit { get; set; }

    [Parameter]
    public string? Trend { get; set; }

    [Parameter]
    public string? Footer { get; set; }

    [Parameter]
    public string? Icon { get; set; }

    [Parameter]
    public string IconColor { get; set; } = "text-blue-600";

    [Parameter]
    public string IconBgGradient { get; set; } = "from-blue-100 to-blue-50";

    [Parameter]
    public string? Badge { get; set; }
}
