@using GolfManager.Shared.DTOs.League
@using GolfManager.Shared.DTOs.Season
@inject NavigationManager Navigation

<div class="group bg-white rounded-lg border border-gray-200 overflow-hidden hover:shadow-lg transition-all hover:border-gray-300 flex flex-col cursor-pointer"
     @onclick="@(() => Navigation.NavigateTo($"/league/{League.Key}"))">
    <!-- Thin color accent -->
    <div class="h-1 bg-primary-500"></div>

    <div class="p-5 flex-1 flex flex-col">
        <!-- League name + admin badge -->
        <div class="flex items-start justify-between gap-2 mb-1">
            <h3 class="text-base font-semibold text-gray-900 truncate">@League.Name</h3>
            @if (IsCurrentUserAdmin)
            {
                <span class="shrink-0 px-1.5 py-0.5 text-xs font-medium bg-primary-100 text-primary-700 rounded">Admin</span>
            }
        </div>

        <!-- League key -->
        <p class="text-xs text-gray-400 font-mono mb-3">@League.Key</p>

        <!-- Season chip -->
        @if (Season != null)
        {
            <div class="mb-3">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200 rounded-full">
                    @if (Season.IsLocked)
                    {
                        <Icon Path="@GolfIcons.Lock" Size="GolfManager.Web.Shared.Icons.IconSize.XS" CssClass="text-blue-500" />
                        <span>@Season.Name — Locked</span>
                    }
                    else
                    {
                        <Icon Path="@GolfIcons.Check" Size="GolfManager.Web.Shared.Icons.IconSize.XS" CssClass="text-blue-500" />
                        <span>@Season.Name</span>
                    }
                </span>
            </div>
        }
        else
        {
            <p class="mb-3 text-xs text-gray-400">No active season</p>
        }

        <!-- Description -->
        @if (!string.IsNullOrEmpty(League.Description))
        {
            <p class="text-sm text-gray-500 mb-3 line-clamp-2">@League.Description</p>
        }

        <!-- Per-user stats -->
        @if (League.CurrentUserRoundsInLeague.HasValue)
        {
            <div class="flex items-center gap-4 mb-3 text-xs text-gray-500">
                <span>@League.CurrentUserRoundsInLeague rounds</span>
                @if (League.CurrentUserLeagueHandicap.HasValue)
                {
                    <span class="w-px h-3 bg-gray-200 inline-block"></span>
                    <span>HCP @League.CurrentUserLeagueHandicap.Value.ToString("F1")</span>
                }
            </div>
        }

        <!-- Action buttons pinned to bottom -->
        <div class="flex gap-2 mt-auto pt-3 border-t border-gray-100" @onclick:stopPropagation>
            <a href="@($"/league/{League.Key}")"
               class="flex-1 px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors text-center">
                View League
            </a>
            @if (Season != null)
            {
                <a href="@($"/league/{League.Key}/season/{Season.Key}/standings")"
                   class="flex-1 px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-center">
                    Standings
                </a>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public LeagueResponse League { get; set; } = null!;

    [Parameter]
    public SeasonResponse? Season { get; set; }

    [Parameter]
    public bool IsCurrentUserAdmin { get; set; }
}
