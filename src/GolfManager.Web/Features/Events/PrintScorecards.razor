@page "/league/{LeagueKey}/season/{SeasonKey}/event/{EventKey}/scorecards"
@layout EventLayout
@using GolfManager.Core.Enums
@using GolfManager.Shared.DTOs.Course
@using GolfManager.Shared.DTOs.Event
@using GolfManager.Shared.DTOs.Player
@using GolfManager.Shared.DTOs.Season

<PageTitle>Print Scorecards - @(seasonEvent?.Name ?? "Event") - Pinzo</PageTitle>

<style>
    @@media print {
        @@page {
            margin: 0.2in;
            padding: 0;
        }

        .no-print, .no-print * {
            display: none !important;
        }

        /* Strip AppLayout main container padding so cards fill the page */
        main {
            max-width: none !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        .container {
            max-width: none !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        .page-break {
            display: block !important;
            height: 0;
            break-before: page;
            page-break-before: always;
            break-inside: avoid;
        }

        .scorecard-print-card {
            overflow: visible !important;
            break-inside: avoid-page;
            page-break-inside: avoid;
            margin-top: 6px !important;
            border: 1px solid #aaa !important;
            border-radius: 0 !important;
            padding: 4px !important;
        }

        .scorecard-print-card.page-break {
            break-before: page;
            page-break-before: always;
            margin-top: 0 !important;
        }

        .summary-print-card {
            break-after: page;
            page-break-after: always;
            break-inside: avoid-page;
            page-break-inside: avoid;
            border: 1px solid #aaa !important;
            border-radius: 0 !important;
        }

        table.scorecard {
            break-inside: avoid-page;
            page-break-inside: avoid;
            font-size: 0.62rem !important;
        }

        table.scorecard td, table.scorecard th {
            padding: 2px 3px !important;
            border-left: 1px solid #000 !important;
        }

        .highlight {
            background-color: rgb(254 240 138) !important;
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }
    }

    .highlight {
        background-color: #fef08a;
    }

    .scorecard-print-card {
        border: 1px solid #d1d5db;
        border-radius: 4px;
        background: white;
        padding: 8px;
    }

    .summary-print-card {
        background: white;
    }

    table.scorecard {
        border-collapse: collapse;
        width: 100%;
        font-size: 0.72rem;
    }

    table.scorecard th, table.scorecard td {
        border: 1px solid #d1d5db;
        padding: 3px 4px;
    }

    tr.no-border th, tr.no-border td {
        border: none;
    }

    tr.spacer td, tr.spacer th {
        border-top: none;
        border-bottom: none;
    }
</style>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading printable scorecards...</p>
        </div>
    </div>
}
else if (accessDenied)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Lock" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Access Denied</h2>
                <p class="text-gray-600 mb-8">You must be a league admin to view scorecards.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/events"))">
                    Back to Events
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else if (seasonEvent == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Event Not Found</h2>
                <p class="text-gray-600 mb-8">Could not load event scorecards for printing.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/events"))">
                    Back to Events
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="container m-auto">

        @* Summary page — all matchups with starting holes, prints as page 1 *@
        <div class="summary-print-card mt-4 border border-gray-300 p-4 bg-white">
            <table class="w-full">
                <thead>
                    <tr class="no-print">
                        <th colspan="3" class="pb-4">
                            <div class="flex gap-2">
                                <button type="button"
                                        class="px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700"
                                        onclick="window.print()">
                                    Print Now
                                </button>
                                <MaterialButton Style="MaterialButtonStyle.Outlined"
                                               OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/events"))">
                                    Back
                                </MaterialButton>
                            </div>
                        </th>
                    </tr>
                    <tr>
                        <th colspan="3" class="text-lg text-center pb-2">
                            @league?.Name<br />
                            @seasonEvent.EventDate.ToString("MMMM d, yyyy")
                        </th>
                    </tr>
                </thead>
                <tbody class="text-xs lg:text-sm">
                    @if (matchups.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-center py-8 text-gray-500">
                                No matchups found. Generate matchups first, then return here to print scorecards.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var m in matchups.OrderBy(x => x.StartingHole).ThenBy(x => x.StartingFlight))
                        {
                            <tr>
                                <td class="text-right py-1" style="width:45%">
                                    <div class="text-xl">@GetTeamName(m.HomeTeamId, m.HomeTeamName)</div>
                                    <div class="text-xs text-gray-600">@string.Join(" / ", GetTeamMembers(m.HomeTeamId).Select(x => x.DisplayName))</div>
                                </td>
                                <td class="text-center font-bold text-xl py-1" style="width:10%">
                                    @m.StartingHole@DigitToLetter(m.StartingFlight ?? 0)
                                </td>
                                <td class="text-left py-1" style="width:45%">
                                    <div class="text-xl">@GetTeamName(m.AwayTeamId, m.AwayTeamName)</div>
                                    <div class="text-xs text-gray-600">@string.Join(" / ", GetTeamMembers(m.AwayTeamId).Select(x => x.DisplayName))</div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (tee == null)
        {
            <div class="no-print mt-4 p-4 bg-amber-100 border border-amber-300 rounded text-amber-800">
                No course/tee configured for this event — scorecards will not show hole data.
            </div>
        }

        @{
            const string highlight = " highlight";
            var index = 0;

            foreach (var match in matchups.OrderBy(x => x.StartingHole).ThenBy(x => x.StartingFlight))
            {
                bool isFront = (match.StartingHole ?? 1) <= 9;
                var paceTimeline = BuildPaceTimeline(match);
                var breakClass = (index % 2 == 0) ? " page-break" : string.Empty;
                var homeMembers = GetTeamMembers(match.HomeTeamId).ToList();
                var awayMembers = GetTeamMembers(match.AwayTeamId).ToList();

                <div class="mt-4 scorecard-print-card@breakClass">
                    <table class="scorecard">
                        <thead>
                            <tr class="no-border">
                                <td colspan="4" class="text-sm">
                                    @league?.Name @seasonEvent.EventDate.ToString("MMMM d, yyyy h:mm tt")
                                </td>
                                <td colspan="7" class="text-sm text-right">
                                    @GetTeamName(match.HomeTeamId, match.HomeTeamName) vs @GetTeamName(match.AwayTeamId, match.AwayTeamName)
                                </td>
                            </tr>
                            <tr>
                                <th style="width:25%" class="text-left">Hole</th>
                                @for (int i = isFront ? 1 : 10; i <= (isFront ? 9 : 18); i++)
                                {
                                    var isStart = match.StartingHole == i;
                                    var hlClass = isStart ? highlight : string.Empty;
                                    <th style="width:7.5%" class="text-center@hlClass">
                                        @i@(isStart && match.StartingFlight.HasValue ? DigitToLetter(match.StartingFlight.Value) : string.Empty)
                                    </th>
                                }
                                <th style="width:7.5%"></th>
                            </tr>
                            <tr>
                                <th class="text-left">Par</th>
                                @{int par = 0;}
                                @for (int i = isFront ? 1 : 10; i <= (isFront ? 9 : 18); i++)
                                {
                                    var hole = tee?.Holes?.FirstOrDefault(x => x.HoleNumber == i);
                                    var isStart = match.StartingHole == i;
                                    par += hole?.Par ?? 0;
                                    <th class="text-center@(isStart ? highlight : string.Empty)">@(hole?.Par.ToString() ?? "-")</th>
                                }
                                <th class="text-center">@(tee != null ? par.ToString() : "-")</th>
                            </tr>
                            <tr>
                                <th class="text-left">@(tee?.Name ?? "Yards")</th>
                                @{int yards = 0;}
                                @for (int i = isFront ? 1 : 10; i <= (isFront ? 9 : 18); i++)
                                {
                                    var hole = tee?.Holes?.FirstOrDefault(x => x.HoleNumber == i);
                                    var isStart = match.StartingHole == i;
                                    yards += hole?.Yardage ?? 0;
                                    <th class="text-center@(isStart ? highlight : string.Empty)">@(hole?.Yardage.ToString() ?? "-")</th>
                                }
                                <th class="text-center">@(tee != null ? yards.ToString() : "-")</th>
                            </tr>
                            <tr style="border-bottom-width:2px;">
                                <th class="text-left">Hdcp</th>
                                @for (int i = isFront ? 1 : 10; i <= (isFront ? 9 : 18); i++)
                                {
                                    var hole = tee?.Holes?.FirstOrDefault(x => x.HoleNumber == i);
                                    var isStart = match.StartingHole == i;
                                    <th class="text-center@(isStart ? highlight : string.Empty)">@(hole?.Handicap.ToString() ?? "-")</th>
                                }
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int golferIndex = 0; golferIndex < 3; golferIndex++)
                            {
                                var golfer = homeMembers.ElementAtOrDefault(golferIndex);
                                <tr>
                                    <td>
                                        <div class="text-sm font-bold">
                                            @if (golfer == null)
                                            {
                                                @((MarkupString)"&nbsp;")
                                            }
                                            else
                                            {
                                                @golfer.DisplayName
                                            }
                                        </div>
                                        <div class="text-xs">Hdcp:
                                            @if (golfer?.LeagueHandicap.HasValue ?? false)
                                            {
                                                if (golfer.LeagueHandicap.Value < 0)
                                                {
                                                    <text>+</text>
                                                }
                                                @Math.Abs(Math.Floor(golfer.LeagueHandicap.Value))
                                            }
                                        </div>
                                    </td>
                                    @for (int i = isFront ? 1 : 10; i <= (isFront ? 9 : 18); i++)
                                    {
                                        var isStart = match.StartingHole == i;
                                        <td class="text-center@(isStart ? highlight : string.Empty)"></td>
                                    }
                                    <td></td>
                                </tr>
                            }

                            <tr class="spacer">
                                <td style="padding-top:0; padding-bottom:0; font-size:.55rem; line-height:.65rem;">Pace</td>
                                @for (int i = isFront ? 1 : 10; i <= (isFront ? 9 : 18); i++)
                                {
                                    var isStart = match.StartingHole == i;
                                    var paceTime = paceTimeline.TryGetValue(i, out var t) ? t : TimeSpan.Zero;
                                    <td class="text-center@(isStart ? highlight : string.Empty)"
                                        style="padding-top:0; padding-bottom:0; font-size:.55rem; line-height:.65rem;">
                                        @FormatPace(paceTime)
                                    </td>
                                }
                                <td></td>
                            </tr>

                            @for (int golferIndex = 0; golferIndex < 3; golferIndex++)
                            {
                                var golfer = awayMembers.ElementAtOrDefault(golferIndex);
                                <tr>
                                    <td>
                                        <div class="text-sm font-bold">
                                            @if (golfer == null)
                                            {
                                                @((MarkupString)"&nbsp;")
                                            }
                                            else
                                            {
                                                @golfer.DisplayName
                                            }
                                        </div>
                                        <div class="text-xs">Hdcp:
                                            @if (golfer?.LeagueHandicap.HasValue ?? false)
                                            {
                                                if (golfer.LeagueHandicap.Value < 0)
                                                {
                                                    <text>+</text>
                                                }
                                                @Math.Abs(Math.Floor(golfer.LeagueHandicap.Value))
                                            }
                                        </div>
                                    </td>
                                    @for (int i = isFront ? 1 : 10; i <= (isFront ? 9 : 18); i++)
                                    {
                                        var isStart = match.StartingHole == i;
                                        <td class="text-center@(isStart ? highlight : string.Empty)"></td>
                                    }
                                    <td></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                index++;
            }
        }

    </div>
}
