@page "/league/{LeagueKey}/season/{SeasonKey}/event/{EventKey}/scorecards"
@layout EventLayout
@using GolfManager.Core.Enums
@using GolfManager.Shared.DTOs.Event
@using GolfManager.Shared.DTOs.Player
@using GolfManager.Shared.DTOs.Season

<PageTitle>Print Scorecards - @(seasonEvent?.Name ?? "Event") - Pinzo</PageTitle>

<style>
    @@media print {
        .print-hide {
            display: none !important;
        }

        .print-card {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        .page-break {
            page-break-before: always;
        }
    }
</style>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading printable scorecards...</p>
        </div>
    </div>
}
else if (accessDenied)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Lock" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Access Denied</h2>
                <p class="text-gray-600 mb-8">You must be a league member to view scorecards.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/events"))">
                    Back to Events
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else if (seasonEvent == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Event Not Found</h2>
                <p class="text-gray-600 mb-8">Could not load event scorecards for printing.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/events"))">
                    Back to Events
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="max-w-6xl mx-auto px-4 py-6">
        <div class="print-hide bg-white border border-gray-200 rounded-lg p-4 mb-6 flex flex-wrap items-center justify-between gap-3">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Print Scorecards</h1>
                <p class="text-sm text-gray-600 mt-1">@seasonEvent.Name • @seasonEvent.EventDate.ToString("MMMM d, yyyy")</p>
            </div>
            <div class="flex gap-2">
                <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/events"))">
                    Back
                </MaterialButton>
                <button type="button" class="px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700" onclick="window.print()">
                    Print Now
                </button>
            </div>
        </div>

        @if (matchups.Count == 0)
        {
            <MaterialCard Variant="MaterialCardVariant.Outlined">
                <div class="md-card__content text-center py-16">
                    <MaterialIcon Icon="MaterialIcons.Description" Class="text-gray-400 text-5xl mb-4" />
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">No Matchups Found</h3>
                    <p class="text-gray-600">Generate weekly matchups first, then return here to print scorecards.</p>
                </div>
            </MaterialCard>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                @foreach (var matchup in matchups.OrderBy(m => m.StartingFlight ?? int.MaxValue).ThenBy(m => m.StartingHole ?? int.MaxValue))
                {
                    <div class="print-card border border-gray-300 rounded-lg bg-white p-4">
                        <div class="flex items-center justify-between border-b border-gray-200 pb-3 mb-3">
                            <div>
                                <h2 class="text-lg font-semibold text-gray-900">@GetTeamName(matchup.HomeTeamId, matchup.HomeTeamName) vs @GetTeamName(matchup.AwayTeamId, matchup.AwayTeamName)</h2>
                                <p class="text-sm text-gray-600">Flight @(matchup.StartingFlight?.ToString() ?? "-") • Hole @(matchup.StartingHole?.ToString() ?? "-")</p>
                            </div>
                            <div class="text-right text-xs text-gray-600">
                                <div>@seasonEvent.EventDate.ToString("MM/dd/yyyy")</div>
                                <div>@(seasonEvent.HolesPlayed == HolesPlayed.Eighteen ? "18 Holes" : "9 Holes")</div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div class="border border-gray-200 rounded p-3">
                                <div class="text-xs font-semibold uppercase tracking-wide text-gray-600 mb-2">Home</div>
                                <div class="font-semibold text-gray-900">@GetTeamName(matchup.HomeTeamId, matchup.HomeTeamName)</div>
                                <div class="text-sm text-gray-600 mt-1">Sub: @GetSubName(matchup.HomeSubSeasonGolferId)</div>
                            </div>
                            <div class="border border-gray-200 rounded p-3">
                                <div class="text-xs font-semibold uppercase tracking-wide text-gray-600 mb-2">Away</div>
                                <div class="font-semibold text-gray-900">@GetTeamName(matchup.AwayTeamId, matchup.AwayTeamName)</div>
                                <div class="text-sm text-gray-600 mt-1">Sub: @GetSubName(matchup.AwaySubSeasonGolferId)</div>
                            </div>
                        </div>

                        <table class="w-full border border-gray-200 text-sm">
                            <thead>
                                <tr class="bg-gray-50">
                                    <th class="text-left px-2 py-1 border-b border-gray-200">Hole</th>
                                    @for (var hole = 1; hole <= HoleCount; hole++)
                                    {
                                        <th class="text-center px-1 py-1 border-b border-gray-200">@hole</th>
                                    }
                                    <th class="text-center px-2 py-1 border-b border-gray-200">Tot</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="px-2 py-2 border-t border-gray-200 font-medium">Home</td>
                                    @for (var hole = 1; hole <= HoleCount; hole++)
                                    {
                                        <td class="px-1 py-2 border-t border-gray-200 text-center">____</td>
                                    }
                                    <td class="px-2 py-2 border-t border-gray-200 text-center">____</td>
                                </tr>
                                <tr>
                                    <td class="px-2 py-2 border-t border-gray-200 font-medium">Away</td>
                                    @for (var hole = 1; hole <= HoleCount; hole++)
                                    {
                                        <td class="px-1 py-2 border-t border-gray-200 text-center">____</td>
                                    }
                                    <td class="px-2 py-2 border-t border-gray-200 text-center">____</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>
}
