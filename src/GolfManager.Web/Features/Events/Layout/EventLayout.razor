@inherits LayoutComponentBase
@layout AppLayout
@using GolfManager.Shared.DTOs.Event
@using MaterialComponents.Models

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading event...</p>
        </div>
    </div>
}
else if (context == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">Event Not Found</h2>
                <p class="text-gray-600 mb-8">The event you're looking for doesn't exist or you don't have access to it.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled"
                                OnClick="@(() => Navigation.NavigateTo("/dashboard"))">
                    Back to Dashboard
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <!-- Event Header — rendered once, persists across all event tab navigations -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8 py-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
            <div>
                <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
                    <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <a href="@($"/league/{leagueKey}")" class="hover:text-primary-600">@context.League.Name</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <a href="@($"/league/{leagueKey}/season/{seasonKey}/events")" class="hover:text-primary-600">@context.Season.Name</a>
                    <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
                    <span class="text-gray-900">@(context.Event.Name ?? "Event")</span>
                </div>
                <div class="flex items-center gap-3 mb-2">
                    <h1 class="text-2xl font-bold text-gray-900">@(context.Event.Name ?? "Event")</h1>
                    @EventStatusBadge(context.Event)
                </div>
                <div class="flex flex-wrap gap-5 text-sm text-gray-600">
                    <span>@context.Event.EventDate.ToString("dddd, MMMM d, yyyy")</span>
                    <span class="text-gray-300">|</span>
                    <span>@context.Event.ScoringFormat</span>
                    <span class="text-gray-300">|</span>
                    <span>@((int)context.Event.HolesPlayed) holes</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab Navigation — persists; only @Body below changes on tab switch -->
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8">
        <MaterialTabs @bind-ActiveTab="activeTab"
                      Tabs="@GetNavigationTabs()"
                      ShowContent="false"
                      OnTabChange="HandleTabChange" />
    </div>

    <div class="mt-8"></div>

    <CascadingValue Value="context" IsFixed="false">
        @Body
    </CascadingValue>
}

@code {
    private RenderFragment EventStatusBadge(EventResponse evt) => __builder =>
    {
        if (evt.IsLocked)
        {
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Completed</span>
        }
        else if (evt.EventDate.Date <= DateTime.Today)
        {
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">In Progress</span>
        }
        else
        {
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Upcoming</span>
        }
    };
}
