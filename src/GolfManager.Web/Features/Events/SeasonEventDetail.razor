@page "/league/{LeagueKey}/season/{SeasonKey}/event/{EventKey}"
@layout EventLayout
@using GolfManager.Shared.DTOs.Event
@using GolfManager.Shared.DTOs.Season

<PageTitle>@(EventContext?.Event.Name ?? "Event") - @(EventContext?.Season.Name ?? "Season") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading event...</p>
        </div>
    </div>
}
else if (EventContext == null)
{
    <div class="max-w-2xl mx-auto mt-12">
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-500 text-5xl mb-4" />
                <h2 class="text-xl font-semibold text-gray-900 mb-2">Event Not Found</h2>
                <p class="text-gray-600 mb-6">The event you're looking for doesn't exist or you don't have access to it.</p>
                <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/events"))">
                    <MaterialIcon Icon="MaterialIcons.ArrowBack" Class="mr-1" />
                    Back to Events
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    @if (matchups.Count == 0)
    {
        <p class="text-sm text-gray-500 py-6">No matchups set up for this event yet.</p>
    }
    else
    {
        <ResponsiveTable TItem="EventMatchupResponse" Items="@matchups">
                <Row Context="m">
                    <tr class="hover:bg-gray-50 cursor-pointer"
                        @onclick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/event/{EventKey}/match/{m.Id}"))">
                        <td class="py-3 pl-5 pr-3 text-sm font-semibold text-gray-700 text-right w-14">
                            @(m.HomePoints.HasValue || m.AwayPoints.HasValue ? (m.HomePoints ?? 0.0).ToString("F1") : "—")
                        </td>
                        <td class="py-3 pr-6 text-sm text-right w-1/2">
                            <div class="font-medium text-gray-900">@(m.HomeTeamName ?? GetTeamName(m.HomeTeamId))</div>
                        </td>
                        <td class="py-3 px-4 text-sm text-center text-gray-500 whitespace-nowrap">
                            <div>@MatchupLabel(m)</div>
                            @if (m.IsComplete)
                            {
                                <div class="text-xs text-gray-400">Complete</div>
                            }
                        </td>
                        <td class="py-3 pl-6 text-sm text-left w-1/2">
                            <div class="font-medium text-gray-900">@(m.AwayTeamName ?? GetTeamName(m.AwayTeamId))</div>
                        </td>
                        <td class="py-3 pl-3 pr-5 text-sm font-semibold text-gray-700 text-left w-14">
                            @(m.HomePoints.HasValue || m.AwayPoints.HasValue ? (m.AwayPoints ?? 0.0).ToString("F1") : "—")
                        </td>
                    </tr>
                </Row>
                <Card Context="m">
                    <a href="/league/@LeagueKey/season/@SeasonKey/event/@EventKey/match/@m.Id" class="block">
                        <div class="border border-gray-200 rounded-lg p-4 bg-white text-center hover:border-primary-300 hover:bg-gray-50 transition-colors">
                            <div>
                                <div class="text-sm font-medium text-gray-900">@(m.HomeTeamName ?? GetTeamName(m.HomeTeamId))</div>
                                @if (m.HomePoints.HasValue || m.AwayPoints.HasValue)
                                {
                                    <div class="text-sm font-bold text-gray-700 mt-0.5">@((m.HomePoints ?? 0.0).ToString("F1"))</div>
                                }
                            </div>
                            <div class="my-3 text-sm text-gray-500">
                                <div>@MatchupLabel(m)</div>
                                @if (m.IsComplete)
                                {
                                    <div class="text-xs text-gray-400 mt-0.5">Complete</div>
                                }
                            </div>
                            <div>
                                <div class="text-sm font-medium text-gray-900">@(m.AwayTeamName ?? GetTeamName(m.AwayTeamId))</div>
                                @if (m.HomePoints.HasValue || m.AwayPoints.HasValue)
                                {
                                    <div class="text-sm font-bold text-gray-700 mt-0.5">@((m.AwayPoints ?? 0.0).ToString("F1"))</div>
                                }
                            </div>
                        </div>
                    </a>
                </Card>
            </ResponsiveTable>
    }
}
