@page "/events/create"
@layout AppLayout

<PageTitle>Create Event - Pinzo</PageTitle>

@if (!canCreate)
{
    <div class="text-center py-16">
        <MaterialIcon Path="@MaterialIcons.LockClosed" Size="MaterialComponents.Icons.IconSize.XL" Class="text-gray-400 mb-4" />
        <h2 class="text-2xl font-semibold text-gray-900 mb-2">Access Denied</h2>
        <p class="text-gray-600 mb-4">You must be a Global Admin to create standalone events.</p>
        <MaterialButton Style="MaterialButtonStyle.Outlined" 
                      Text="Back to Events"
                      OnClick="@(() => Navigation.NavigateTo("/events"))" />
    </div>
}
else
{
    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex items-center gap-2 text-sm text-gray-600 mb-2">
            <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
            <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
            <a href="/events" class="hover:text-primary-600">Events</a>
            <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
            <span class="text-gray-900">Create Event</span>
        </div>
        <h1 class="text-3xl font-bold text-gray-900">Create New Event</h1>
    </div>

    <!-- Create Form -->
    <div class="max-w-2xl">
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <EditForm Model="model" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <!-- Event Name -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Event Name *</label>
                    <InputText @bind-Value="model.EventName"
                               placeholder="e.g., Summer Championship"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    <ValidationMessage For="@(() => model.EventName)" class="text-sm text-red-600 mt-1" />
                </div>

                <!-- Description -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                    <InputTextArea @bind-Value="model.Description"
                                   rows="3"
                                   placeholder="Describe your event..."
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    <ValidationMessage For="@(() => model.Description)" class="text-sm text-red-600 mt-1" />
                </div>

                <!-- Date and Time -->
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Date *</label>
                        <InputDate @bind-Value="model.EventDate"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                        <ValidationMessage For="@(() => model.EventDate)" class="text-sm text-red-600 mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Tee Time</label>
                        <InputText @bind-Value="model.TeeTimeString"
                                   placeholder="09:00"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    </div>
                </div>

                <!-- Course -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Golf Course *</label>
                    <InputText @bind-Value="model.CourseName"
                               placeholder="e.g., Pebble Beach Golf Links"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    <ValidationMessage For="@(() => model.CourseName)" class="text-sm text-red-600 mt-1" />
                </div>

                <!-- Format -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Format *</label>
                    <InputSelect @bind-Value="model.Format" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500">
                        <option value="individual">Individual Stroke Play</option>
                        <option value="team">Team Event</option>
                        <option value="scramble">Scramble</option>
                        <option value="bestball">Best Ball</option>
                    </InputSelect>
                </div>

                <!-- Max Players -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Maximum Players</label>
                    <InputNumber @bind-Value="model.MaxPlayers"
                                 min="1"
                                 placeholder="Leave empty for unlimited"
                                 class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    <ValidationMessage For="@(() => model.MaxPlayers)" class="text-sm text-red-600 mt-1" />
                </div>

                <!-- Registration Deadline -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Registration Deadline</label>
                    <InputDate @bind-Value="model.RegistrationDeadline"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>

                <ErrorBanner Message="@errorMessage" />

                <!-- Actions -->
                <div class="flex gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Filled"
                                  Text="Create Event"
                                  Type="submit"
                                  Disabled="@isSubmitting" />
                    <MaterialButton Style="MaterialButtonStyle.Outlined"
                                  Text="Cancel"
                                  OnClick="@(() => Navigation.NavigateTo("/events"))" />
                </div>
            </EditForm>
        </div>

        <!-- Info Box -->
        <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
            <div class="flex items-start gap-3">
                <MaterialIcon Path="@GolfIcons.Info" Class="text-blue-600 flex-shrink-0" />
                <div class="text-sm text-blue-900">
                    <p class="font-semibold mb-1">Standalone vs Season Events</p>
                    <p>This creates a standalone one-time event. To create an event within a league season, navigate to the season and create the event there.</p>
                </div>
            </div>
        </div>
    </div>
}

