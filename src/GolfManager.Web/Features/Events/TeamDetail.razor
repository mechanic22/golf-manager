@page "/league/{LeagueKey}/season/{SeasonKey}/team/{TeamId}"
@layout AppLayout
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Shared.DTOs.Event

<PageTitle>@(team?.Name ?? "Team") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading team...</p>
        </div>
    </div>
}
else if (team == null)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard>
            <div class="p-8 text-center">
                <MaterialIcon Icon="MaterialIcons.ErrorOutline" Class="text-6xl text-gray-400 mb-4" />
                <h2 class="text-xl font-semibold text-gray-900 mb-2">Team Not Found</h2>
                <p class="text-gray-600 mb-6">The team you're looking for doesn't exist or you don't have access.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled"
                                OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/teams"))">
                    Back to Teams
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Back nav -->
        <div class="mb-6">
            <MaterialButton Style="MaterialButtonStyle.Text"
                            OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/teams"))">
                <MaterialIcon Icon="MaterialIcons.ArrowBack" Class="mr-1" />
                Back to Teams
            </MaterialButton>
        </div>

        <!-- Team Header -->
        <MaterialCard Class="mb-6">
            <div class="p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-16 h-16 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                        <MaterialIcon Icon="MaterialIcons.Groups" Class="text-primary-700 text-3xl" />
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900">@team.Name</h1>
                        <p class="text-sm text-gray-500">@team.Members.Count member@(team.Members.Count == 1 ? "" : "s")</p>
                    </div>
                </div>

                <!-- W/L/T Record -->
                <div class="grid grid-cols-4 gap-4 border-t border-gray-100 pt-4">
                    <div class="text-center">
                        <div class="text-2xl font-bold text-gray-900">@team.Wins</div>
                        <div class="text-xs text-gray-500 uppercase tracking-wide">Wins</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-gray-900">@team.Losses</div>
                        <div class="text-xs text-gray-500 uppercase tracking-wide">Losses</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-gray-900">@team.Ties</div>
                        <div class="text-xs text-gray-500 uppercase tracking-wide">Ties</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-primary-700">@(team.SeasonPoints?.ToString("F1") ?? "—")</div>
                        <div class="text-xs text-gray-500 uppercase tracking-wide">Points</div>
                    </div>
                </div>
            </div>
        </MaterialCard>

        <!-- Members -->
        <h2 class="text-lg font-semibold text-gray-900 mb-3">Members</h2>
        @if (team.Members.Count == 0)
        {
            <MaterialCard>
                <div class="p-6 text-center py-10">
                    <p class="text-gray-500">No members assigned to this team.</p>
                </div>
            </MaterialCard>
        }
        else
        {
            <MaterialCard>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead>
                            <tr class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                <th class="px-6 py-3 w-full">Player</th>
                                <th class="px-6 py-3">Handicap</th>
                                <th class="px-6 py-3">Points</th>
                                <th class="px-6 py-3">Rounds</th>
                                <th class="px-6 py-3">Avg Net</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            @foreach (var member in team.Members)
                            {
                                var standing = GetStanding(member.SeasonGolferId);
                                <tr class="hover:bg-gray-50 @(GetLeagueGolferId(member.SeasonGolferId) != null ? "cursor-pointer" : "")"
                                    @onclick="@(() => { var lgId = GetLeagueGolferId(member.SeasonGolferId); if (lgId != null) Navigation.NavigateTo($"/league/{LeagueKey}/player/{lgId}"); })">
                                    <td class="px-6 py-4 text-sm font-medium text-primary-700 hover:underline">
                                        @member.DisplayName
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        @(member.LeagueHandicap?.ToString("F1") ?? "—")
                                    </td>
                                    <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                        @(standing?.SeasonPoints?.ToString("F1") ?? "—")
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        @(standing?.RoundCount > 0 ? standing.RoundCount.ToString() : "—")
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        @(standing?.AverageNetScore?.ToString("F1") ?? "—")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </MaterialCard>
        }

        <!-- Match Results -->
        @if (teamMatches.Any())
        {
            <h2 class="text-lg font-semibold text-gray-900 mb-3 mt-6">Match Results</h2>
            <MaterialCard>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead>
                            <tr class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                <th class="px-6 py-3">Date</th>
                                <th class="px-6 py-3">Opponent</th>
                                <th class="px-6 py-3">Score</th>
                                <th class="px-6 py-3">Result</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            @foreach (var (eventDate, match) in teamMatches)
                            {
                                var isHome = string.Equals(match.HomeTeamId, TeamId, StringComparison.OrdinalIgnoreCase);
                                var ourPoints = isHome ? match.HomePoints : match.AwayPoints;
                                var theirPoints = isHome ? match.AwayPoints : match.HomePoints;
                                var opponentName = isHome ? match.AwayTeamName : match.HomeTeamName;
                                var result = ourPoints.HasValue && theirPoints.HasValue
                                    ? (ourPoints > theirPoints ? "W" : ourPoints < theirPoints ? "L" : "T")
                                    : "—";
                                var resultClass = result == "W" ? "text-green-700 bg-green-50"
                                               : result == "L" ? "text-red-700 bg-red-50"
                                               : "text-gray-700 bg-gray-100";
                                <tr>
                                    <td class="px-6 py-4 text-sm text-gray-600">@eventDate.ToString("MMM d, yyyy")</td>
                                    <td class="px-6 py-4 text-sm font-medium text-gray-900">@(opponentName ?? "—")</td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        @(ourPoints?.ToString("F1") ?? "—") – @(theirPoints?.ToString("F1") ?? "—")
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 text-xs font-semibold rounded-full @resultClass">@result</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </MaterialCard>
        }
    </div>
}
