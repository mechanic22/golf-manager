@page "/league/{LeagueKey}/season/{SeasonKey}/event/{EventKey}/scores"
@layout EventLayout
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Shared.DTOs.Player
@using GolfManager.Shared.DTOs.Round
@using GolfManager.Shared.DTOs.Event
@using GolfManager.Core.Enums

<PageTitle>Score Entry - @(seasonEvent?.Name ?? "Event") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center min-h-screen">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading event...</p>
        </div>
    </div>
}
else if (accessDenied)
{
    <div class="max-w-2xl mx-auto mt-12">
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <MaterialIcon Icon="MaterialIcons.Lock" Class="text-red-500 text-5xl mb-4" />
                <h2 class="text-xl font-semibold text-gray-900 mb-2">Access Denied</h2>
                <p class="text-gray-600 mb-6">Only league or season admins can enter scores for events.</p>
                <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}"))">
                    <MaterialIcon Icon="MaterialIcons.ArrowBack" Class="mr-1" />
                    Back to Season
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="max-w-7xl mx-auto">

        @if (!golfers.Any())
        {
            <MaterialCard Variant="MaterialCardVariant.Outlined">
                <div class="md-card__content text-center py-12">
                    <MaterialIcon Icon="MaterialIcons.People" Class="text-gray-400 text-5xl mb-4" />
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">No Golfers Found</h3>
                    <p class="text-gray-600">Add golfers to the season to start entering scores.</p>
                </div>
            </MaterialCard>
        }
        else if (hasMatchLayout)
        {
            <!-- Match-based layout: one card per matchup -->
            @foreach (var group in matchGroups)
            {
                var matchup = group.Matchup;
                var matchLabel = matchup.StartingFlight.HasValue || matchup.StartingHole.HasValue
                    ? $"Flight {matchup.StartingFlight?.ToString() ?? "–"}  ·  Hole {matchup.StartingHole?.ToString() ?? "–"}"
                    : null;

                <div class="mb-6">
                    @if (matchLabel != null)
                    {
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">@matchLabel</p>
                    }

                    <MaterialCard Variant="MaterialCardVariant.Outlined">
                        <div class="md-card__content p-0">
                            <!-- Home team -->
                            <div class="border-b border-gray-200">
                                <div class="flex items-center justify-between px-4 pt-3 pb-1">
                                    <span class="text-sm font-semibold text-gray-700">@(group.HomeTeamName ?? "Home Team")</span>
                                    @RenderSubControl(matchup, isHome: true, group.HomeSub, group.HomeMembers)
                                </div>
                                @RenderScoreTable(group.HomeMembers, group.HomeSub)
                            </div>

                            <!-- Away team -->
                            <div>
                                <div class="flex items-center justify-between px-4 pt-3 pb-1">
                                    <span class="text-sm font-semibold text-gray-700">@(group.AwayTeamName ?? "Away Team")</span>
                                    @RenderSubControl(matchup, isHome: false, group.AwaySub, group.AwayMembers)
                                </div>
                                @RenderScoreTable(group.AwayMembers, group.AwaySub)
                            </div>
                        </div>
                    </MaterialCard>
                </div>
            }

            <!-- Ungrouped golfers (not in any matchup) -->
            @if (ungroupedGolfers.Any())
            {
                <div class="mb-6">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">No Matchup Assigned</p>
                    <MaterialCard Variant="MaterialCardVariant.Outlined">
                        <div class="md-card__content p-0">
                            @RenderScoreTable(ungroupedGolfers, null)
                        </div>
                    </MaterialCard>
                </div>
            }
        }
        else
        {
            <!-- Flat list (no matchups configured) -->
            <MaterialCard Variant="MaterialCardVariant.Outlined">
                <div class="md-card__content p-0">
                    @RenderScoreTable(golfers.OrderBy(g => g.DisplayName).ToList(), null)
                </div>
            </MaterialCard>
        }
    </div>
}

@code {

    private RenderFragment RenderScoreTable(List<PlayerResponse> members, PlayerResponse? sub) => __builder =>
    {
        var evt = seasonEvent!;
        var lid = league!.Id;
        var holeCount = evt.HolesPlayed == HolesPlayed.Eighteen ? 18 : 9;
        <div class="overflow-x-auto">
            <table class="w-full min-w-max">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider sticky left-0 bg-gray-50 z-10 min-w-40">
                            Player
                        </th>
                        @for (int i = 1; i <= holeCount; i++)
                        {
                            <th class="px-2 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider min-w-13">@i</th>
                        }
                        <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider min-w-17.5 bg-gray-100">Total</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var golfer in members)
                    {
                        <ScoreEntryRow
                            Golfer="@golfer"
                            SeasonEvent="@evt"
                            LeagueId="@lid"
                            IsSubstitute="false"
                            OnScoreChanged="@HandleScoreChanged" />
                    }
                    @if (sub != null)
                    {
                        <ScoreEntryRow
                            Golfer="@sub"
                            SeasonEvent="@evt"
                            LeagueId="@lid"
                            IsSubstitute="true"
                            OnScoreChanged="@HandleScoreChanged" />
                    }
                </tbody>
            </table>
        </div>
    };

    private RenderFragment RenderSubControl(EventMatchupResponse matchup, bool isHome, PlayerResponse? currentSub, List<PlayerResponse> teamMembers) => __builder =>
    {
        var isEditing = subEditMatchupId == matchup.Id && subEditIsHome == isHome;
        var teamId = isHome ? matchup.HomeTeamId : matchup.AwayTeamId;

        if (isEditing)
        {
            <div class="flex items-center gap-2">
                <select class="text-sm border border-gray-300 rounded px-2 py-1 focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        value="@subEditSelectedSeasonGolferId"
                        @onchange="@((e) => subEditSelectedSeasonGolferId = e.Value?.ToString() ?? string.Empty)">
                    <option value="">— No Sub —</option>
                    @foreach (var candidate in GetSubCandidates(teamId))
                    {
                        <option value="@candidate.SeasonGolferId">@candidate.DisplayName</option>
                    }
                </select>
                <button class="text-xs text-white bg-primary-600 hover:bg-primary-700 px-2 py-1 rounded disabled:opacity-50"
                        disabled="@isSavingSub"
                        @onclick="SaveSubAsync">
                    @(isSavingSub ? "Saving…" : "Save")
                </button>
                <button class="text-xs text-gray-500 hover:text-gray-700 px-1 py-1" @onclick="CancelSubEdit">Cancel</button>
            </div>
        }
        else if (currentSub != null)
        {
            <div class="flex items-center gap-2 text-xs text-gray-500">
                <span>Sub: <span class="font-medium text-gray-700">@currentSub.DisplayName</span></span>
                <button class="text-primary-600 hover:text-primary-800 underline"
                        @onclick="@(() => BeginSubEdit(matchup.Id, isHome))">Change</button>
            </div>
        }
        else
        {
            <button class="text-xs text-primary-600 hover:text-primary-800 underline"
                    @onclick="@(() => BeginSubEdit(matchup.Id, isHome))">+ Add Sub</button>
        }
    };
}
