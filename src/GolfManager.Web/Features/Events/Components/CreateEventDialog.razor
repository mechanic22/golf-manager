@using GolfManager.Shared.DTOs.OneTimeEvent

<MaterialDialog @bind-IsOpen="IsOpen" Title="Create New Event" MaxWidth="MaterialDialogMaxWidth.Medium">
    <ChildContent>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger mb-4">
                @ErrorMessage
            </div>
        }

        <EditForm Model="@Request" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <MaterialInput @bind-Value="Request.Name"
                                  Label="Event Name"
                                  Placeholder="Summer Golf Tournament"
                                  Variant="MaterialInputVariant.Outlined"
                                  Required="true" />
                    <ValidationMessage For="@(() => Request.Name)" />
                </div>

                <div>
                    <MaterialInput @bind-Value="Request.EventDate"
                                  Label="Event Date"
                                  Type="date"
                                  Variant="MaterialInputVariant.Outlined"
                                  Required="true" />
                    <ValidationMessage For="@(() => Request.EventDate)" />
                </div>

                <div>
                    <MaterialInput @bind-Value="Request.Format"
                                  Label="Format"
                                  Placeholder="Scramble, Best Ball, etc."
                                  Variant="MaterialInputVariant.Outlined"
                                  Required="true" />
                    <ValidationMessage For="@(() => Request.Format)" />
                </div>

                <div>
                    <MaterialInput @bind-Value="Request.TeamSize"
                                  Label="Team Size"
                                  Type="number"
                                  Variant="MaterialInputVariant.Outlined"
                                  Required="true" />
                    <ValidationMessage For="@(() => Request.TeamSize)" />
                </div>

                <div class="mt-4 flex justify-end gap-3">
                    <MaterialButton Type="button" Style="MaterialButtonStyle.Text" OnClick="HandleCancel" Disabled="IsSubmitting">
                        Cancel
                    </MaterialButton>
                    <MaterialButton Type="submit" Style="MaterialButtonStyle.Filled" Disabled="IsSubmitting">
                        @if (IsSubmitting)
                        {
                            <span>Creating...</span>
                        }
                        else
                        {
                            <span>Create Event</span>
                        }
                    </MaterialButton>
                </div>
            </div>
        </EditForm>
    </ChildContent>
</MaterialDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback<OneTimeEventResponse> OnEventCreated { get; set; }

    private CreateOneTimeEventRequest Request { get; set; } = new();
    private string? ErrorMessage { get; set; }
    private bool IsSubmitting { get; set; }

    [Inject] private IOneTimeEventService EventService { get; set; } = default!;
    [Inject] private ILogger<CreateEventDialog> Logger { get; set; } = default!;

    private async Task HandleSubmit()
    {
        IsSubmitting = true;
        ErrorMessage = null;

        try
        {
            var response = await EventService.CreateEventAsync(Request);

            if (response?.Success == true && response.Data != null)
            {
                await OnEventCreated.InvokeAsync(response.Data);
                await CloseDialog();
            }
            else
            {
                ErrorMessage = response?.Message ?? "Failed to create event. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating event");
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task HandleCancel()
    {
        await CloseDialog();
    }

    private Task CloseDialog()
    {
        Request = new CreateOneTimeEventRequest();
        ErrorMessage = null;
        return IsOpenChanged.InvokeAsync(false);
    }
}
