@page "/league/{LeagueKey}/season/{SeasonKey}/player/{PlayerId}"
@layout SeasonLayout
@using GolfManager.Shared.DTOs.Player
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Web.Shared.Charts

<PageTitle>@(player?.DisplayName ?? "Player") - @(SeasonCtx?.Season.Name ?? "Season") - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center min-h-64">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading player...</p>
        </div>
    </div>
}
else if (player == null)
{
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <MaterialCard>
            <div class="p-8 text-center">
                <MaterialIcon Icon="MaterialIcons.ErrorOutline" Class="text-6xl text-gray-400 mb-4" />
                <h2 class="text-xl font-semibold text-gray-900 mb-2">Player Not Found</h2>
                <p class="text-gray-600 mb-6">The player you're looking for doesn't exist or you don't have access.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled"
                                OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/standings"))">
                    Back to Standings
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        <!-- Back -->
        <div class="mb-4">
            <MaterialButton Style="MaterialButtonStyle.Text"
                            OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{SeasonKey}/standings"))">
                <MaterialIcon Icon="MaterialIcons.ArrowBack" Class="mr-1" />
                Back to Standings
            </MaterialButton>
        </div>

        <!-- Hero Card -->
        <div class="relative overflow-hidden rounded-xl bg-linear-to-br from-primary-600 to-primary-800 text-white mb-8">
            <div class="absolute -top-12 -right-12 w-64 h-64 rounded-full bg-white/10 blur-3xl pointer-events-none"></div>
            <div class="absolute -bottom-8 -left-8 w-48 h-48 rounded-full bg-white/5 blur-2xl pointer-events-none"></div>

            <div class="relative p-6 md:p-8">
                <div class="flex flex-col md:flex-row items-start md:items-center gap-6">

                    <!-- Identity -->
                    <div class="flex items-center gap-4 flex-1 min-w-0">
                        <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-white/20 border-2 border-white/30 flex items-center justify-center shrink-0">
                            <span class="text-2xl md:text-3xl font-bold">@GetInitials(player.DisplayName)</span>
                        </div>
                        <div class="min-w-0">
                            <p class="text-primary-200 text-xs uppercase tracking-widest mb-0.5">@(SeasonCtx?.Season.Name ?? "Season") Profile</p>
                            <h1 class="text-2xl md:text-3xl font-bold leading-tight truncate">@player.DisplayName</h1>
                            @if (!string.IsNullOrEmpty(player.Nickname))
                            {
                                <p class="text-primary-200 text-sm">"@player.Nickname"</p>
                            }
                        </div>
                    </div>

                    <!-- Season stat tiles -->
                    <div class="grid grid-cols-3 md:grid-cols-5 gap-3 w-full md:w-auto shrink-0">
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-14">
                            <div class="text-2xl font-bold">
                                @if (currentPoints.HasValue) { @currentPoints.Value.ToString("F1") }
                                else { <span class="text-white/50">—</span> }
                            </div>
                            <div class="text-primary-200 text-xs mt-0.5">Points</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-14">
                            <div class="text-2xl font-bold">@currentRounds</div>
                            <div class="text-primary-200 text-xs mt-0.5">Rounds</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-14">
                            <div class="text-2xl font-bold">
                                @if (currentAvgGross.HasValue) { @currentAvgGross.Value.ToString("F1") }
                                else { <span class="text-white/50">—</span> }
                            </div>
                            <div class="text-primary-200 text-xs mt-0.5">Avg Gross</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-14">
                            <div class="text-2xl font-bold">
                                @if (currentAvgNet.HasValue) { @currentAvgNet.Value.ToString("F1") }
                                else { <span class="text-white/50">—</span> }
                            </div>
                            <div class="text-primary-200 text-xs mt-0.5">Avg Net</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-14">
                            <div class="text-2xl font-bold">
                                @if (currentBest.HasValue) { @currentBest.Value }
                                else { <span class="text-white/50">—</span> }
                            </div>
                            <div class="text-primary-200 text-xs mt-0.5">Best</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Season Comparison -->
        @if (prevSeasonRounds.Count > 0 && prevSeasonName != null)
        {
            <div class="mb-8">
                <h2 class="text-lg font-semibold text-gray-900 mb-3">Season Comparison</h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
                    @ComparisonCard("Rounds",   currentRounds,              prevRounds,              0)
                    @ComparisonCard("Avg Gross", currentAvgGross,            prevAvgGross,            1)
                    @ComparisonCard("Avg Net",   currentAvgNet,              prevAvgNet,              1)
                    @ComparisonCard("Best",      currentBest.HasValue ? (double?)currentBest.Value : null, prevBest.HasValue ? (double?)prevBest.Value : null, 0, lowerIsBetter: true)
                    @ComparisonCard("Points",    currentPoints,              prevPoints,              1)
                </div>
                <p class="text-xs text-gray-400 mt-2">vs @prevSeasonName</p>
            </div>
        }

        <!-- Charts -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <!-- Hole Trend -->
            @if (holeStats?.Holes.Any() == true)
            {
                <MaterialCard>
                    <div class="p-5">
                        <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Avg Over Par by Hole</h3>
                        <HoleTrendChart seasonHoles="@holeStats.Holes" EmptyMessage="No hole data" MaxHeightPx="220" />
                    </div>
                </MaterialCard>

                <!-- Scoring Profile -->
                <MaterialCard>
                    <div class="p-5">
                        <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Scoring Profile</h3>
                        <ScoringProfileChart CurrentHoles="@holeStats.Holes"
                                             CareerHoles="@careerHoleStats?.Holes"
                                             EmptyMessage="No scoring data" />
                    </div>
                </MaterialCard>
            }

            <!-- Score Trend -->
            @{
                var scoreData = currentSeasonRounds.Count > 0 ? BuildScoreChartSeries(currentSeasonRounds) : new();
                var hcpData   = currentSeasonRounds.Count > 0 ? BuildHandicapTrendSeries(currentSeasonRounds) : new();
            }
            @if (scoreData.Any())
            {
                <MaterialCard>
                    <div class="p-5">
                        <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Score Trend</h3>
                        <LineChart chartSeries="@scoreData" YFormat="F0" MaxHeightPx="220" EmptyMessage="No score data" />
                    </div>
                </MaterialCard>
            }
            @if (hcpData.Any())
            {
                <MaterialCard>
                    <div class="p-5">
                        <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Handicap Trend</h3>
                        <LineChart chartSeries="@hcpData" YFormat="F1" MaxHeightPx="220" EmptyMessage="No handicap data" />
                    </div>
                </MaterialCard>
            }
        </div>

        <!-- Round History -->
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-xl font-semibold text-gray-900">Round History</h2>
            <span class="text-sm text-gray-500">@currentSeasonRounds.Count round@(currentSeasonRounds.Count == 1 ? "" : "s")</span>
        </div>

        <MaterialCard class="mb-8">
            <ResponsiveTable TItem="GolfManager.Shared.DTOs.Round.RoundResponse" Items="@currentSeasonRounds">
                <Headers>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Course</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Holes</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Gross</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Net</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Handicap</th>
                </Headers>
                <Row Context="round">
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            @(round.RoundDate == default ? "—" : round.RoundDate.ToString("MMM d, yyyy"))
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm font-medium text-gray-900">@round.CourseName</div>
                            @if (!string.IsNullOrEmpty(round.TeeName))
                            {
                                <div class="text-xs text-gray-500">@round.TeeName tees</div>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@round.HolesPlayed</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                            @if (round.TotalScore.HasValue) { <span class="font-semibold text-gray-900">@round.TotalScore</span> }
                            else { <span class="text-gray-400">—</span> }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                            @if (round.NetScore.HasValue) { <span class="text-blue-700 font-medium">@round.NetScore</span> }
                            else { <span class="text-gray-400">—</span> }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-600">
                            @(round.HandicapUsed.HasValue ? round.HandicapUsed.Value.ToString("F1") : "—")
                        </td>
                    </tr>
                </Row>
                <Card Context="round">
                    <div class="border-b border-gray-100 px-4 py-4">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <div class="font-medium text-gray-900 truncate">@round.CourseName</div>
                                @if (!string.IsNullOrEmpty(round.TeeName))
                                {
                                    <div class="text-xs text-gray-500">@round.TeeName tees</div>
                                }
                                <div class="text-sm text-gray-500 mt-0.5">
                                    @(round.RoundDate == default ? "—" : round.RoundDate.ToString("MMM d, yyyy"))
                                </div>
                            </div>
                            @if (round.TotalScore.HasValue)
                            {
                                <div class="text-right shrink-0">
                                    <div class="text-2xl font-bold text-gray-900">@round.TotalScore</div>
                                    <div class="text-xs text-gray-500">Gross</div>
                                </div>
                            }
                        </div>
                        <div class="flex flex-wrap gap-3 mt-3 text-sm">
                            @if (round.NetScore.HasValue)
                            {
                                <div><span class="text-gray-500">Net</span> <span class="font-semibold text-blue-700">@round.NetScore</span></div>
                            }
                            @if (round.HandicapUsed.HasValue)
                            {
                                <div><span class="text-gray-500">HCP</span> <span class="font-medium text-gray-700">@round.HandicapUsed.Value.ToString("F1")</span></div>
                            }
                            <div><span class="text-gray-500">Holes</span> <span class="font-medium text-gray-700">@round.HolesPlayed</span></div>
                        </div>
                    </div>
                </Card>
                <Empty>
                    <div class="p-6 text-center py-12">
                        <MaterialIcon Icon="MaterialIcons.GolfCourse" Class="text-6xl text-gray-300 mb-4" />
                        <h3 class="text-lg font-semibold text-gray-900 mb-2">No Rounds This Season</h3>
                        <p class="text-gray-600">This player hasn't posted any rounds this season.</p>
                    </div>
                </Empty>
            </ResponsiveTable>
        </MaterialCard>

        <!-- League profile link -->
        <div class="text-center pb-4">
            <MaterialButton Style="MaterialButtonStyle.Text"
                            OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/player/{PlayerId}"))">
                View Full League Profile
                <MaterialIcon Icon="MaterialIcons.ArrowForward" Class="ml-1" />
            </MaterialButton>
        </div>

    </div>
}
