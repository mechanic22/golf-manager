
@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600"></div>
    </div>
}
else
{
    <div class="max-w-3xl">
        <!-- Season Info (read-only) -->
        <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Season Information</h2>
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 text-sm">
                <div>
                    <dt class="text-gray-500">Season Name</dt>
                    <dd class="text-gray-900 font-medium mt-0.5">@SeasonCtx!.Season.Name</dd>
                </div>
                <div>
                    <dt class="text-gray-500">Season Key</dt>
                    <dd class="font-mono text-gray-700 mt-0.5">@SeasonCtx!.Season.Key</dd>
                </div>
                <div>
                    <dt class="text-gray-500">Start Date</dt>
                    <dd class="text-gray-900 mt-0.5">@SeasonCtx!.Season.StartDate.ToString("MMM d, yyyy")</dd>
                </div>
                <div>
                    <dt class="text-gray-500">End Date</dt>
                    <dd class="text-gray-900 mt-0.5">@(SeasonCtx!.Season.EndDate.HasValue ? SeasonCtx.Season.EndDate.Value.ToString("MMM d, yyyy") : "—")</dd>
                </div>
                <div>
                    <dt class="text-gray-500">Status</dt>
                    <dd class="mt-0.5">
                        @if (SeasonCtx!.Season.IsLocked)
                        {
                            <span class="text-gray-500">Archived</span>
                        }
                        else
                        {
                            <span class="text-green-600">Active</span>
                        }
                    </dd>
                </div>
            </dl>
        </div>

        <!-- Season Setup -->
        <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">Season Setup</h2>
            <p class="text-sm text-gray-600 mb-6">Paste a calendar and team list to bulk create season events, teams, and season player assignments.</p>

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Calendar</label>
                    <textarea @bind="calendarText"
                              rows="12"
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent font-mono text-sm"
                              placeholder="Paste week, date, and note rows here"></textarea>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Teams</label>
                    <textarea @bind="teamsText"
                              rows="12"
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent font-mono text-sm"
                              placeholder="Paste tab-separated team rosters here"></textarea>
                </div>

                <div class="flex items-center">
                    <input type="checkbox"
                           @bind="replaceExistingSetup"
                           id="replaceExistingSetup"
                           class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" />
                    <label for="replaceExistingSetup" class="ml-2 block text-sm text-gray-700">
                        Replace existing events, teams, and season player assignments for this season
                    </label>
                </div>

                @if (!string.IsNullOrEmpty(seasonSetupMessage))
                {
                    <div class="px-4 py-3 rounded text-sm @(seasonSetupSuccess ? "bg-green-50 border border-green-200 text-green-800" : "bg-red-50 border border-red-200 text-red-800")">
                        @seasonSetupMessage
                    </div>
                }

                @if (seasonSetupResult != null)
                {
                    <div class="rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-gray-800 space-y-2">
                        <div><span class="font-semibold">Calendar rows parsed:</span> @seasonSetupResult.CalendarWeeksParsed</div>
                        <div><span class="font-semibold">Weeks skipped:</span> @seasonSetupResult.SkippedWeeks</div>
                        <div><span class="font-semibold">Events created:</span> @seasonSetupResult.EventsCreated</div>
                        <div><span class="font-semibold">Teams created:</span> @seasonSetupResult.TeamsCreated</div>
                        <div><span class="font-semibold">Players assigned:</span> @seasonSetupResult.PlayersAssigned</div>

                        @if (seasonSetupResult.Warnings.Count > 0)
                        {
                            <div>
                                <div class="font-semibold">Warnings</div>
                                <ul class="list-disc list-inside space-y-1 text-amber-800">
                                    @foreach (var warning in seasonSetupResult.Warnings)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (seasonSetupResult.MissingPlayers.Count > 0)
                        {
                            <div>
                                <div class="font-semibold text-red-800">Players not matched to league records</div>
                                <ul class="list-disc list-inside space-y-1 text-red-700">
                                    @foreach (var player in seasonSetupResult.MissingPlayers)
                                    {
                                        <li>@player</li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="mt-6 flex justify-end">
                <button @onclick="ApplySeasonSetup"
                        disabled="@(isApplyingSeasonSetup || string.IsNullOrWhiteSpace(calendarText) || string.IsNullOrWhiteSpace(teamsText))"
                        class="px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 disabled:opacity-50">
                    @GetApplySetupButtonText()
                </button>
            </div>
        </div>

        <!-- Danger Zone -->
        <div class="bg-white rounded-lg border border-red-200 p-6">
            <h2 class="text-lg font-semibold text-red-900 mb-4">Danger Zone</h2>

            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-red-50 rounded-lg">
                    <div>
                        <h3 class="text-sm font-semibold text-red-900">Archive Season</h3>
                        <p class="text-sm text-red-700 mt-1">Mark this season as archived. It will be read-only.</p>
                    </div>
                    <button @onclick="ArchiveSeason"
                            disabled="@(isArchiving || SeasonCtx?.Season.IsLocked == true)"
                            class="px-4 py-2 text-sm font-medium border border-red-300 text-red-700 rounded-lg hover:bg-red-100 disabled:opacity-50">
                        @(isArchiving ? "Archiving..." : "Archive")
                    </button>
                </div>

                <div class="flex items-center justify-between p-4 bg-red-50 rounded-lg">
                    <div>
                        <h3 class="text-sm font-semibold text-red-900">Delete Season</h3>
                        <p class="text-sm text-red-700 mt-1">Permanently delete this season and all its data. This cannot be undone.</p>
                        @if (!string.IsNullOrEmpty(deleteError))
                        {
                            <p class="text-sm text-red-600 mt-1">@deleteError</p>
                        }
                    </div>
                    <button @onclick="DeleteSeason"
                            disabled="@isDeleting"
                            class="px-4 py-2 text-sm font-medium border border-red-300 text-red-700 rounded-lg hover:bg-red-100 disabled:opacity-50">
                        @(confirmDelete ? "Confirm Delete" : isDeleting ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        </div>
    </div>
}
