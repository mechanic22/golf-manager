@page "/league/{LeagueKey}/standings"
@layout AppLayout

<PageTitle>@(leagueName ?? LeagueKey) - Pinzo Golf</PageTitle>

<div class="flex items-center justify-center py-16">
    @if (isLoading)
    {
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-500 text-sm">Loading...</p>
        </div>
    }
    else if (noSeason)
    {
        <div class="bg-white rounded-lg border border-gray-200 p-12 text-center max-w-md">
            @if (!string.IsNullOrEmpty(logoUrl))
            {
                <img src="@logoUrl" alt="@leagueName" class="h-16 w-16 mx-auto mb-4 rounded-lg object-contain border border-gray-200 p-1" />
            }
            <div class="text-4xl mb-4">⛳</div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">No Active Season</h3>
            <p class="text-gray-500 text-sm">@(leagueName ?? LeagueKey) doesn't have an active season yet. Check back once the season begins.</p>
        </div>
    }
</div>
