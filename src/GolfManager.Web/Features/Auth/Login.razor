@page "/login"

<PageTitle>Sign In - Pinzo</PageTitle>

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background-color: #f9fafb; padding: 2rem;">
    <div class="card" style="max-width: 28rem; width: 100%; padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <img src="/img/pinzo-green.png" alt="Pinzo Golf" style="height: 2.5rem; margin-bottom: 1rem;" />
            <h1 style="font-size: 1.875rem; font-weight: 700; color: #111827; margin-bottom: 0.5rem;">Welcome Back</h1>
            <p style="color: #6b7280; font-size: 0.875rem;">Sign in to your Pinzo account</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
            </div>
        }

        <EditForm Model="@loginRequest" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">Email Address</label>
                <InputText id="email" @bind-Value="loginRequest.Email" class="form-control" placeholder="you@example.com" />
                <ValidationMessage For="@(() => loginRequest.Email)" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" type="password" @bind-Value="loginRequest.Password" class="form-control" placeholder="••••••••" />
                <ValidationMessage For="@(() => loginRequest.Password)" />
            </div>

            <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Signing In...</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </button>
        </EditForm>

        <div style="margin-top: 1.5rem; text-align: center; padding-top: 1.5rem; border-top: 1px solid #e5e7eb;">
            <p style="color: #6b7280; font-size: 0.875rem;">
                Don't have an account? <a href="/register" class="text-primary-600 font-medium">Create one</a>
            </p>
        </div>

        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
            @if (!showGuestForm)
            {
                <button type="button" @onclick="@(() => showGuestForm = true)"
                        style="width: 100%; background: none; border: none; color: #6b7280; font-size: 0.875rem; cursor: pointer; padding: 0.5rem 0; text-decoration: underline;">
                    View a league as a guest
                </button>
            }
            else
            {
                <p style="color: #6b7280; font-size: 0.75rem; margin-bottom: 0.75rem;">Enter your league key to continue as a guest viewer</p>
                <div style="display: flex; gap: 0.5rem;">
                    <input type="text" @bind="guestLeagueKey" placeholder="League key (e.g. dkgl)"
                           style="flex: 1; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.875rem;" />
                    <button type="button" @onclick="HandleGuestAccess"
                            style="padding: 0.5rem 1rem; background: #f3f4f6; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.875rem; cursor: pointer; white-space: nowrap;">
                        Continue
                    </button>
                </div>
            }
        </div>
    </div>
</div>

