@page "/league/{LeagueKey}/player/{PlayerId}"
@layout AppLayout
@using GolfManager.Shared.DTOs.Player

@if (isLoading)
{
    <div class="flex items-center justify-center min-h-screen">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading player...</p>
        </div>
    </div>
}
else if (league == null || player == null)
{
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <MaterialCard>
            <div class="p-8 text-center">
                <MaterialIcon Icon="MaterialIcons.ErrorOutline" Class="text-6xl text-gray-400 mb-4" />
                <h2 class="text-xl font-semibold text-gray-900 mb-2">Player Not Found</h2>
                <p class="text-gray-600 mb-6">The player you're looking for doesn't exist or you don't have access.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}"))">
                    Back to League
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        <!-- Back -->
        <div class="mb-4">
            <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}"))">
                <MaterialIcon Icon="MaterialIcons.ArrowBack" Class="mr-1" />
                Back to League
            </MaterialButton>
        </div>

        <!-- Hero Card -->
        <div class="relative overflow-hidden rounded-xl bg-linear-to-br from-primary-600 to-primary-800 text-white mb-8">
            <div class="absolute -top-12 -right-12 w-64 h-64 rounded-full bg-white/10 blur-3xl pointer-events-none"></div>
            <div class="absolute -bottom-8 -left-8 w-48 h-48 rounded-full bg-white/5 blur-2xl pointer-events-none"></div>

            <div class="relative p-6 md:p-8">
                <div class="flex flex-col md:flex-row items-start md:items-center gap-6">

                    <!-- Avatar + Identity -->
                    <div class="flex items-center gap-4 flex-1 min-w-0">
                        <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-white/20 border-2 border-white/30 flex items-center justify-center shrink-0">
                            <span class="text-2xl md:text-3xl font-bold">@GetInitials(player.DisplayName)</span>
                        </div>
                        <div class="min-w-0">
                            <p class="text-primary-200 text-xs uppercase tracking-widest mb-0.5">Player Profile</p>
                            <h1 class="text-2xl md:text-3xl font-bold leading-tight truncate">@player.DisplayName</h1>
                            @if (!string.IsNullOrEmpty(player.Nickname))
                            {
                                <p class="text-primary-200 text-sm">"@player.Nickname"</p>
                            }
                            <p class="text-primary-300 text-xs mt-1">Member since @player.JoinedAt.ToString("MMMM d, yyyy")</p>
                        </div>
                    </div>

                    <!-- Stats grid -->
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 w-full md:w-auto shrink-0">
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-18">
                            <div class="text-2xl font-bold">
                                @if (player.LeagueHandicap.HasValue)
                                { @string.Format("{0:F1}", player.LeagueHandicap.Value) }
                                else { <span class="text-white/50">—</span> }
                            </div>
                            <div class="text-primary-200 text-xs mt-0.5">Handicap</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-18">
                            <div class="text-2xl font-bold">@player.TotalRounds</div>
                            <div class="text-primary-200 text-xs mt-0.5">Rounds</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-18">
                            <div class="text-2xl font-bold">
                                @if (player.AverageScore.HasValue)
                                { @string.Format("{0:F1}", player.AverageScore.Value) }
                                else { <span class="text-white/50">—</span> }
                            </div>
                            <div class="text-primary-200 text-xs mt-0.5">Avg Score</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-3 text-center min-w-18">
                            <div class="text-2xl font-bold">
                                @if (player.BestScore.HasValue)
                                { @player.BestScore.Value }
                                else { <span class="text-white/50">—</span> }
                            </div>
                            <div class="text-primary-200 text-xs mt-0.5">Best</div>
                        </div>
                    </div>

                    <!-- Edit button -->
                    @if (league.IsCurrentUserAdmin)
                    {
                        <div class="shrink-0">
                            <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="OpenEditModal"
                                            Class="border-white/30 text-white hover:bg-white/10">
                                <MaterialIcon Icon="MaterialIcons.Edit" Class="mr-1" />
                                Edit
                            </MaterialButton>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Charts -->
        @{
            var scoreData = rounds.Count > 0 ? BuildScoreChartSeries() : new();
            var hcpData   = rounds.Count > 0 ? BuildHandicapTrendSeries() : new();
        }
        @if (scoreData.Any() || hcpData.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                @if (scoreData.Any())
                {
                    <MaterialCard>
                        <div class="p-5">
                            <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Score Trend</h3>
                            <LineChart chartSeries="@scoreData" YFormat="F0" MaxHeightPx="200" EmptyMessage="No score data" />
                        </div>
                    </MaterialCard>
                }
                @if (hcpData.Any())
                {
                    <MaterialCard>
                        <div class="p-5">
                            <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Handicap Over Time</h3>
                            <LineChart chartSeries="@hcpData" YFormat="F1" MaxHeightPx="200" EmptyMessage="No handicap data" />
                        </div>
                    </MaterialCard>
                }
            </div>
        }

        <!-- Round History -->
        <div class="mb-4 flex flex-col sm:flex-row sm:items-center justify-between gap-2">
            <h2 class="text-xl font-semibold text-gray-900">Round History</h2>
            <span class="text-sm text-gray-500">@FilteredRounds.Count() round@(FilteredRounds.Count() == 1 ? "" : "s")</span>
        </div>

        <!-- Season Filter -->
        @if (PlayerSeasons.Count > 1)
        {
            <div class="flex flex-wrap items-center gap-2 mb-4">
                <button @onclick="SelectAllSeasons"
                        class="@(showAllSeasons
                            ? "bg-primary-600 text-white border-primary-600"
                            : "bg-white text-gray-700 border-gray-300 hover:border-primary-400") px-3 py-1.5 rounded-full text-sm font-medium border transition-colors">
                    All Seasons
                </button>
                @foreach (var season in PlayerSeasons)
                {
                    var sid = season.Id;
                    var sname = season.Name;
                    var isActive = !showAllSeasons && selectedSeasonIds.Contains(sid);
                    <button @onclick="@(() => ToggleSeason(sid))"
                            class="@(isActive
                                ? "bg-primary-600 text-white border-primary-600"
                                : "bg-white text-gray-700 border-gray-300 hover:border-primary-400") px-3 py-1.5 rounded-full text-sm font-medium border transition-colors">
                        @sname
                    </button>
                }
            </div>
        }

        @if (isLoadingRounds)
        {
            <MaterialCard>
                <div class="p-6 text-center py-12">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mb-3"></div>
                    <p class="text-gray-600">Loading rounds...</p>
                </div>
            </MaterialCard>
        }
        else
        {
            <MaterialCard>
                <ResponsiveTable TItem="GolfManager.Shared.DTOs.Round.RoundResponse" Items="@FilteredRounds">
                    <Headers>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Course</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Holes</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Gross</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Net</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Handicap</th>
                    </Headers>
                    <Row Context="round">
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                @(round.RoundDate == default ? "—" : round.RoundDate.ToString("MMM d, yyyy"))
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-medium text-gray-900">@round.CourseName</div>
                                @if (!string.IsNullOrEmpty(round.TeeName))
                                {
                                    <div class="text-xs text-gray-500">@round.TeeName tees</div>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@round.HolesPlayed</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                                @if (round.TotalScore.HasValue)
                                { <span class="font-semibold text-gray-900">@round.TotalScore</span> }
                                else { <span class="text-gray-400">—</span> }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                                @if (round.NetScore.HasValue)
                                { <span class="text-blue-700 font-medium">@round.NetScore</span> }
                                else { <span class="text-gray-400">—</span> }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-600">
                                @(round.HandicapUsed.HasValue ? round.HandicapUsed.Value.ToString("F1") : "—")
                            </td>
                        </tr>
                    </Row>
                    <Card Context="round">
                        <div class="border-b border-gray-100 px-4 py-4">
                            <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0">
                                    <div class="font-medium text-gray-900 truncate">@round.CourseName</div>
                                    @if (!string.IsNullOrEmpty(round.TeeName))
                                    {
                                        <div class="text-xs text-gray-500">@round.TeeName tees</div>
                                    }
                                    <div class="text-sm text-gray-500 mt-0.5">
                                        @(round.RoundDate == default ? "—" : round.RoundDate.ToString("MMM d, yyyy"))
                                    </div>
                                </div>
                                @if (round.TotalScore.HasValue)
                                {
                                    <div class="text-right shrink-0">
                                        <div class="text-2xl font-bold text-gray-900">@round.TotalScore</div>
                                        <div class="text-xs text-gray-500">Gross</div>
                                    </div>
                                }
                            </div>
                            <div class="flex flex-wrap gap-3 mt-3 text-sm">
                                @if (round.NetScore.HasValue)
                                {
                                    <div><span class="text-gray-500">Net</span> <span class="font-semibold text-blue-700">@round.NetScore</span></div>
                                }
                                @if (round.HandicapUsed.HasValue)
                                {
                                    <div><span class="text-gray-500">HCP</span> <span class="font-medium text-gray-700">@round.HandicapUsed.Value.ToString("F1")</span></div>
                                }
                                <div><span class="text-gray-500">Holes</span> <span class="font-medium text-gray-700">@round.HolesPlayed</span></div>
                            </div>
                        </div>
                    </Card>
                    <Empty>
                        <div class="p-6 text-center py-12">
                            <MaterialIcon Icon="MaterialIcons.GolfCourse" Class="text-6xl text-gray-300 mb-4" />
                            <h3 class="text-lg font-semibold text-gray-900 mb-2">No Rounds Yet</h3>
                            <p class="text-gray-600">This player hasn't posted any rounds in this league.</p>
                        </div>
                    </Empty>
                </ResponsiveTable>
            </MaterialCard>
        }

    </div>
}

@if (showEditModal && player != null)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-112">
            <div class="flex items-center justify-between p-6 border-b border-gray-200">
                <h2 class="text-xl font-semibold text-gray-900">Edit Player</h2>
                <button @onclick="CloseEditModal" class="text-gray-400 hover:text-gray-600">
                    <MaterialIcon Icon="MaterialIcons.Close" />
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label>
                    <input type="text" @bind="editDisplayName"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                           placeholder="Display name" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nickname</label>
                    <input type="text" @bind="editNickname"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                           placeholder="Nickname (optional)" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">League Handicap</label>
                    <input type="number" step="0.1" @bind="editHandicap"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                           placeholder="e.g. 12.4" />
                </div>
                @if (!string.IsNullOrEmpty(editError))
                {
                    <p class="text-sm text-red-600">@editError</p>
                }
            </div>
            <div class="flex justify-end gap-3 px-6 py-4 border-t border-gray-200">
                <MaterialButton Style="MaterialButtonStyle.Text" OnClick="CloseEditModal" Text="Cancel" />
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="SaveEdit" Disabled="isSavingEdit" Text="@(isSavingEdit ? "Saving…" : "Save")" />
            </div>
        </div>
    </div>
}
