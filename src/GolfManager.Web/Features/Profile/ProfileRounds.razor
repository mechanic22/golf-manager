@page "/profile/rounds"
@layout AppLayout
@using GolfManager.Shared.DTOs.Round

<PageTitle>My Rounds - Pinzo</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    <div class="text-center py-16">
        <p class="text-gray-600">Please log in to view your rounds.</p>
    </div>
}
else
{
    <!-- Breadcrumb -->
    <div class="mb-6 flex items-center gap-2 text-sm text-gray-600">
        <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
        <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
        <a href="/profile" class="hover:text-primary-600">Profile</a>
        <MaterialIcon Icon="MaterialIcons.ChevronRight" Class="text-xs" />
        <span class="text-gray-900">Rounds</span>
    </div>

    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">My Rounds</h1>
        <p class="text-gray-600 mt-1">Complete history of all your rounds</p>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Date Range</label>
                <select @bind="selectedDateRange"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
                    <option value="all">All Time</option>
                    <option value="30">Last 30 Days</option>
                    <option value="90">Last 90 Days</option>
                    <option value="year">This Year</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">League</label>
                <select @bind="selectedLeagueId"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
                    <option value="all">All Leagues</option>
                    @foreach (var league in leagueOptions)
                    {
                        <option value="@league.Id">@league.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Course</label>
                <select @bind="selectedCourse"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
                    <option value="all">All Courses</option>
                    @foreach (var course in courseOptions)
                    {
                        <option value="@course">@course</option>
                    }
                </select>
            </div>
            <div class="flex items-end">
                <MaterialButton Style="MaterialButtonStyle.Filled"
                                Text="Apply Filters"
                                Class="w-full"
                                OnClick="ApplyFilters" />
            </div>
        </div>
    </div>

    <!-- Rounds List -->
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Course</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">League/Event</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Score</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Handicap Used</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @if (isLoading)
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center">
                            <div class="flex justify-center">
                                <MaterialProgressIndicator Variant="MaterialProgressVariant.Circular" />
                            </div>
                        </td>
                    </tr>
                }
                else if (!PagedRounds.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                            @if (!rounds.Any())
                            {
                                <span>No rounds found. Play some golf and track your scores!</span>
                            }
                            else
                            {
                                <span>No rounds match the selected filters.</span>
                            }
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var round in PagedRounds)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@round.RoundDate.ToString("MMM dd, yyyy")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                <div>@round.CourseName</div>
                                <div class="text-xs text-gray-500">@round.TeeName</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@(round.LeagueId != null ? "League" : "Casual")</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="@GetScoreClass(round.TotalScore ?? 0)">@(round.TotalScore?.ToString() ?? "-")</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@(round.HandicapUsed?.ToString("F1") ?? "-")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (!isLoading && rounds.Any())
    {
        <div class="mt-6 flex items-center justify-between">
            <p class="text-sm text-gray-600">
                @if (TotalFiltered == 0)
                {
                    <span>No results</span>
                }
                else
                {
                    <span>Showing @ShowingFrom–@ShowingTo of @TotalFiltered round@(TotalFiltered == 1 ? "" : "s")</span>
                }
            </p>
            <div class="flex gap-2">
                <MaterialButton Style="MaterialButtonStyle.Outlined"
                                Text="Previous"
                                Disabled="@(currentPage <= 1)"
                                OnClick="PreviousPage" />
                <MaterialButton Style="MaterialButtonStyle.Outlined"
                                Text="Next"
                                Disabled="@(currentPage >= TotalPages)"
                                OnClick="NextPage" />
            </div>
        </div>
    }
}
