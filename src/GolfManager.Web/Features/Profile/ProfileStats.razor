@page "/profile/stats"
@layout AppLayout
@using GolfManager.Shared.DTOs.User

<PageTitle>My Stats - Pinzo</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    <div class="text-center py-16">
        <p class="text-gray-600">Please log in to view your stats.</p>
    </div>
}
else if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="text-center">
            <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
            <p class="text-gray-600">Loading stats...</p>
        </div>
    </div>
}
else
{
    <!-- Breadcrumb -->
    <div class="mb-6 text-sm text-gray-600">
        <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
        <span class="mx-2">/</span>
        <a href="/profile" class="hover:text-primary-600">Profile</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Stats</span>
    </div>

    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">My Statistics</h1>
        <p class="text-gray-600">Detailed analysis of your golf performance</p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="text-sm text-gray-500 mb-1">Scoring Average</div>
            <div class="text-3xl font-bold text-primary-600">
                @(stats?.AverageGrossScore?.ToString("F1") ?? "—")
            </div>
            <div class="text-xs text-gray-500 mt-1">Gross score per round</div>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="text-sm text-gray-500 mb-1">Best Score</div>
            <div class="text-3xl font-bold text-gray-900">
                @(stats?.LowGrossScore?.ToString() ?? "—")
            </div>
            <div class="text-xs text-gray-500 mt-1">All-time low gross</div>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="text-sm text-gray-500 mb-1">Rounds This Year</div>
            <div class="text-3xl font-bold text-gray-900">@(stats?.RoundsThisYear ?? 0)</div>
            <div class="text-xs text-gray-500 mt-1">@(stats?.RoundsLast30Days ?? 0) in last 30 days</div>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="text-sm text-gray-500 mb-1">Handicap Index</div>
            <div class="text-3xl font-bold text-primary-600">
                @(stats?.CurrentHandicap?.ToString("F1") ?? "—")
            </div>
            <div class="text-xs text-gray-500 mt-1">Current index</div>
        </div>
    </div>

    <!-- Performance by Course -->
    <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Performance by Course</h2>
        @if (stats?.CourseStats == null || !stats.CourseStats.Any())
        {
            <p class="text-gray-500">No course data yet. Record some rounds to see your course performance.</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var course in stats.CourseStats)
                {
                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                        <div>
                            <p class="font-medium text-gray-900">@course.CourseName</p>
                            <p class="text-sm text-gray-500">@course.Rounds round@(course.Rounds != 1 ? "s" : "")</p>
                        </div>
                        <div class="text-right">
                            <p class="font-semibold text-primary-600">@course.AverageScore.ToString("F1") avg</p>
                            <p class="text-sm text-gray-500">Best: @course.BestScore</p>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Summary -->
    @if (stats != null && stats.RoundsPlayed == 0)
    {
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 text-center">
            <p class="text-blue-800 font-medium mb-2">No rounds recorded yet</p>
            <p class="text-sm text-blue-700">Play and record rounds in your leagues to see your statistics here.</p>
        </div>
    }
    else
    {
        <div class="bg-gray-50 rounded-lg p-4 text-sm text-gray-500 text-center">
            Based on @(stats?.RoundsPlayed ?? 0) total rounds recorded
        </div>
    }
}

