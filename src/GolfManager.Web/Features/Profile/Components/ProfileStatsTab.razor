@using GolfManager.Shared.DTOs.User

@if (isLoading)
{
    <div class="flex items-center justify-center py-8">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
    </div>
}
else
{
    <div class="space-y-6">
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-white rounded-lg border border-gray-200 p-5">
                <div class="text-sm text-gray-500 mb-1">Scoring Average</div>
                <div class="text-3xl font-bold text-primary-600">@(stats?.AverageGrossScore?.ToString("F1") ?? "—")</div>
                <div class="text-xs text-gray-500 mt-1">Gross score per round</div>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-5">
                <div class="text-sm text-gray-500 mb-1">Best Score</div>
                <div class="text-3xl font-bold text-gray-900">@(stats?.LowGrossScore?.ToString() ?? "—")</div>
                <div class="text-xs text-gray-500 mt-1">All-time low gross</div>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-5">
                <div class="text-sm text-gray-500 mb-1">Rounds This Year</div>
                <div class="text-3xl font-bold text-gray-900">@(stats?.RoundsThisYear ?? 0)</div>
                <div class="text-xs text-gray-500 mt-1">@(stats?.RoundsLast30Days ?? 0) in last 30 days</div>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-5">
                <div class="text-sm text-gray-500 mb-1">Handicap Index</div>
                <div class="text-3xl font-bold text-primary-600">@(stats?.CurrentHandicap?.ToString("F1") ?? "—")</div>
                <div class="text-xs text-gray-500 mt-1">Current index</div>
            </div>
        </div>

        <!-- Performance by Course -->
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Performance by Course</h3>
            @if (stats?.CourseStats == null || !stats.CourseStats.Any())
            {
                <p class="text-gray-500 text-sm">No course data yet. Record some rounds to see your performance by course.</p>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var course in stats.CourseStats)
                    {
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                            <div>
                                <p class="font-medium text-gray-900">@course.CourseName</p>
                                <p class="text-sm text-gray-500">@course.Rounds round@(course.Rounds != 1 ? "s" : "")</p>
                            </div>
                            <div class="text-right">
                                <p class="font-semibold text-primary-600">@course.AverageScore.ToString("F1") avg</p>
                                <p class="text-sm text-gray-500">Best: @course.BestScore</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Coming Soon Stats -->
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">More Stats <span class="text-sm font-normal text-gray-400 ml-2">Coming Soon</span></h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                @foreach (var stat in ComingSoonStats)
                {
                    <div class="bg-gray-50 rounded-lg p-4 opacity-60">
                        <div class="text-sm text-gray-500 mb-1">@stat</div>
                        <div class="text-2xl font-bold text-gray-300">—</div>
                    </div>
                }
            </div>
        </div>

        @if (stats != null && stats.RoundsPlayed == 0)
        {
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-5 text-center">
                <p class="text-blue-800 font-medium mb-1">No rounds recorded yet</p>
                <p class="text-sm text-blue-700">Play and record rounds in your leagues to see statistics here.</p>
            </div>
        }
        else if (stats != null)
        {
            <p class="text-sm text-gray-400 text-center">Based on @stats.RoundsPlayed total rounds recorded</p>
        }
    </div>
}
