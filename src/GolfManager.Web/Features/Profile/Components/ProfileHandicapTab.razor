@using GolfManager.Shared.DTOs.Handicap

@if (isLoading)
{
    <div class="flex items-center justify-center py-8">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
    </div>
}
else
{
    <div class="space-y-6">
        <!-- Current Handicap -->
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-lg font-semibold text-gray-900">Current Handicap Index</h3>
                <span class="text-4xl font-bold text-primary-600">
                    @(currentHandicap > 0 ? currentHandicap.ToString("F1") : "—")
                </span>
            </div>
            @if (lastUpdated.HasValue)
            {
                <p class="text-sm text-gray-500">Last updated: @lastUpdated.Value.ToString("MMMM dd, yyyy")</p>
            }
            else
            {
                <p class="text-sm text-gray-500">No handicap recorded yet.</p>
            }
        </div>

        <!-- History -->
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Handicap History</h3>

            @if (!handicapHistory.Any())
            {
                <p class="text-gray-500 text-sm">No history yet. Play and record rounds to build your handicap.</p>
            }
            else
            {
                <div class="space-y-2">
                    @foreach (var entry in handicapHistory)
                    {
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                            <div>
                                <p class="text-sm font-medium text-gray-900">@(entry.CalculationMethod ?? "Calculated")</p>
                                <p class="text-xs text-gray-500">@entry.EffectiveDate.ToString("MMM dd, yyyy")</p>
                                @if (entry.RoundsUsed.HasValue)
                                {
                                    <p class="text-xs text-gray-400">Based on @entry.RoundsUsed rounds</p>
                                }
                            </div>
                            <div class="text-right">
                                <p class="font-semibold text-gray-900">@entry.HandicapIndex.ToString("F1")</p>
                                @if (!string.IsNullOrEmpty(entry.Notes))
                                {
                                    <p class="text-xs text-gray-500">@entry.Notes</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Explanation -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-5">
            <h4 class="font-semibold text-blue-900 mb-2">How is my handicap calculated?</h4>
            <p class="text-sm text-blue-800">
                Your Handicap Index uses the best 8 of your last 20 rounds. Each round's score differential
                is calculated from the course rating and slope. The average of your best 8 differentials
                is multiplied by 0.96 to produce your index.
            </p>
        </div>
    </div>
}
