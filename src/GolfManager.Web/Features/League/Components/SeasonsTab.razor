@using GolfManager.Shared.DTOs.League
@using GolfManager.Shared.DTOs.Season
@using MaterialComponents
@inject ISeasonService SeasonService
@inject NavigationManager Navigation
@inject ILogger<SeasonsTab> Logger

<div class="mb-6">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">Seasons</h2>
            <p class="text-gray-600 text-sm">All seasons in this league</p>
        </div>
        @if (CanManageLeague)
        {
            <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="OnCreateSeason">
                <MaterialIcon Icon="MaterialIcons.Add" Class="mr-1" />
                Create Season
            </MaterialButton>
        }
    </div>
</div>

@if (isLoading)
{
    <div class="flex items-center justify-center py-8">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
    </div>
}
else if (seasons == null || !seasons.Any())
{
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-12">
            <MaterialIcon Icon="MaterialIcons.CalendarToday" Class="text-gray-400 text-5xl mb-4" />
            <p class="text-gray-600">No seasons yet</p>
        </div>
    </MaterialCard>
}
else
{
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content p-0">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-full">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Start</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">End</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Events</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Golfers</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var season in seasons.OrderByDescending(s => s.StartDate))
                        {
                            <tr class="hover:bg-gray-50 cursor-pointer"
                                @onclick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{season.Key}"))">
                                <td class="px-6 py-4">
                                    <span class="font-medium text-primary-700 hover:underline">@season.Name</span>
                                    <span class="ml-2 text-xs text-gray-400 font-mono">@season.Key</span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 whitespace-nowrap">@season.StartDate.ToString("MMM d, yyyy")</td>
                                <td class="px-6 py-4 text-sm text-gray-600 whitespace-nowrap">
                                    @(season.EndDate?.ToString("MMM d, yyyy") ?? "—")
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">@season.EventCount</td>
                                <td class="px-6 py-4 text-sm text-gray-600">@season.GolferCount</td>
                                <td class="px-6 py-4 text-sm">
                                    @if (season.IsLocked)
                                    {
                                        <span class="text-gray-400">Locked</span>
                                    }
                                    else
                                    {
                                        <span class="font-medium text-green-600">Active</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </MaterialCard>
}

@code {
    [Parameter, EditorRequired]
    public LeagueResponse League { get; set; } = null!;

    [Parameter, EditorRequired]
    public string LeagueKey { get; set; } = string.Empty;

    [Parameter]
    public bool CanManageLeague { get; set; }

    [Parameter]
    public EventCallback OnCreateSeason { get; set; }

    private List<SeasonResponse>? seasons;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSeasons();
    }

    private async Task LoadSeasons()
    {
        isLoading = true;
        try
        {
            var response = await SeasonService.GetLeagueSeasonsAsync(League.Id);
            seasons = response?.Success == true && response.Data != null
                ? response.Data.ToList()
                : [];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading seasons");
            seasons = [];
        }
        finally
        {
            isLoading = false;
        }
    }
}
