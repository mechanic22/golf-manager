@using GolfManager.Shared.DTOs.League
@using MaterialComponents.Models
@inject ILeagueService LeagueService
@inject ILogger<SettingsTab> Logger

<div class="mb-6">
    <h2 class="text-xl font-semibold text-gray-900">League Settings</h2>
    <p class="text-gray-600 text-sm">Configure your league preferences and details</p>
</div>

@if (!canEdit)
{
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-12">
            <MaterialIcon Icon="MaterialIcons.Lock" Class="text-gray-400 text-5xl mb-4" />
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Admin Access Required</h3>
            <p class="text-gray-600">Only league administrators can modify league settings</p>
        </div>
    </MaterialCard>
}
else if (isEditing)
{
    <!-- Edit Form -->
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content">
            <form @onsubmit="SaveChanges">
                <div class="space-y-6">
                    <!-- League Name -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            League Name <span class="text-red-600">*</span>
                        </label>
                        <input type="text" @bind="editName" placeholder="Enter league name" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    </div>

                    <!-- Description -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            Description
                        </label>
                        <textarea @bind="editDescription" placeholder="League description (optional)" rows="4"
                                  class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"></textarea>
                    </div>

                    <!-- Logo URL -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            Logo URL
                        </label>
                        <input type="url" @bind="editLogoUrl" placeholder="https://example.com/logo.png"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                        <p class="text-xs text-gray-500 mt-1">Enter a URL to an image to use as the league logo</p>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
                            <div class="flex items-center gap-2 text-red-800">
                                <MaterialIcon Icon="MaterialIcons.Error" Size="MaterialComponents.Icons.IconSize.SM" />
                                <span class="text-sm">@errorMessage</span>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
                            <div class="flex items-center gap-2 text-green-800">
                                <MaterialIcon Icon="MaterialIcons.CheckCircle" Size="MaterialComponents.Icons.IconSize.SM" />
                                <span class="text-sm">@successMessage</span>
                            </div>
                        </div>
                    }

                    <!-- Action Buttons -->
                    <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
                        <MaterialButton Style="MaterialButtonStyle.Filled" Type="submit" Disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span>Saving...</span>
                            }
                            else
                            {
                                <MaterialIcon Icon="MaterialIcons.Save" Class="mr-1" />
                                <span>Save Changes</span>
                            }
                        </MaterialButton>
                        <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="CancelEdit" Disabled="@isSaving">
                            Cancel
                        </MaterialButton>
                    </div>
                </div>
            </form>
        </div>
    </MaterialCard>
}
else
{
    <!-- View Mode -->
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content">
            <div class="space-y-6">
                <!-- League Name -->
                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">League Name</label>
                    <p class="text-base text-gray-900">@League.Name</p>
                </div>

                <!-- League Key -->
                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">League Key</label>
                    <p class="text-base text-gray-900 font-mono">@League.Key</p>
                    <p class="text-xs text-gray-500 mt-1">This cannot be changed</p>
                </div>

                <!-- Description -->
                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">Description</label>
                    <p class="text-base text-gray-900">@(League.Description ?? "No description provided")</p>
                </div>

                <!-- Logo URL -->
                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">Logo URL</label>
                    @if (!string.IsNullOrEmpty(League.LogoUrl))
                    {
                        <div class="flex items-center gap-4">
                            <img src="@League.LogoUrl" alt="@League.Name"
                                 class="w-16 h-16 rounded-lg object-cover border border-gray-200" />
                            <a href="@League.LogoUrl" target="_blank"
                               class="text-primary-600 hover:text-primary-700 text-sm break-all">
                                @League.LogoUrl
                            </a>
                        </div>
                    }
                    else
                    {
                        <p class="text-base text-gray-500">No logo set</p>
                    }
                </div>

                <!-- Edit Button -->
                <div class="pt-4 border-t border-gray-200">
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="StartEdit">
                        <MaterialIcon Icon="MaterialIcons.Edit" Class="mr-1" />
                        Edit Settings
                    </MaterialButton>
                </div>
            </div>
        </div>
    </MaterialCard>

    <!-- Anonymous Guest Access -->
    <div class="mt-8">
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content">
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Guest Access</h3>
                <p class="text-sm text-gray-600 mb-4">Allow non-members to view team standings using a shareable link</p>

                <!-- Guest Access Toggle -->
                <div class="space-y-4">
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border border-gray-200">
                        <div>
                            <label class="block text-sm font-medium text-gray-900 mb-1">Enable Guest Access</label>
                            <p class="text-xs text-gray-600">Others can view standings if they have the link and password
                            </p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" checked="@guestAccessEnabled" @onchange="HandleGuestAccessToggle"
                                   class="sr-only peer">
                            <div
                                class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600">
                            </div>
                        </label>
                    </div>

                    @if (guestAccessEnabled)
                    {
                        <!-- Password Section -->
                        <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg">
                            <label class="block text-sm font-medium text-gray-900 mb-2">Access Password</label>
                            <div class="flex gap-2 mb-2">
                                <input type="text" @bind="guestAccessPassword" placeholder="Enter a password (optional)"
                                       class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-sm" />
                                <button type="button" @onclick="GeneratePassword"
                                        class="px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">
                                    Generate
                                </button>
                                <button type="button" @onclick="ClearGuestPassword"
                                        class="px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">
                                    Clear
                                </button>
                            </div>
                            <p class="text-xs text-gray-600">Leave blank for no password</p>
                        </div>

                        <!-- Share Link Section -->
                        <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
                            <label class="block text-sm font-medium text-gray-900 mb-2">Shareable Link</label>
                            <div class="flex items-center gap-2">
                                <input type="text" readonly value="@GetGuestLink()"
                                       class="flex-1 px-3 py-2 border border-gray-300 rounded-lg bg-white text-sm font-mono" />
                                <button type="button" @onclick="CopyLinkToClipboard"
                                        class="px-3 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700">
                                    @(linkCopied ? "✓ Copied" : "Copy")
                                </button>
                            </div>
                            <p class="text-xs text-gray-600 mt-2">Share this link with others. They'll need the password (if
                                set) to view standings.</p>
                            </div>

                            <!-- Update Guest Settings -->
                            <div class="flex gap-2">
                                <button type="button" @onclick="SaveGuestSettings"
                                        class="px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700">
                                    Save Settings
                                </button>
                                <button type="button" @onclick="CancelGuestSettings"
                                        class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">
                                    Cancel
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </MaterialCard>
        </div>

        <!-- Danger Zone -->
        <div class="mt-8">
            <MaterialCard Variant="MaterialCardVariant.Outlined" Class="border-red-200">
                <div class="md-card__content">
                    <h3 class="text-lg font-semibold text-red-900 mb-2">Danger Zone</h3>
                    <p class="text-sm text-gray-600 mb-4">Irreversible and destructive actions</p>
                    <MaterialButton Style="MaterialButtonStyle.Outlined" Class="border-red-600 text-red-600 hover:bg-red-50">
                        <MaterialIcon Icon="MaterialIcons.Delete" Class="mr-1" />
                        Delete League
                    </MaterialButton>
                    <p class="text-xs text-gray-500 mt-2">This will permanently delete the league and all associated data</p>
                </div>
            </MaterialCard>
        </div>
    }

@code {
    [Parameter, EditorRequired]
    public LeagueResponse League { get; set; } = null!;

    [Parameter, EditorRequired]
    public string LeagueKey { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnLeagueUpdated { get; set; }

    [Parameter]
    public bool CanEdit { get; set; }

    private bool canEdit = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private string? errorMessage;
    private string? successMessage;

    // Edit form fields
    private string editName = string.Empty;
    private string? editDescription;
    private string? editLogoUrl;

    // Guest access fields
    private bool guestAccessEnabled = false;
    private string? guestAccessPassword;
    private bool linkCopied = false;
    private System.Timers.Timer? copyTimer;

    protected override void OnInitialized()
    {
        canEdit = CanEdit;
        guestAccessEnabled = League.RequireAnonymousPassword;
    }

    private void StartEdit()
    {
        isEditing = true;
        editName = League.Name;
        editDescription = League.Description;
        editLogoUrl = League.LogoUrl;
        errorMessage = null;
        successMessage = null;
    }

    private void CancelEdit()
    {
        isEditing = false;
        errorMessage = null;
        successMessage = null;
    }

    private async Task SaveChanges()
    {
        if (string.IsNullOrWhiteSpace(editName))
        {
            errorMessage = "League name is required";
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var request = new UpdateLeagueRequest
            {
                Name = editName,
                Description = editDescription,
                LogoUrl = editLogoUrl
            };

            var response = await LeagueService.UpdateLeagueAsync(League.Id, request);

            if (response?.Success == true && response.Data != null)
            {
                successMessage = "League settings updated successfully!";
                isEditing = false;

                // Notify parent to reload league data
                await OnLeagueUpdated.InvokeAsync();

                Logger.LogInformation("League {LeagueId} updated successfully", League.Id);
            }
            else
            {
                errorMessage = response?.Message ?? "Failed to update league settings";
                Logger.LogWarning("Failed to update league: {Error}", errorMessage);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating league settings");
            errorMessage = "An error occurred while saving. Please try again.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void HandleGuestAccessToggle(ChangeEventArgs e)
    {
        guestAccessEnabled = (bool)(e.Value ?? false);

        // When toggling on, load current settings; when toggling off, clear password
        if (guestAccessEnabled && !League.HasAnonymousPassword)
        {
            guestAccessPassword = null;
        }
    }

    private async Task SaveGuestSettings()
    {
        isSaving = true;
        try
        {
            var request = new UpdateLeagueRequest
            {
                RequireAnonymousPassword = guestAccessEnabled,
                AnonymousAccessPassword = guestAccessPassword,
                IsPubliclyDiscoverable = true // Auto-enable public discovery with guest access
            };

            var response = await LeagueService.UpdateLeagueAsync(League.Id, request);

            if (response?.Success == true)
            {
                successMessage = "Guest access settings updated!";
                await OnLeagueUpdated.InvokeAsync();
            }
            else
            {
                errorMessage = response?.Message ?? "Failed to save guest settings";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving guest settings");
            errorMessage = "Failed to save settings. Please try again.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelGuestSettings()
    {
        guestAccessEnabled = League.RequireAnonymousPassword;
        guestAccessPassword = null;
        successMessage = null;
        errorMessage = null;
    }

    private void GeneratePassword()
    {
        // Generate a random 8-character alphanumeric password
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
        var random = new System.Random();
        guestAccessPassword = new string(Enumerable.Range(0, 8)
            .Select(_ => chars[random.Next(chars.Length)])
            .ToArray());
    }

    private void ClearGuestPassword()
    {
        guestAccessPassword = null;
    }

    private string GetGuestLink()
    {
        var baseUrl = new Uri(League.CustomDomain ?? "pinzogolf.com");
        return $"{baseUrl.Scheme}://{baseUrl.Host}/league/{League.Key}/guest";
    }

    private async Task CopyLinkToClipboard()
    {
        try
        {
            // This would require JS interop to access clipboard
            // For now, just show visual feedback
            linkCopied = true;
            if (copyTimer != null)
            {
                copyTimer.Stop();
                copyTimer.Dispose();
            }
            copyTimer = new System.Timers.Timer(2000);
            copyTimer.Elapsed += (s, e) =>
            {
                linkCopied = false;
                copyTimer?.Dispose();
                StateHasChanged();
            };
            copyTimer.Start();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error copying link");
        }
    }
}
