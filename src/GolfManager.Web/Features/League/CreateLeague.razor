@page "/leagues/create"
@layout AppLayout
@using GolfManager.Shared.DTOs.League

<PageTitle>Create League - Pinzo</PageTitle>

@if (!canCreate)
{
    <div class="text-center py-16">
        <MaterialIcon Path="@MaterialIcons.LockClosed" Size="MaterialComponents.Icons.IconSize.XL" Class="text-gray-400 mb-4" />
        <h2 class="text-2xl font-semibold text-gray-900 mb-2">Access Denied</h2>
        <p class="text-gray-600 mb-4">You must be signed in to create a league.</p>
        <MaterialButton Style="MaterialButtonStyle.Outlined" 
                      Text="Back to Leagues"
                      OnClick="@(() => Navigation.NavigateTo("/leagues"))" />
    </div>
}
else
{
    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex items-center gap-2 text-sm text-gray-600 mb-2">
            <a href="/dashboard" class="hover:text-primary-600">Dashboard</a>
            <span>/</span>
            <a href="/leagues" class="hover:text-primary-600">Leagues</a>
            <span>/</span>
            <span class="text-gray-900">Create League</span>
        </div>
        <h1 class="text-3xl font-bold text-gray-900">Create New League</h1>
    </div>

    <!-- Create Form -->
    <div class="max-w-2xl">
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <EditForm Model="@request" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">League Name *</label>
                    <input type="text"
                           value="@request.Name"
                           @oninput="HandleNameInput"
                           placeholder="e.g., Sunset Golf League"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    <ValidationMessage For="@(() => request.Name)" />
                </div>

                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">League Key *</label>
                    <input type="text"
                           value="@request.Key"
                           @oninput="HandleKeyInput"
                           placeholder="sunset-golf-league"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg font-mono focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    <p class="mt-1 text-xs text-gray-500">Used in the league URL. Lowercase letters, numbers, and hyphens only.</p>
                    <ValidationMessage For="@(() => request.Key)" />
                </div>

                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                    <textarea @bind="request.Description"
                              rows="4"
                              placeholder="Describe your league..."
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"></textarea>
                    <ValidationMessage For="@(() => request.Description)" />
                </div>

                <div class="mb-6">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Logo URL</label>
                    <input type="url"
                           @bind="request.LogoUrl"
                           placeholder="https://example.com/logo.png"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    <ValidationMessage For="@(() => request.LogoUrl)" />
                </div>

                <div class="mb-6 rounded-lg border border-gray-200 bg-gray-50 p-4">
                    <div class="mb-4 flex items-center gap-3">
                        <input id="use-custom-domain"
                               type="checkbox"
                               @bind="request.UseCustomDomain"
                               class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
                        <label for="use-custom-domain" class="text-sm font-medium text-gray-700">Enable custom domain</label>
                    </div>

                    <label class="block text-sm font-medium text-gray-700 mb-2">Custom Domain</label>
                    <input type="text"
                           @bind="request.CustomDomain"
                           placeholder="golf.example.com"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                           disabled="@(!request.UseCustomDomain)" />
                    <p class="mt-1 text-xs text-gray-500">You can verify DNS later from league settings after the league is created.</p>
                    <ValidationMessage For="@(() => request.CustomDomain)" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                        <p class="text-sm text-red-700">@errorMessage</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
                        <p class="text-sm text-green-700">@successMessage</p>
                    </div>
                }

                <!-- Actions -->
                <div class="flex gap-3">
                    <MaterialButton Style="MaterialButtonStyle.Filled"
                                  Text="Create League"
                                  Type="submit"
                                  Disabled="@isSubmitting" />
                    <MaterialButton Style="MaterialButtonStyle.Outlined"
                                  Text="Cancel"
                                  OnClick="@(() => Navigation.NavigateTo("/leagues"))" />
                </div>
            </EditForm>
        </div>

        <!-- Info Box -->
        <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
            <div class="flex items-start gap-3">
                <MaterialIcon Path="@GolfIcons.Info" Class="text-blue-600 flex-shrink-0" />
                <div class="text-sm text-blue-900">
                    <p class="font-semibold mb-1">What happens next?</p>
                    <p>After creating your league, you'll land on the league dashboard as the owner and can immediately manage settings, seasons, and members.</p>
                </div>
            </div>
        </div>
    </div>
}

