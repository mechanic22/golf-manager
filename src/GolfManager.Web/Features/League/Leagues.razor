@page "/leagues"
@page "/discover"
@layout AppLayout
@using GolfManager.Shared.DTOs.League

<PageTitle>Leagues - Pinzo</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center py-16">
        <div class="inline-block animate-spin rounded-full h-10 w-10 border-b-2 border-primary-600"></div>
    </div>
}
else
{
    <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
            <h1 class="text-2xl font-bold text-gray-900">Leagues</h1>
            @if (canCreateLeague)
            {
                <button @onclick="@(() => Navigation.NavigateTo("/leagues/create"))"
                        class="px-3 py-1.5 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">
                    + Create League
                </button>
            }
        </div>

        <!-- My Leagues -->
        <h2 class="text-base font-semibold text-gray-700 mb-2">My Leagues</h2>

        @if (myLeagues == null || !myLeagues.Any())
        {
            <p class="text-gray-500 text-sm mb-6">You're not a member of any leagues yet.</p>
        }
        else
        {
            <div class="overflow-x-auto mb-8">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead>
                        <tr class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            <th class="py-3 pr-6 w-full">Name</th>
                            <th class="py-3 pr-6">Members</th>
                            <th class="py-3 pr-6">Seasons</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var league in myLeagues)
                        {
                            <tr class="hover:bg-gray-50 cursor-pointer" @onclick="@(() => Navigation.NavigateTo($"/league/{league.Key}"))">
                                <td class="py-3 pr-6">
                                    <span class="font-medium text-primary-700 hover:underline">@league.Name</span>
                                    @if (league.IsCurrentUserAdmin)
                                    {
                                        <span class="ml-2 text-xs text-blue-600 font-medium">Admin</span>
                                    }
                                    @if (!string.IsNullOrEmpty(league.Description))
                                    {
                                        <p class="text-xs text-gray-500 mt-0.5 truncate max-w-xs">@league.Description</p>
                                    }
                                </td>
                                <td class="py-3 pr-6 text-sm text-gray-600">@league.MemberCount</td>
                                <td class="py-3 pr-6 text-sm text-gray-600">@league.SeasonCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Discover Leagues -->
        <div class="flex items-center justify-between mb-2">
            <h2 class="text-base font-semibold text-gray-700">Discover Leagues</h2>
            <div class="flex items-center gap-2">
                <input type="text"
                       @bind="searchQuery"
                       @bind:event="oninput"
                       placeholder="Search leagues..."
                       class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 w-52" />
                <button @onclick="SearchLeagues"
                        class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">
                    Search
                </button>
            </div>
        </div>

        @if (publicLeagues == null || !publicLeagues.Any())
        {
            <p class="text-gray-500 text-sm">No public leagues found.</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead>
                        <tr class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            <th class="py-3 pr-6 w-full">Name</th>
                            <th class="py-3 pr-6">Members</th>
                            <th class="py-3 pr-6"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var league in publicLeagues)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="py-3 pr-6">
                                    <div class="font-medium text-gray-900">@league.Name</div>
                                    @if (!string.IsNullOrEmpty(league.Description))
                                    {
                                        <p class="text-xs text-gray-500 mt-0.5 truncate max-w-xs">@league.Description</p>
                                    }
                                </td>
                                <td class="py-3 pr-6 text-sm text-gray-600">@league.MemberCount</td>
                                <td class="py-3 pr-6 text-sm">
                                    <button @onclick="@(() => RequestToJoin(league))"
                                            class="text-primary-600 hover:underline text-sm">
                                        Join
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
