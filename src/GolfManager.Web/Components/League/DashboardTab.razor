@using GolfManager.Shared.DTOs.League
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Web.Services
@using MaterialComponents.Models
@inject ISeasonService SeasonService
@inject NavigationManager Navigation
@inject IAuthorizationService AuthorizationService
@inject ILogger<DashboardTab> Logger

<!-- Quick Stats -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-6">
            <MaterialIcon Icon="MaterialIcons.EmojiEvents" Class="text-yellow-600 text-4xl mb-2" />
            <div class="text-3xl font-bold text-gray-900">@League.SeasonCount</div>
            <div class="text-sm text-gray-600">Seasons</div>
        </div>
    </MaterialCard>
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-6">
            <MaterialIcon Icon="MaterialIcons.GolfCourse" Class="text-green-600 text-4xl mb-2" />
            <div class="text-3xl font-bold text-gray-900">@League.PlayerCount</div>
            <div class="text-sm text-gray-600">Active Players</div>
        </div>
    </MaterialCard>
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-6">
            <MaterialIcon Icon="MaterialIcons.People" Class="text-blue-600 text-4xl mb-2" />
            <div class="text-3xl font-bold text-gray-900">@League.MemberCount</div>
            <div class="text-sm text-gray-600">Members</div>
        </div>
    </MaterialCard>
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-6">
            <MaterialIcon Icon="MaterialIcons.Event" Class="text-purple-600 text-4xl mb-2" />
            <div class="text-3xl font-bold text-gray-900">@totalEvents</div>
            <div class="text-sm text-gray-600">Total Events</div>
        </div>
    </MaterialCard>
</div>

<!-- Current Season Highlight -->
@if (currentSeason != null)
{
    <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="text-xl font-semibold text-gray-900">Current Season</h2>
                <p class="text-gray-600 text-sm">Active season for @DateTime.Now.Year</p>
            </div>
            <a href="/league/@LeagueKey/season/@currentSeason.Key" class="text-primary-600 hover:text-primary-700 text-sm font-medium">
                View Details →
            </a>
        </div>
        <MaterialCard Variant="MaterialCardVariant.Outlined" Class="border-l-4 border-l-primary-600">
            <div class="md-card__content">
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-3">
                            <MaterialIcon Icon="MaterialIcons.EmojiEvents" Class="text-primary-600 text-3xl" />
                            <div>
                                <h3 class="text-2xl font-bold text-gray-900">@currentSeason.Name</h3>
                                <p class="text-gray-600 text-sm">@currentSeason.StartDate.ToString("MMM d, yyyy") - @(currentSeason.EndDate?.ToString("MMM d, yyyy") ?? "Ongoing")</p>
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-6 mt-4">
                            <div>
                                <div class="text-2xl font-bold text-gray-900">@currentSeason.GolferCount</div>
                                <div class="text-xs text-gray-500 uppercase tracking-wide">Players</div>
                            </div>
                            <div>
                                <div class="text-2xl font-bold text-gray-900">@currentSeason.EventCount</div>
                                <div class="text-xs text-gray-500 uppercase tracking-wide">Events</div>
                            </div>
                        </div>
                    </div>
                    <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{currentSeason.Key}"))">
                        View Season
                    </MaterialButton>
                </div>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="mb-8">
        <div class="mb-4">
            <h2 class="text-xl font-semibold text-gray-900">Current Season</h2>
            <p class="text-gray-600 text-sm">No active season</p>
        </div>
        <MaterialCard Variant="MaterialCardVariant.Outlined">
            <div class="md-card__content text-center py-12">
                <MaterialIcon Icon="MaterialIcons.CalendarToday" Class="text-gray-400 text-5xl mb-4" />
                <h3 class="text-lg font-semibold text-gray-900 mb-2">No Active Season</h3>
                <p class="text-gray-600 mb-6">Start a new season to begin tracking rounds and competitions</p>
                @if (AuthorizationService.CanManageLeague(League.Id))
                {
                    <MaterialButton Style="MaterialButtonStyle.Filled">
                        <MaterialIcon Icon="MaterialIcons.Add" Class="mr-1" />
                        Create Season
                    </MaterialButton>
                }
            </div>
        </MaterialCard>
    </div>
}

<!-- Quick Actions (for admins) -->
@if (AuthorizationService.CanManageLeague(League.Id))
{
    <div class="mb-8">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Quick Actions</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <MaterialCard Variant="MaterialCardVariant.Outlined" Class="cursor-pointer hover:shadow-md transition-shadow">
                <div class="md-card__content text-center py-6">
                    <MaterialIcon Icon="MaterialIcons.Add" Class="text-primary-600 text-4xl mb-3" />
                    <h3 class="font-semibold text-gray-900 mb-1">Create Season</h3>
                    <p class="text-sm text-gray-600">Start a new competition season</p>
                </div>
            </MaterialCard>
            <MaterialCard Variant="MaterialCardVariant.Outlined" Class="cursor-pointer hover:shadow-md transition-shadow" OnClick="OnAddMember">
                <div class="md-card__content text-center py-6">
                    <MaterialIcon Icon="MaterialIcons.PersonAdd" Class="text-blue-600 text-4xl mb-3" />
                    <h3 class="font-semibold text-gray-900 mb-1">Add Member</h3>
                    <p class="text-sm text-gray-600">Invite someone to the league</p>
                </div>
            </MaterialCard>
            <MaterialCard Variant="MaterialCardVariant.Outlined" Class="cursor-pointer hover:shadow-md transition-shadow" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/settings"))">
                <div class="md-card__content text-center py-6">
                    <MaterialIcon Icon="MaterialIcons.Settings" Class="text-gray-600 text-4xl mb-3" />
                    <h3 class="font-semibold text-gray-900 mb-1">League Settings</h3>
                    <p class="text-sm text-gray-600">Configure league details</p>
                </div>
            </MaterialCard>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public LeagueResponse League { get; set; } = null!;
    
    [Parameter, EditorRequired]
    public string LeagueKey { get; set; } = string.Empty;
    
    [Parameter]
    public EventCallback OnAddMember { get; set; }

    private SeasonResponse? currentSeason;
    private int totalEvents = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadSeasons();
    }

    private async Task LoadSeasons()
    {
        try
        {
            var response = await SeasonService.GetLeagueSeasonsAsync(League.Id);
            if (response != null && response.Success && response.Data != null)
            {
                var seasons = response.Data;
                
                // Calculate total events
                totalEvents = seasons.Sum(s => s.EventCount);
                
                // Find current season
                var today = DateOnly.FromDateTime(DateTime.Now);
                currentSeason = seasons.FirstOrDefault(s => 
                    s.StartDate <= today && 
                    (!s.EndDate.HasValue || s.EndDate.Value >= today));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading seasons for dashboard");
        }
    }
}
