@using GolfManager.Shared.DTOs.League
@using GolfManager.Core.Enums
@using GolfManager.Web.Services
@using MaterialComponents.Models
@inject ILeagueService LeagueService
@inject IAuthorizationService AuthorizationService
@inject ILogger<MembersTab> Logger

<div class="mb-6">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">League Members</h2>
            <p class="text-gray-600 text-sm">Manage who has access to this league</p>
        </div>
        @if (AuthorizationService.CanManageLeague(League.Id))
        {
            <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="OnAddMember">
                <MaterialIcon Icon="MaterialIcons.PersonAdd" Class="mr-1" />
                Add Member
            </MaterialButton>
        }
    </div>

    <!-- Filter Controls -->
    <div class="flex gap-4 items-center">
        <!-- Search -->
        <div class="flex-1">
            <input type="text"
                   @bind="searchTerm"
                   @bind:event="oninput"
                   placeholder="Search by name or email..."
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>

        <!-- Status Filter -->
        <select @bind="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500">
            <option value="all">All Members (@members?.Count ?? 0)</option>
            <option value="active">Active Only (@members?.Count(m => m.IsActive) ?? 0)</option>
            <option value="inactive">Inactive Only (@members?.Count(m => !m.IsActive) ?? 0)</option>
        </select>
    </div>
</div>

@if (isLoading)
{
    <div class="flex items-center justify-center py-8">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
    </div>
}
else if (members == null || !members.Any())
{
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-12">
            <MaterialIcon Icon="MaterialIcons.People" Class="text-gray-400 text-5xl mb-4" />
            <p class="text-gray-600">No members yet</p>
        </div>
    </MaterialCard>
}
else
{
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content p-0">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Member</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
                            @if (AuthorizationService.CanManageLeague(League.Id))
                            {
                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var member in filteredMembers)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10 bg-primary-100 rounded-full flex items-center justify-center">
                                            <span class="text-primary-700 font-semibold">@GetInitials(member.FirstName, member.LastName)</span>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-gray-900">@member.FullName</div>
                                            @if (!string.IsNullOrEmpty(member.PlayerDisplayName))
                                            {
                                                <div class="text-xs text-gray-500">Player: @member.PlayerDisplayName</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@member.Email</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <MaterialChip Text="@GetRoleLabel(member.Role)" Color="@GetRoleColor(member.Role)" Size="MaterialChipSize.Small" />
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (member.IsActive)
                                    {
                                        <MaterialChip Text="Active" Color="MaterialChipColor.Success" Size="MaterialChipSize.Small" />
                                    }
                                    else
                                    {
                                        <MaterialChip Text="Inactive" Color="MaterialChipColor.Error" Size="MaterialChipSize.Small" />
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@member.JoinedAt.ToString("MMM d, yyyy")</td>
                                @if (AuthorizationService.CanManageLeague(League.Id))
                                {
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                        <div class="flex justify-end gap-2">
                                            <select value="@member.Role"
                                                    @onchange="args => ChangeMemberRole(member, args)"
                                                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500">
                                                @foreach (var role in LeagueRoles)
                                                {
                                                    <option value="@role">@GetRoleLabel(role)</option>
                                                }
                                            </select>

                                            @if (member.IsActive)
                                            {
                                                <MaterialButton Style="MaterialButtonStyle.Text" OnClick="() => ToggleMemberStatus(member)">
                                                    Deactivate
                                                </MaterialButton>
                                            }
                                            else
                                            {
                                                <MaterialButton Style="MaterialButtonStyle.Text" OnClick="() => ToggleMemberStatus(member)">
                                                    Reactivate
                                                </MaterialButton>
                                            }

                                            <MaterialButton Style="MaterialButtonStyle.Text" OnClick="() => OnRemoveMember.InvokeAsync(member)">
                                                <span class="text-red-600">Remove</span>
                                            </MaterialButton>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </MaterialCard>
}

@code {
    [Parameter, EditorRequired]
    public LeagueResponse League { get; set; } = null!;

    [Parameter]
    public EventCallback OnAddMember { get; set; }

    [Parameter]
    public EventCallback<LeagueMemberResponse> OnPromoteToAdmin { get; set; }

    [Parameter]
    public EventCallback<LeagueMemberResponse> OnDemoteFromAdmin { get; set; }

    [Parameter]
    public EventCallback<LeagueMemberResponse> OnRemoveMember { get; set; }

    private List<LeagueMemberResponse>? members;
    private bool isLoading = true;
    private string searchTerm = "";
    private string statusFilter = "all";
    private static readonly LeagueMemberRole[] LeagueRoles =
    [
        LeagueMemberRole.Owner,
        LeagueMemberRole.Admin,
        LeagueMemberRole.Member,
        LeagueMemberRole.Viewer
    ];

    private List<LeagueMemberResponse> filteredMembers => members?
        .Where(m =>
        {
            // Status filter
            if (statusFilter == "active" && !m.IsActive) return false;
            if (statusFilter == "inactive" && m.IsActive) return false;

            // Search filter
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var search = searchTerm.ToLower();
                return m.FullName.ToLower().Contains(search) ||
                       m.Email.ToLower().Contains(search) ||
                       (m.PlayerDisplayName?.ToLower().Contains(search) ?? false);
            }

            return true;
        })
        .ToList() ?? new List<LeagueMemberResponse>();

    protected override async Task OnInitializedAsync()
    {
        await LoadMembers();
    }

    private async Task LoadMembers()
    {
        isLoading = true;
        try
        {
            var response = await LeagueService.GetLeagueMembersAsync(League.Id);
            if (response != null && response.Success && response.Data != null)
            {
                members = response.Data.ToList();
                Logger.LogInformation("Loaded {Count} members for league {LeagueId}", members.Count, League.Id);
            }
            else
            {
                members = new List<LeagueMemberResponse>();
                Logger.LogWarning("Failed to load members: {Error}", response?.Message ?? "Unknown error");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading members");
            members = new List<LeagueMemberResponse>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleMemberStatus(LeagueMemberResponse member)
    {
        try
        {
            var request = new UpdateLeagueMemberRequest
            {
                IsActive = !member.IsActive
            };

            var response = await LeagueService.UpdateLeagueMemberAsync(League.Id, member.UserId, request);

            if (response != null && response.Success)
            {
                // Reload members to reflect changes
                await LoadMembers();
                Logger.LogInformation("Toggled member {UserId} status to {Status}", member.UserId, !member.IsActive);
            }
            else
            {
                Logger.LogWarning("Failed to toggle member status: {Error}", response?.Message ?? "Unknown error");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error toggling member status");
        }
    }

    private async Task ChangeMemberRole(LeagueMemberResponse member, ChangeEventArgs args)
    {
        if (args.Value == null || !Enum.TryParse<LeagueMemberRole>(args.Value.ToString(), out var role))
        {
            return;
        }

        try
        {
            var request = new UpdateLeagueMemberRequest { Role = role };
            var response = await LeagueService.UpdateLeagueMemberAsync(League.Id, member.UserId, request);

            if (response != null && response.Success)
            {
                await LoadMembers();
                Logger.LogInformation("Updated member {UserId} role to {Role}", member.UserId, role);
            }
            else
            {
                Logger.LogWarning("Failed to update member role: {Error}", response?.Message ?? "Unknown error");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating member role");
        }
    }

    private static string GetRoleLabel(LeagueMemberRole role)
    {
        return role.ToString();
    }

    private static MaterialChipColor GetRoleColor(LeagueMemberRole role)
    {
        return role switch
        {
            LeagueMemberRole.Owner => MaterialChipColor.Primary,
            LeagueMemberRole.Admin => MaterialChipColor.Info,
            LeagueMemberRole.Viewer => MaterialChipColor.Secondary,
            _ => MaterialChipColor.Default
        };
    }

    private string GetInitials(string firstName, string lastName)
    {
        var first = !string.IsNullOrEmpty(firstName) ? firstName[0].ToString() : "";
        var last = !string.IsNullOrEmpty(lastName) ? lastName[0].ToString() : "";
        return $"{first}{last}".ToUpper();
    }
}
