@using GolfManager.Shared.DTOs.League
@using MaterialComponents.Models
@inject NavigationManager Navigation

@if (League == null && !IsLoading)
{
    <div class="max-w-2xl mx-auto my-8">
        <MaterialCard Variant="MaterialCardVariant.Elevated">
            <div class="md-card__content text-center py-16">
                <MaterialIcon Icon="MaterialIcons.Error" Class="text-red-600 text-5xl mb-4" />
                <h2 class="text-2xl font-semibold text-gray-900 mb-3">League Not Found</h2>
                <p class="text-gray-600 mb-8">The league you're looking for doesn't exist or you don't have access to it.</p>
                <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="NavigateToDashboard">
                    Back to Dashboard
                </MaterialButton>
            </div>
        </MaterialCard>
    </div>
}
else
{
    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8 py-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-4">
                @if (ShowLeagueIcon)
                {
                    @if (!string.IsNullOrEmpty(League?.LogoUrl))
                    {
                        <img src="@League.LogoUrl" alt="@(League?.Name ?? "League")" class="w-16 h-16 rounded-lg object-cover" />
                    }
                    else
                    {
                        <div class="w-16 h-16 bg-primary-100 rounded-lg flex items-center justify-center">
                            <MaterialIcon Icon="MaterialIcons.GolfCourse" Class="text-primary-700 text-2xl" />
                        </div>
                    }
                }

                <div>
                    <h1 class="text-3xl font-bold text-gray-900 mb-1">@(League?.Name ?? CurrentLeagueName ?? "League")</h1>
                    <p class="text-gray-600 text-sm font-mono">@(League?.Key ?? LeagueKey)</p>
                </div>
            </div>

            @if (HeaderActions != null)
            {
                <div class="flex gap-3">
                    @HeaderActions
                </div>
            }
        </div>
    </div>

    <div class="bg-white border-b border-gray-200 -mx-4 md:-mx-8 px-4 md:px-8">
        <MaterialTabs ActiveTab="@ActiveTab"
                      Tabs="@GetNavigationTabs()"
                      ShowContent="false"
                      OnTabChange="HandleTabChange" />
    </div>

    <div class="mt-8">
        @if (League == null)
        {
            <div class="flex items-center justify-center py-16">
                <div class="text-center">
                    <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600 mb-4"></div>
                    <p class="text-gray-600">@LoadingMessage</p>
                </div>
            </div>
        }
        else
        {
            @ChildContent
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public string LeagueKey { get; set; } = string.Empty;
    [Parameter] public LeagueResponse? League { get; set; }
    [Parameter] public string? CurrentLeagueName { get; set; }
    [Parameter, EditorRequired] public string ActiveTab { get; set; } = "dashboard";
    [Parameter] public bool ShowSettingsTab { get; set; }
    [Parameter] public bool ShowLeagueIcon { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string LoadingMessage { get; set; } = "Loading...";
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    private List<MaterialTab> GetNavigationTabs()
    {
        var tabs = new List<MaterialTab>
        {
            new()
            {
                Value = "dashboard",
                Label = "Dashboard",
                Icon = @<MaterialIcon Icon="MaterialIcons.Dashboard" Size="IconSize.SM" />
            },
            new()
            {
                Value = "seasons",
                Label = "Seasons",
                Icon = @<MaterialIcon Icon="MaterialIcons.CalendarToday" Size="IconSize.SM" />
            },
            new()
            {
                Value = "members",
                Label = "Members",
                Icon = @<MaterialIcon Icon="MaterialIcons.People" Size="IconSize.SM" />
            }
        };

        if (ShowSettingsTab)
        {
            tabs.Add(new MaterialTab
            {
                Value = "settings",
                Label = "Settings",
                Icon = @<MaterialIcon Icon="MaterialIcons.Settings" Size="IconSize.SM" />
            });
        }

        return tabs;
    }

    private void HandleTabChange(string tabValue)
    {
        var route = tabValue switch
        {
            "dashboard" => $"/league/{LeagueKey}",
            "seasons" => $"/league/{LeagueKey}/seasons",
            "members" => $"/league/{LeagueKey}/members",
            "settings" => $"/league/{LeagueKey}/settings",
            _ => $"/league/{LeagueKey}"
        };

        Navigation.NavigateTo(route);
    }

    private void NavigateToDashboard()
    {
        Navigation.NavigateTo("/dashboard");
    }
}