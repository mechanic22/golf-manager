@using GolfManager.Shared.DTOs.League
@using GolfManager.Shared.DTOs.Season
@using GolfManager.Web.Services
@using MaterialComponents.Models
@inject ISeasonService SeasonService
@inject NavigationManager Navigation
@inject ILogger<SeasonsTab> Logger

<div class="mb-6 flex items-center justify-between">
    <div>
        <h2 class="text-xl font-semibold text-gray-900">Seasons</h2>
        <p class="text-gray-600 text-sm">Manage league seasons and competitions</p>
    </div>
    @if (CanManageLeague)
    {
        <MaterialButton Style="MaterialButtonStyle.Filled" OnClick="OnCreateSeason">
            <MaterialIcon Icon="MaterialIcons.Add" Class="mr-1" />
            Create Season
        </MaterialButton>
    }
</div>

@if (isLoading)
{
    <div class="flex items-center justify-center py-8">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
    </div>
}
else if (seasons == null || !seasons.Any())
{
    <MaterialCard Variant="MaterialCardVariant.Outlined">
        <div class="md-card__content text-center py-12">
            <MaterialIcon Icon="MaterialIcons.CalendarToday" Class="text-gray-400 text-5xl mb-4" />
            <p class="text-gray-600">No seasons yet</p>
            @if (CanManageLeague)
            {
                <MaterialButton Style="MaterialButtonStyle.Outlined" OnClick="OnCreateSeason" Class="mt-4">
                    Create First Season
                </MaterialButton>
            }
        </div>
    </MaterialCard>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var season in seasons.OrderByDescending(s => s.StartDate))
        {
            <MaterialCard Variant="MaterialCardVariant.Outlined" Class="hover:shadow-md transition-shadow">
                <div class="md-card__content">
                    <div class="flex items-start justify-between mb-3">
                        <div>
                            <h3 class="text-lg font-semibold text-gray-900">@season.Name</h3>
                            <p class="text-sm text-gray-600 font-mono">@season.Key</p>
                        </div>
                        @if (season.IsLocked)
                        {
                            <MaterialChip Text="Locked" Color="MaterialChipColor.Secondary" Size="MaterialChipSize.Small" />
                        }
                    </div>
                    <div class="space-y-2 text-sm text-gray-600 mb-4">
                        <div class="flex items-center gap-2">
                            <MaterialIcon Icon="MaterialIcons.CalendarToday" Size="IconSize.SM" />
                            <span>@season.StartDate.ToString("MMM d, yyyy")</span>
                            @if (season.EndDate.HasValue)
                            {
                                <span>- @season.EndDate.Value.ToString("MMM d, yyyy")</span>
                            }
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-1">
                                <MaterialIcon Icon="MaterialIcons.Event" Size="IconSize.SM" />
                                <span>@season.EventCount events</span>
                            </div>
                            <div class="flex items-center gap-1">
                                <MaterialIcon Icon="MaterialIcons.People" Size="IconSize.SM" />
                                <span>@season.GolferCount golfers</span>
                            </div>
                        </div>
                    </div>
                    <div class="pt-3 border-t border-gray-200">
                        <MaterialButton Style="MaterialButtonStyle.Text" OnClick="@(() => Navigation.NavigateTo($"/league/{LeagueKey}/season/{season.Key}"))">
                            View Season Details
                            <MaterialIcon Icon="MaterialIcons.ArrowForward" Class="ml-1" />
                        </MaterialButton>
                    </div>
                </div>
            </MaterialCard>
        }
    </div>
}

@code {
    [Parameter, EditorRequired]
    public LeagueResponse League { get; set; } = null!;
    
    [Parameter, EditorRequired]
    public string LeagueKey { get; set; } = string.Empty;

    [Parameter]
    public bool CanManageLeague { get; set; }
    
    [Parameter]
    public EventCallback OnCreateSeason { get; set; }

    private List<SeasonResponse>? seasons;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSeasons();
    }

    private async Task LoadSeasons()
    {
        isLoading = true;
        try
        {
            var response = await SeasonService.GetLeagueSeasonsAsync(League.Id);
            if (response != null && response.Success && response.Data != null)
            {
                seasons = response.Data.ToList();
                Logger.LogInformation("Loaded {Count} seasons for league {LeagueId}", seasons.Count, League.Id);
            }
            else
            {
                seasons = new List<SeasonResponse>();
                Logger.LogWarning("Failed to load seasons: {Error}", response?.Message ?? "Unknown error");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading seasons");
            seasons = new List<SeasonResponse>();
        }
        finally
        {
            isLoading = false;
        }
    }
}
