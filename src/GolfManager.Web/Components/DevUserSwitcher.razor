@using GolfManager.Shared.DTOs.Auth
@using GolfManager.Web.Components.Icons
@using GolfManager.Web.Services
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@inject IAuthService AuthService
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ILogger<DevUserSwitcher> Logger
@inject IWebAssemblyHostEnvironment HostEnvironment
@inject SeedDataService SeedData

@* Only show in development mode *@
@if (IsDevelopment)
{
    <!-- Toggle Button -->
    <button
        @onclick="TogglePanel"
        class="fixed bottom-6 right-6 z-50 bg-gradient-to-r from-purple-600 to-blue-600 text-white p-3 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2"
        title="Dev User Switcher">
        <MaterialIcon Path="@(isOpen ? MaterialIcons.Close : MaterialIcons.Person)" Size="MaterialComponents.Icons.IconSize.LG" />
    </button>

    <!-- Backdrop -->
    @if (isOpen)
    {
        <div
            @onclick="TogglePanel"
            class="fixed inset-0 bg-black bg-opacity-50 z-40 transition-opacity duration-300"
            style="@(isOpen ? "opacity: 1;" : "opacity: 0; pointer-events: none;")">
        </div>
    }

    <!-- Slide-in Panel -->
    <div class="fixed top-0 right-0 h-full w-96 bg-white shadow-2xl z-50 transform transition-transform duration-300 ease-in-out @(isOpen ? "translate-x-0" : "translate-x-full")">
        <div class="h-full flex flex-col">
            <!-- Header -->
            <div class="bg-gradient-to-r from-purple-600 to-blue-600 text-white p-6">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-3">
                        <MaterialIcon Path="@MaterialIcons.Settings" Size="MaterialComponents.Icons.IconSize.LG" />
                        <h2 class="text-xl font-bold">Dev User Switcher</h2>
                    </div>
                    <button
                        @onclick="TogglePanel"
                        class="text-white hover:bg-white hover:bg-opacity-20 rounded-full p-2 transition-colors">
                        <MaterialIcon Path="@MaterialIcons.Close" />
                    </button>
                </div>
                <p class="text-purple-100 text-sm">Quickly switch between test users</p>
            </div>

            <!-- Current User -->
            <div class="bg-purple-50 border-b border-purple-200 p-4">
                <div class="text-xs font-semibold text-purple-700 uppercase tracking-wide mb-1">Current User</div>
                <div class="text-sm font-medium text-gray-900">
                    @if (AuthService.IsAuthenticated)
                    {
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center font-bold">
                                @GetInitials(AuthService.UserEmail)
                            </div>
                            <div>
                                <div class="font-semibold">@AuthService.UserEmail</div>
                                <div class="text-xs text-purple-600">
                                    @(AuthService.IsGlobalAdmin ? "Global Admin" : "User")
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <span class="text-gray-500">Not logged in</span>
                    }
                </div>
            </div>

            <!-- User List -->
            <div class="flex-1 overflow-y-auto p-4">
                @if (isSwitching)
                {
                    <div class="flex flex-col items-center justify-center py-12">
                        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-purple-600 mb-4"></div>
                        <p class="text-gray-600">Switching user...</p>
                    </div>
                }
                else
                {
                    <!-- Search Box -->
                    <div class="mb-4">
                        <input type="text"
                               @bind="searchQuery"
                               @bind:event="oninput"
                               placeholder="Search users..."
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
                    </div>

                    <!-- Filter Buttons -->
                    <div class="flex gap-2 mb-4">
                        <button @onclick="@SetFilterAll"
                                class="px-3 py-1 text-xs rounded-full @GetFilterClass("all")">
                            All (@TestUsers.Count)
                        </button>
                        <button @onclick="@SetFilterAdmin"
                                class="px-3 py-1 text-xs rounded-full @GetFilterClass("admin")">
                            Admins
                        </button>
                        <button @onclick="@SetFilterPlayer"
                                class="px-3 py-1 text-xs rounded-full @GetFilterClass("player")">
                            Players
                        </button>
                    </div>

                    <div class="space-y-2">
                        @foreach (var user in FilteredUsers)
                        {
                            var isActive = AuthService.UserEmail == user.Email;
                            <button
                                @onclick="@(() => SwitchToUser(user))"
                                disabled="@isActive"
                                class="w-full text-left p-3 rounded-lg border transition-all duration-200 @(isActive ? "bg-purple-50 border-purple-500 cursor-not-allowed" : "bg-white border-gray-200 hover:border-purple-400 hover:shadow-sm cursor-pointer")">
                                <div class="flex items-start gap-2">
                                    <div class="w-8 h-8 @(isActive ? "bg-purple-600" : "bg-gray-400") text-white rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">
                                        @GetInitials(user.Email)
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="text-sm font-semibold text-gray-900 truncate">@user.Name</div>
                                        <div class="text-xs text-gray-500 truncate">@user.Email</div>
                                        <div class="flex items-center gap-1 mt-0.5">
                                            <span class="text-xs font-medium @GetRoleColor(user.Role)">@user.Role</span>
                                            @if (user.Handicap.HasValue)
                                            {
                                                <span class="text-xs text-gray-400">• HCP @user.Handicap.Value.ToString("F1")</span>
                                            }
                                        </div>
                                    </div>
                                    @if (isActive)
                                    {
                                        <MaterialIcon Path="@MaterialIcons.Check" Class="text-purple-600" Size="MaterialComponents.Icons.IconSize.SM" />
                                    }
                                </div>
                            </button>
                        }
                    </div>

                    @if (!FilteredUsers.Any())
                    {
                        <div class="text-center py-8 text-gray-500 text-sm">
                            No users found
                        </div>
                    }
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mt-4 p-3 bg-red-50 border border-red-200 rounded-lg">
                        <div class="flex items-start gap-2">
                            <MaterialIcon Path="@MaterialIcons.Close" Class="text-red-600" />
                            <div class="text-sm text-red-700">@errorMessage</div>
                        </div>
                    </div>
                }
            </div>

            <!-- Footer -->
            <div class="border-t border-gray-200 p-4 bg-gray-50">
                <div class="text-xs text-gray-500 text-center">
                    <MaterialIcon Path="@GolfIcons.Info" Size="MaterialComponents.Icons.IconSize.SM" Class="inline" />
                    Development mode only
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool IsDevelopment => HostEnvironment.IsDevelopment();
    private bool isOpen = false;
    private bool isSwitching = false;
    private string? errorMessage;
    private string searchQuery = string.Empty;
    private string filterRole = "all";

    private List<TestUser> FilteredUsers
    {
        get
        {
            var users = TestUsers.AsEnumerable();

            // Apply role filter
            if (filterRole == "admin")
                users = users.Where(u => u.Role.Contains("Admin"));
            else if (filterRole == "player")
                users = users.Where(u => u.Role == "Player");

            // Apply search filter
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var query = searchQuery.ToLower();
                users = users.Where(u =>
                    u.Name.ToLower().Contains(query) ||
                    u.Email.ToLower().Contains(query));
            }

            return users.ToList();
        }
    }

    private void TogglePanel()
    {
        isOpen = !isOpen;
        errorMessage = null;
    }

    private void SetFilterAll() => filterRole = "all";
    private void SetFilterAdmin() => filterRole = "admin";
    private void SetFilterPlayer() => filterRole = "player";

    private string GetFilterClass(string role)
    {
        return filterRole == role
            ? (role == "all" ? "bg-purple-600 text-white" : role == "admin" ? "bg-red-600 text-white" : "bg-gray-600 text-white")
            : "bg-gray-200 text-gray-700";
    }

    private string GetInitials(string? email)
    {
        if (string.IsNullOrEmpty(email)) return "?";
        var parts = email.Split('@')[0].Split('.');
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return email[0].ToString().ToUpper();
    }

    private string GetRoleIcon(string role) => role switch
    {
        "Global Admin" => MaterialIcons.Settings,
        "League Admin" => GolfIcons.Trophy,
        "Season Admin" => GolfIcons.Calendar,
        _ => MaterialIcons.Person
    };

    private string GetRoleColor(string role) => role switch
    {
        "Global Admin" => "text-red-600",
        "League Admin" => "text-blue-600",
        "Season Admin" => "text-green-600",
        _ => "text-gray-600"
    };

    private class TestUser
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public decimal? Handicap { get; set; }
    }

    private List<TestUser> TestUsers => SeedData.Users.Select(u => new TestUser
    {
        Name = $"{u.FirstName} {u.LastName}",
        Email = u.Email,
        Password = u.Password,
        Role = u.IsGlobalAdmin ? "Global Admin" : "Player",
        Handicap = u.Handicap
    }).ToList();

    private async Task SwitchToUser(TestUser user)
    {
        if (isSwitching) return;

        try
        {
            isSwitching = true;
            errorMessage = null;
            StateHasChanged();

            Logger.LogInformation("Dev: Switching to user {Email}", user.Email);

            // Logout current user
            await AuthService.LogoutAsync();

            // Login as new user
            var loginRequest = new LoginRequest
            {
                Email = user.Email,
                Password = user.Password
            };

            var authResponse = await AuthService.LoginAsync(loginRequest);

            if (authResponse != null)
            {
                // Re-initialize authorization service with new user
                await AuthorizationService.InitializeAsync();

                Logger.LogInformation("Dev: Successfully switched to {Email}", user.Email);

                // Close the panel
                isOpen = false;

                // Navigate to dashboard to refresh the UI
                // Don't use forceLoad as it causes auth to not be initialized yet
                Navigation.NavigateTo("/dashboard", forceLoad: false);
            }
            else
            {
                errorMessage = "Failed to switch user. Check console for details.";
                Logger.LogError("Dev: Failed to switch to user {Email}", user.Email);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Logger.LogError(ex, "Dev: Error switching to user {Email}", user.Email);
        }
        finally
        {
            isSwitching = false;
            StateHasChanged();
        }
    }
}

