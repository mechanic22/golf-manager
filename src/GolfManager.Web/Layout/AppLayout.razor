@using MaterialComponents
@using MaterialComponents.Models
@using GolfManager.Shared.DTOs.Auth
@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject AppState AppState
@implements IDisposable

<div class="min-h-screen bg-gray-50">
    <!-- App Navigation Bar (Always Solid) -->
    <nav class="w-full fixed top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
        <div class="container max-w-7xl mx-auto px-4 md:px-8 flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/dashboard" class="flex items-center no-underline h-full py-2">
                <img src="/img/pinzo-green.png" alt="Pinzo Golf" class="max-h-full w-auto" />
            </a>

            <!-- Desktop Navigation - Context Aware -->
            <div class="hidden md:flex gap-2 items-center">
                @if (AuthService.IsGuest)
                {
                    <!-- Guest Mode Navigation -->
                    <NavLink href="@($"/league/{AuthService.GuestLeagueKey}")" class="app-nav-link"
                             ActiveClass="app-nav-link-active">
                        Home
                    </NavLink>
                    <NavLink href="@($"/league/{AuthService.GuestLeagueKey}/events")" class="app-nav-link"
                             ActiveClass="app-nav-link-active">
                        Events
                    </NavLink>
                    <NavLink href="@($"/league/{AuthService.GuestLeagueKey}/standings")" class="app-nav-link"
                             Match="NavLinkMatch.All" ActiveClass="app-nav-link-active">
                        Standings
                    </NavLink>
                }
                else if (AuthService.IsAuthenticated && AppState.UserLeagues.Count > 0)
                {
                    <div class="mr-2">
                        <select class="px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white text-gray-700"
                                value="@CurrentLeagueSelection" @onchange="HandleLeagueChange">
                            <option value="">Select League</option>
                            @foreach (var leagueOption in LeagueOptions)
                            {
                                <option value="@leagueOption.LeagueKey">@leagueOption.LeagueName</option>
                            }
                        </select>
                    </div>
                }

                @if (IsInEventContext)
                {
                    <!-- Event Context Navigation — tabs handled by EventLayout -->
                    <NavLink href="@GetSeasonEventsUrl()" class="app-nav-link" ActiveClass="app-nav-link-active">
                        ← Events
                    </NavLink>
                }
                else if (IsInSeasonContext)
                {
                    <NavLink href="@GetLeagueUrl()" class="app-nav-link" ActiveClass="app-nav-link-active">
                        ← @(AppState.CurrentLeagueName ?? "League")
                    </NavLink>
                }
                else if (IsInLeagueContext)
                {
                    <!-- League Context Navigation — tabs handle within-league nav -->
                    <NavLink href="dashboard" class="app-nav-link" ActiveClass="app-nav-link-active">
                        ← Dashboard
                    </NavLink>
                }
                else if (IsInAdminContext && AuthorizationService.IsGlobalAdmin())
                {
                    <!-- Admin Context Navigation -->
                    <NavLink href="admin" class="app-nav-link" Match="NavLinkMatch.All" ActiveClass="app-nav-link-active">
                        Dashboard
                    </NavLink>
                    <NavLink href="admin/users" class="app-nav-link" ActiveClass="app-nav-link-active">
                        Users
                    </NavLink>
                    <NavLink href="admin/leagues" class="app-nav-link" ActiveClass="app-nav-link-active">
                        Leagues
                    </NavLink>
                }
                else
                {
                    <!-- Default Navigation -->
                    <NavLink href="dashboard" class="app-nav-link" Match="NavLinkMatch.All"
                             ActiveClass="app-nav-link-active">
                        Dashboard
                    </NavLink>
                    <NavLink href="events" class="app-nav-link" ActiveClass="app-nav-link-active">
                        Events
                    </NavLink>
                    <NavLink href="profile" class="app-nav-link" ActiveClass="app-nav-link-active">
                        Profile
                    </NavLink>
                }

                <!-- User Menu Dropdown -->
                <div class="relative ml-4 pl-4 border-l border-gray-200">
                    @if (AuthService.IsGuest)
                    {
                        <button @onclick="HandleLogout"
                                class="flex items-center gap-2 px-4 py-2 text-primary-600 hover:text-primary-700 rounded-lg hover:bg-primary-50 transition-colors text-sm font-medium border border-primary-300">
                            <Icon Path="@GolfIcons.Person" Size="GolfManager.Web.Shared.Icons.IconSize.SM" />
                            Sign In to Join
                        </button>
                    }
                    else
                    {
                        <button @onclick="ToggleUserMenu"
                                class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                            <div
                                class="w-8 h-8 bg-primary-600 rounded-full flex items-center justify-center text-white text-sm font-semibold">
                                @GetUserInitials()
                            </div>
                            <span class="text-xs text-gray-600">▼</span>
                        </button>

                        <MaterialDrop @bind-IsOpen="showUserMenu" Position="MaterialDropPosition.Bottom"
                                      Alignment="MaterialDropAlignment.End"
                                      class="w-56 bg-white rounded-lg shadow-lg border border-gray-200 py-2">
                            <div class="px-4 py-2 border-b border-gray-200">
                                <p class="text-sm font-semibold text-gray-900 mb-1">@AuthService.UserEmail</p>
                                <p class="text-xs text-gray-600 mb-1">@GetUserRole()</p>
                            </div>

                            <a href="/profile" @onclick="() => showUserMenu = false"
                               class="md-menu-item flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors">
                                <Icon Path="@GolfIcons.Person" Size="GolfManager.Web.Shared.Icons.IconSize.SM" />
                                <span class="text-sm">My Profile</span>
                            </a>

                            @if (AuthorizationService.IsGlobalAdmin())
                            {
                                <a href="/admin" @onclick="() => showUserMenu = false"
                                   class="md-menu-item flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors">
                                    <Icon Path="@GolfIcons.Settings" Size="GolfManager.Web.Shared.Icons.IconSize.SM" />
                                    <span class="text-sm">Admin Dashboard</span>
                                </a>
                            }

                            <div class="md-menu-divider"></div>

                            <button @onclick="HandleLogout"
                                    class="md-menu-item flex items-center gap-2 w-full px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                                <Icon Path="@GolfIcons.Logout" Size="GolfManager.Web.Shared.Icons.IconSize.SM" />
                                <span class="text-sm">Logout</span>
                            </button>
                        </MaterialDrop>
                    }
                </div>
            </div>

            <!-- Mobile Menu Button -->
            <button @onclick="ToggleNavMenu" class="block md:hidden p-2 text-gray-600 hover:text-gray-900">
                <Icon Path="@GolfIcons.Menu" Size="GolfManager.Web.Shared.Icons.IconSize.SM" />
            </button>
        </div>

        <!-- Mobile Menu -->
        @if (!collapseNavMenu)
        {
            <div class="border-t border-gray-200 bg-white md:hidden">
                <div class="container max-w-7xl mx-auto px-4 py-4">
                    <!-- User Info -->
                    <div class="flex items-center gap-3 pb-4 mb-4 border-b border-gray-200">
                        <div
                            class="w-10 h-10 bg-primary-600 rounded-full flex items-center justify-center text-white font-semibold">
                            @GetUserInitials()
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-gray-900">@AuthService.UserEmail</p>
                            <p class="text-xs text-gray-600">@GetUserRole()</p>
                        </div>
                    </div>

                    <div class="flex flex-col gap-2">
                        @if (AuthService.IsGuest)
                        {
                            <NavLink href="@($"/league/{AuthService.GuestLeagueKey}")" @onclick="ToggleNavMenu"
                                     class="app-nav-link" ActiveClass="app-nav-link-active">
                                Home
                            </NavLink>
                            <NavLink href="@($"/league/{AuthService.GuestLeagueKey}/events")" @onclick="ToggleNavMenu"
                                     class="app-nav-link" ActiveClass="app-nav-link-active">
                                Events
                            </NavLink>
                            <NavLink href="@($"/league/{AuthService.GuestLeagueKey}/standings")" @onclick="ToggleNavMenu"
                                     class="app-nav-link" ActiveClass="app-nav-link-active">
                                Standings
                            </NavLink>
                        }
                        else if (AuthService.IsAuthenticated && AppState.UserLeagues.Count > 0)
                        {
                            <div class="pb-2 mb-2 border-b border-gray-200">
                                <label class="block text-xs font-medium text-gray-600 mb-1">Current League</label>
                                <select
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white text-gray-700"
                                    value="@CurrentLeagueSelection" @onchange="HandleLeagueChangeAndCloseMenu">
                                    <option value="">Select League</option>
                                    @foreach (var leagueOption in LeagueOptions)
                                    {
                                        <option value="@leagueOption.LeagueKey">@leagueOption.LeagueName</option>
                                    }
                                </select>
                            </div>
                        }

                        @if (IsInEventContext)
                        {
                            <!-- Event Context Navigation — tabs handled by EventLayout -->
                            <NavLink href="@GetSeasonEventsUrl()" @onclick="ToggleNavMenu" class="app-nav-link" ActiveClass="app-nav-link-active">
                                ← Events
                            </NavLink>
                        }
                        else if (IsInSeasonContext)
                        {
                            <NavLink href="@GetLeagueUrl()" @onclick="ToggleNavMenu" class="app-nav-link" ActiveClass="app-nav-link-active">
                                ← @(AppState.CurrentLeagueName ?? "League")
                            </NavLink>
                        }
                        else if (IsInLeagueContext)
                        {
                            <!-- League Context Navigation — tabs handle within-league nav -->
                            <NavLink href="dashboard" @onclick="ToggleNavMenu" class="app-nav-link"
                                     ActiveClass="app-nav-link-active">
                                ← Dashboard
                            </NavLink>
                        }
                        else if (IsInAdminContext && AuthorizationService.IsGlobalAdmin())
                        {
                            <NavLink href="admin" @onclick="ToggleNavMenu" class="app-nav-link" Match="NavLinkMatch.All"
                                     ActiveClass="app-nav-link-active">
                                Dashboard
                            </NavLink>
                            <NavLink href="admin/users" @onclick="ToggleNavMenu" class="app-nav-link"
                                     ActiveClass="app-nav-link-active">
                                Users
                            </NavLink>
                            <NavLink href="admin/leagues" @onclick="ToggleNavMenu" class="app-nav-link"
                                     ActiveClass="app-nav-link-active">
                                Leagues
                            </NavLink>
                        }
                        else
                        {
                            <NavLink href="dashboard" @onclick="ToggleNavMenu" class="app-nav-link" Match="NavLinkMatch.All"
                                     ActiveClass="app-nav-link-active">
                                Dashboard
                            </NavLink>
                            <NavLink href="events" @onclick="ToggleNavMenu" class="app-nav-link"
                                     ActiveClass="app-nav-link-active">
                                Events
                            </NavLink>
                            <NavLink href="profile" @onclick="ToggleNavMenu" class="app-nav-link"
                                     ActiveClass="app-nav-link-active">
                                Profile
                            </NavLink>
                        }

                        <div class="pt-2 mt-2 border-t border-gray-200 space-y-2">
                            <NavLink href="profile" @onclick="ToggleNavMenu" class="app-nav-link"
                                     ActiveClass="app-nav-link-active">
                                <Icon Path="@GolfIcons.Person" Size="GolfManager.Web.Shared.Icons.IconSize.SM"
                                      Class="inline-block mr-2" />
                                My Profile
                            </NavLink>

                            @if (AuthorizationService.IsGlobalAdmin())
                            {
                                <NavLink href="admin" @onclick="ToggleNavMenu" class="app-nav-link"
                                         ActiveClass="app-nav-link-active">
                                    <Icon Path="@GolfIcons.Settings" Size="GolfManager.Web.Shared.Icons.IconSize.SM"
                                          Class="inline-block mr-2" />
                                    Admin Dashboard
                                </NavLink>
                            }

                            @if (AuthService.IsGuest)
                            {
                                <button @onclick="HandleLogout" class="btn btn-primary w-full justify-center">
                                    <Icon Path="@GolfIcons.Person" Size="GolfManager.Web.Shared.Icons.IconSize.SM"
                                          Class="inline-block mr-2" />
                                    Sign In to Join
                                </button>
                            }
                            else
                            {
                                <button @onclick="HandleLogout" class="btn btn-secondary w-full justify-center">
                                    <Icon Path="@GolfIcons.Logout" Size="GolfManager.Web.Shared.Icons.IconSize.SM"
                                          Class="inline-block mr-2" />
                                    Logout
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </nav>

    <!-- Spacer to prevent content from going under fixed navbar -->
    <div class="h-16"></div>

    <!-- Main Content -->
    <main class="container max-w-7xl mx-auto px-4 md:px-8 py-8">
        @Body
    </main>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool showUserMenu = false;
    private string currentUrl = string.Empty;
    private string CurrentLeagueSelection => AppState.CurrentLeagueKey ?? string.Empty;
    private IEnumerable<LeagueMappingResponse> LeagueOptions => AppState.UserLeagues.OrderBy(l => l.LeagueName);

    protected override void OnInitialized()
    {
        currentUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.LocationChanged += OnLocationChanged;
        AppState.OnChange += OnAppStateChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = Navigation.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        AppState.OnChange -= OnAppStateChanged;
    }

    private void OnAppStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    // Context detection — event context takes priority over season context
    // Note: ToBaseRelativePath strips the leading slash, so URLs start with "league/" not "/league/"
    private bool IsInEventContext => currentUrl.StartsWith("league/") && currentUrl.Contains("/season/") && currentUrl.Contains("/event/");
    private bool IsInSeasonContext => currentUrl.StartsWith("league/") && currentUrl.Contains("/season/") && !IsInEventContext;
    private bool IsInLeagueContext => currentUrl.StartsWith("league/") && !currentUrl.Contains("/season/");
    private bool IsInAdminContext => currentUrl.StartsWith("admin");

    // URL builders
    private string GetLeagueUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 2) return $"/league/{parts[1]}";
        return "/dashboard";
    }

    private string GetLeagueSeasonsUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 2) return $"/league/{parts[1]}/seasons";
        return "/dashboard";
    }

    private string GetLeagueMembersUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 2) return $"/league/{parts[1]}/members";
        return "/dashboard";
    }

    private string GetSeasonOverviewUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 4) return $"/league/{parts[1]}/season/{parts[3]}";
        return "/dashboard";
    }

    private string GetSeasonEventsUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 4) return $"/league/{parts[1]}/season/{parts[3]}/events";
        return "/dashboard";
    }

    private string GetSeasonSettingsUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 4) return $"/league/{parts[1]}/season/{parts[3]}/settings";
        return "/dashboard";
    }

    private string GetSeasonStandingsUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 4) return $"/league/{parts[1]}/season/{parts[3]}/standings";
        return "/dashboard";
    }

    private string GetSeasonPlayersUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 4) return $"/league/{parts[1]}/season/{parts[3]}/players";
        return "/dashboard";
    }

    private string GetSeasonTeamsUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 4) return $"/league/{parts[1]}/season/{parts[3]}/teams";
        return "/dashboard";
    }

    private string GetLeagueSettingsUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 2) return $"/league/{parts[1]}/settings";
        return "/dashboard";
    }

    // URL: league/{key}/season/{skey}/event/{ekey}/...
    // Split index: 0=league 1={key} 2=season 3={skey} 4=event 5={ekey}
    private string GetEventBaseUrl()
    {
        var parts = currentUrl.Split('/');
        if (parts.Length >= 6) return $"/league/{parts[1]}/season/{parts[3]}/event/{parts[5]}";
        return "/dashboard";
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
        showUserMenu = false;
    }

    private void ToggleUserMenu()
    {
        showUserMenu = !showUserMenu;
    }

    private void HandleLeagueChange(ChangeEventArgs args)
    {
        var leagueKey = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(leagueKey))
        {
            return;
        }

        AppState.SetCurrentLeague(leagueKey);
        Navigation.NavigateTo($"/league/{leagueKey}");
    }

    private void HandleLeagueChangeAndCloseMenu(ChangeEventArgs args)
    {
        HandleLeagueChange(args);
        collapseNavMenu = true;
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private string GetUserInitials()
    {
        var first = AuthService.UserFirstName;
        var last = AuthService.UserLastName;

        if (!string.IsNullOrEmpty(first) && !string.IsNullOrEmpty(last))
            return $"{char.ToUpper(first[0])}{char.ToUpper(last[0])}";

        if (!string.IsNullOrEmpty(first) && first.Length >= 2)
            return first.Substring(0, 2).ToUpper();

        if (string.IsNullOrEmpty(AuthService.UserEmail))
            return "?";

        var emailParts = AuthService.UserEmail.Split('@');
        var name = emailParts[0];
        return name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
    }

    private string GetUserRole()
    {
        if (AuthorizationService.IsGlobalAdmin())
            return "Global Admin";

        if (AppState.IsCurrentLeagueAdmin)
            return "League Admin";

        if (!string.IsNullOrEmpty(AppState.CurrentLeagueName))
            return "League Member";

        return "Member";
    }
}

