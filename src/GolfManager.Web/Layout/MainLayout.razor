@inherits LayoutComponentBase
@inject IAuthService AuthService

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        @if (AuthService.IsAuthenticated)
        {
            <div class="top-row px-4">
                <span class="user-info">👤 @AuthService.UserEmail</span>
            </div>
        }

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
