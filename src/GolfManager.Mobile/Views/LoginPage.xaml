<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GolfManager.Mobile.ViewModels"
             x:Class="GolfManager.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="DK Golf"
             BackgroundColor="#121212">

    <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

        <Label Text="DK Golf"
               FontSize="36" FontAttributes="Bold"
               TextColor="#A5D6A7" HorizontalOptions="Center"
               Margin="0,0,0,24" />

        <Entry Placeholder="Email"
               Text="{Binding Email}"
               Keyboard="Email"
               PlaceholderColor="#666"
               TextColor="White"
               BackgroundColor="#1E1E1E" />

        <Entry Placeholder="Password"
               Text="{Binding Password}"
               IsPassword="True"
               PlaceholderColor="#666"
               TextColor="White"
               BackgroundColor="#1E1E1E" />

        <Label Text="{Binding ErrorMessage}"
               TextColor="#EF5350"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToBoolConverter}}"
               HorizontalOptions="Center" />

        <Button Text="Sign In"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                BackgroundColor="#2E7D32"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="8"
                Margin="0,8,0,0" />

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#A5D6A7"
                           HorizontalOptions="Center" />

        <BoxView HeightRequest="1" BackgroundColor="#333" Margin="0,8" />

        <Button Text="Sign in with Google"
                Command="{Binding LoginWithGoogleCommand}"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                BackgroundColor="#1E1E1E"
                TextColor="White"
                BorderColor="#555"
                BorderWidth="1"
                CornerRadius="8" />

        <Button Text="Sign in with Face ID"
                Command="{Binding LoginWithBiometricCommand}"
                IsVisible="{Binding IsBiometricAvailable}"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                BackgroundColor="#1E1E1E"
                TextColor="White"
                BorderColor="#A5D6A7"
                BorderWidth="1"
                CornerRadius="8" />

    </VerticalStackLayout>

</ContentPage>
