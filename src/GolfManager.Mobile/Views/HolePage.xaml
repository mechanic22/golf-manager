<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GolfManager.Mobile.ViewModels"
             xmlns:models="clr-namespace:GolfManager.Mobile.Models"
             x:Class="GolfManager.Mobile.Views.HolePage"
             x:DataType="vm:HoleViewModel"
             x:Name="thisPage"
             Title="{Binding HoleTitle}"
             BackgroundColor="#121212">

    <Grid RowDefinitions="*, Auto">

        <!-- Distance tab content -->
        <Grid Grid.Row="0" RowDefinitions="Auto,*,Auto" Padding="20"
              IsVisible="{Binding IsDistanceTab}">

            <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,16">
                <Label Text="{Binding HoleTitle}"
                       FontSize="28" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="White" />
                <Label Text="{Binding HoleSubtitle}"
                       FontSize="14" HorizontalOptions="Center" TextColor="#888" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="1" Spacing="24"
                                 VerticalOptions="Center" HorizontalOptions="Center">
                <Border BackgroundColor="#1E1E1E" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="24,20">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="{Binding DistanceFront, StringFormat='{0:0}'}"
                                       FontSize="32" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center" />
                                <Label Text="FRONT" FontSize="11" TextColor="#A5D6A7"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                <Label Text="{Binding DistanceCenter, StringFormat='{0:0}'}"
                                       FontSize="48" FontAttributes="Bold"
                                       TextColor="#FFEB3B" HorizontalOptions="Center" />
                                <Label Text="CENTER" FontSize="11" TextColor="#A5D6A7"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                <Label Text="{Binding DistanceBack, StringFormat='{0:0}'}"
                                       FontSize="32" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center" />
                                <Label Text="BACK" FontSize="11" TextColor="#A5D6A7"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                        <Label Text="yards" FontSize="13" TextColor="#666"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding GpsStatusText}"
                       FontSize="12" TextColor="#666"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Row="2" Spacing="16"
                                   HorizontalOptions="Center" Margin="0,0,0,8">
                <Button Text="&#9664;" Command="{Binding PreviousHoleCommand}"
                        WidthRequest="52" HeightRequest="44"
                        BackgroundColor="#2E7D32" TextColor="White" CornerRadius="8" />
                <Label Text="{Binding CurrentHoleNumber, StringFormat='Hole {0}'}"
                       VerticalOptions="Center" FontSize="18" TextColor="White"
                       MinimumWidthRequest="80" HorizontalTextAlignment="Center" />
                <Button Text="&#9654;" Command="{Binding NextHoleCommand}"
                        WidthRequest="52" HeightRequest="44"
                        BackgroundColor="#2E7D32" TextColor="White" CornerRadius="8" />
            </HorizontalStackLayout>

        </Grid>

        <!-- Scores tab content -->
        <Grid Grid.Row="0" RowDefinitions="Auto,*,Auto" Padding="20"
              IsVisible="{Binding IsScoresTab}">

            <Label Grid.Row="0"
                   Text="{Binding HoleTitle}"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center" TextColor="White"
                   Margin="0,0,0,16" />

            <CollectionView Grid.Row="1" ItemsSource="{Binding PlayerScores}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PlayerScore">
                        <Grid ColumnDefinitions="*,Auto,52,Auto"
                              ColumnSpacing="8" Padding="0,10">
                            <Label Grid.Column="0"
                                   Text="{Binding PlayerName}"
                                   VerticalOptions="Center" TextColor="White"
                                   FontSize="16" />
                            <Button Grid.Column="1" Text="&#8722;"
                                    Command="{Binding Source={x:Reference thisPage}, Path=BindingContext.DecrementScoreCommand}"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="44" HeightRequest="44"
                                    BackgroundColor="#333" TextColor="White"
                                    CornerRadius="8" />
                            <Label Grid.Column="2"
                                   Text="{Binding Score}"
                                   FontSize="24" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" TextColor="White" />
                            <Button Grid.Column="3" Text="+"
                                    Command="{Binding Source={x:Reference thisPage}, Path=BindingContext.IncrementScoreCommand}"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="44" HeightRequest="44"
                                    BackgroundColor="#2E7D32" TextColor="White"
                                    CornerRadius="8" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Grid.Row="2"
                    Text="Save Scores"
                    Command="{Binding SaveScoresCommand}"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvertBoolConverter}}"
                    BackgroundColor="#1B5E20" TextColor="White"
                    FontAttributes="Bold" FontSize="16"
                    CornerRadius="8" Margin="0,12,0,0" />
        </Grid>

        <!-- Custom tab bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*"
              BackgroundColor="#1B5E20" HeightRequest="52">
            <Button Grid.Column="0" Text="Distance"
                    Command="{Binding ShowDistanceCommand}"
                    BackgroundColor="{Binding IsDistanceTab, Converter={StaticResource ActiveTabColorConverter}}"
                    TextColor="White" FontSize="15" BorderWidth="0"
                    CornerRadius="0" />
            <Button Grid.Column="1" Text="Scores"
                    Command="{Binding ShowScoresCommand}"
                    BackgroundColor="{Binding IsScoresTab, Converter={StaticResource ActiveTabColorConverter}}"
                    TextColor="White" FontSize="15" BorderWidth="0"
                    CornerRadius="0" />
        </Grid>

    </Grid>

</ContentPage>
