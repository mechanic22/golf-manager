{
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-sql-server;Database=GolfManager;User Id=your-user;Password=your-password;TrustServerCertificate=True"
  },
  "DatabaseProvider": "SqlServer",
  "Jwt": {
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLongForHS256Algorithm",
    "Issuer": "GolfManager",
    "Audience": "GolfManager",
    "AccessTokenExpirationMinutes": "60",
    "RefreshTokenExpirationDays": "30"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CustomDomainVerification": {
    "AllowedIps": [
      "127.0.0.1",
      "::1"
    ],
    "RequireTxtRecord": true,
    "TxtRecordPrefix": "_golfmanager"
  }
}
