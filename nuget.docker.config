<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- clear removes nuget.org defined in the SDK image's user-level NuGet.Config -->
    <clear />
    <!-- local-packages is a fallback for vendor .nupkg files not yet on a remote feed -->
    <add key="local-packages" value="./local-packages" />
  </packageSources>
</configuration>
