<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Default NuGet.org source -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    
    <!-- Local vendor packages — drop .nupkg files here for packages not yet on nuget.org -->
    <add key="local-packages" value="./local-packages" />
  </packageSources>
</configuration>

