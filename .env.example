# GolfManager v2 - Environment Variables Template
# Copy this file to .env and update with your values
# DO NOT commit .env to source control!

# Database Configuration
# =====================

# Database Provider: Sqlite | SqlServer | PostgreSQL
DatabaseProvider=SqlServer

# SQLite (Development)
# ConnectionStrings__DefaultConnection=Data Source=GolfManager.db

# SQL Server (Production - Azure SQL)
ConnectionStrings__DefaultConnection=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=GolfManager;User ID=your-user;Password=YourPassword123!;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# SQL Server (Production - AWS RDS)
# ConnectionStrings__DefaultConnection=Server=your-db.rds.amazonaws.com;Database=GolfManager;User Id=admin;Password=YourPassword123!;Encrypt=True;TrustServerCertificate=True

# SQL Server (Development - LocalDB on Windows)
# ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=GolfManager;Trusted_Connection=True;MultipleActiveResultSets=true

# JWT Configuration
# =================
Jwt__SecretKey=YourSuperSecretKeyThatIsAtLeast32CharactersLongForHS256Algorithm
Jwt__Issuer=GolfManager
Jwt__Audience=GolfManager
Jwt__AccessTokenExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=30

# CORS Configuration
# ==================
# Comma-separated list of allowed origins (for production)
# AllowedOrigins=https://yourdomain.com,https://www.yourdomain.com

# Logging
# =======
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
Logging__LogLevel__Microsoft.EntityFrameworkCore=Warning

# Application Settings
# ====================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://+:443;http://+:80

# Azure-specific (if deploying to Azure App Service)
# ===================================================
# WEBSITE_HTTPLOGGING_RETENTION_DAYS=7
# APPINSIGHTS_INSTRUMENTATIONKEY=your-key-here

# AWS-specific (if deploying to AWS)
# ===================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
